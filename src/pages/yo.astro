---
import Layout from '../layouts/Layout.astro';
import {
  getUserBySession,
  createSession,
  deleteSession,
  hashPassword,
  getUserBadges,
  type User,
} from '../lib/auth';

const env = Astro.locals.runtime.env;
let user: (User & { isGuest?: boolean }) | null = await getUserBySession(Astro.cookies, env);
let errorMsg = '';
let successMsg = '';
let activeTab = 'login'; // login | register

// Verificar si tiene cookie de invitado activa
const isGuest = Astro.cookies.get('edificarte_guest')?.value === 'true';

// Si es guest, leer su nombre desde una cookie sibling que setea el modal
// de bienvenida (src/pages/index.astro). Esto permite pre-rellenar el
// formulario de registro para que conserve su identidad al crear la cuenta.
let guestPrefillName = '';
if (isGuest) {
  guestPrefillName = Astro.cookies.get('edificarte_guest_name')?.value || '';
}

if (!user && isGuest) {
  user = {
    id: 'guest',
    email: 'invitado@edificarte.app',
    name: 'Edificador Invitado',
    avatar_url: '👷',
    bio: 'Explorando EdificARTE como invitado. ¡Creá una cuenta para guardar tu progreso on-chain de forma permanente!',
    points: 0,
    likes: 0,
    visits: 0,
    phone: null,
    created_at: new Date().toISOString(),
    isGuest: true
  } satisfies User & { isGuest: boolean };
}

// Manejo de peticiones POST (acciones de autenticación y perfil)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action');

    if (action === 'register') {
      activeTab = 'register';
      const name = formData.get('name')?.toString().trim();
      const email = formData.get('email')?.toString().trim().toLowerCase();
      const password = formData.get('password')?.toString();

      if (!name || !email || !password) {
        errorMsg = 'Completá todos los campos, por favor.';
      } else {
        // Verificar si el correo ya existe
        const existing = await env.DB.prepare('SELECT id FROM users WHERE email = ?')
          .bind(email)
          .first();

        if (existing) {
          errorMsg = 'El correo electrónico ya está registrado.';
        } else {
          const userId = crypto.randomUUID();
          const hashedPassword = await hashPassword(password);
          
          // Avatar por defecto de edificador (Emoji)
          const avatarUrl = '👷';
          const bio = '¡Hola! Soy un nuevo edificador explorando el patrimonio cultural con EdificARTE.';

          await env.DB.prepare(
            'INSERT INTO users (id, email, password, name, avatar_url, bio, points, likes, visits) VALUES (?, ?, ?, ?, ?, ?, 0, 0, 0)'
          )
            .bind(userId, email, hashedPassword, name, avatarUrl, bio)
            .run();

          // Eliminar cookie de invitado si existía
          Astro.cookies.delete('edificarte_guest', { path: '/' });
          Astro.cookies.delete('edificarte_guest_name', { path: '/' });

          // Crear sesión
          await createSession(Astro.cookies, env, userId);
          return Astro.redirect('/mapa?welcome=1');
        }
      }
    } else if (action === 'login') {
      activeTab = 'login';
      const email = formData.get('email')?.toString().trim().toLowerCase();
      const password = formData.get('password')?.toString();

      if (!email || !password) {
        errorMsg = 'Ingresá tu correo y contraseña.';
      } else {
        const hashedPassword = await hashPassword(password);
        const { results } = await env.DB.prepare(
          'SELECT * FROM users WHERE email = ? AND password = ?'
        )
          .bind(email, hashedPassword)
          .all();

        const dbUser = results[0];
        if (!dbUser) {
          errorMsg = 'Correo o contraseña incorrectos.';
        } else {
          // Eliminar cookie de invitado si existía
          Astro.cookies.delete('edificarte_guest', { path: '/' });

          await createSession(Astro.cookies, env, dbUser.id);
          return Astro.redirect('/yo');
        }
      }
    } else if (action === 'guest') {
      // Iniciar sesión como invitado temporal
      // NOTA: NO httpOnly — el cliente (modal de bienvenida, botón "registrarse")
      // necesita poder escribir/leer esta cookie. La cookie real de sesión
      // (edificarte_session) SÍ es httpOnly, así que la seguridad sigue cubierta.
      Astro.cookies.set('edificarte_guest', 'true', {
        path: '/',
        httpOnly: false,
        secure: import.meta.env.PROD,
        sameSite: 'lax',
        maxAge: 60 * 60 * 24 * 365 // 1 año
      });
      return Astro.redirect('/yo');
    } else if (action === 'edit_profile') {
      const isGuestCookie = Astro.cookies.get('edificarte_guest')?.value === 'true';
      if (!user || isGuestCookie) return Astro.redirect('/yo');

      const name = formData.get('name')?.toString().trim();
      const bio = formData.get('bio')?.toString().trim();
      const avatarUrl = formData.get('avatar_url')?.toString().trim();

      if (!name) {
        errorMsg = 'El nombre no puede estar vacío.';
      } else {
        await env.DB.prepare(
          'UPDATE users SET name = ?, bio = ?, avatar_url = ? WHERE id = ?'
        )
          .bind(name, bio || '', avatarUrl || '', user.id)
          .run();

        successMsg = 'Perfil actualizado con éxito.';
        // Recargar datos del usuario
        user = await getUserBySession(Astro.cookies, env);
      }
    } else if (action === 'logout') {
      await deleteSession(Astro.cookies, env);
      Astro.cookies.delete('edificarte_guest', { path: '/' });
      return Astro.redirect('/yo');
    }
  } catch (err: unknown) {
    errorMsg = `Ocurrió un error: ${err instanceof Error ? err.message : String(err)}`;
  }
}

const unlockedBadges = user && !isGuest ? await getUserBadges(env, user.id) : [];

let walletAddress: string | null = null;
if (user && !isGuest) {
  const walletRow = await env.DB.prepare(
    'SELECT address FROM user_wallets WHERE user_id = ? LIMIT 1'
  )
    .bind(user.id)
    .first<{ address: string }>();
  if (walletRow) {
    walletAddress = walletRow.address;
  }
}

const badges = [
  {
    id: 1,
    name: 'Explorador Romano',
    description: 'Reproduce la audioguía del Palacio de Bellas Artes.',
    image:
      'https://images.unsplash.com/photo-1552832230-c0197dd311b5?auto=format&fit=crop&w=150&h=150&q=80',
    unlocked: unlockedBadges.includes(1),
  },
  {
    id: 2,
    name: 'Alma Gótica',
    description: 'Reproduce la audioguía de la Catedral Metropolitana.',
    image:
      'https://images.unsplash.com/photo-1543872084-c7bd3822856f?auto=format&fit=crop&w=150&h=150&q=80',
    unlocked: unlockedBadges.includes(2),
  },
  {
    id: 3,
    name: 'Legado Virreinal',
    description: 'Reproduce la audioguía del Hotel Virreyes.',
    image:
      'https://coming-aqua-flyingfish.myfilebase.com/ipfs/QmSb45pdEwGTuJFivhHuaRwZZFX83nrx4Gki1o5cCXqDo1',
    unlocked: unlockedBadges.includes(3),
  },
  {
    id: 4,
    name: 'Cazador de Templos',
    description: 'Reproduce la audioguía del Templo Mayor.',
    image:
      'https://images.unsplash.com/photo-1508849789987-4e5333c12b78?auto=format&fit=crop&w=150&h=150&q=80',
    unlocked: unlockedBadges.includes(4),
  },
];

const isEmoji = (str: string) => {
  if (!str) return false;
  return !str.includes('/') && !str.includes('.') && !str.startsWith('http');
};
---

<Layout title="EdificARTE - Yo">
  {user ? (
    /* =========================================================================
       VISTA DEL PANEL DE USUARIO AUTENTICADO
       ========================================================================= */
    <div
      id="profile-container"
      data-has-wallet={walletAddress ? "true" : "false"}
      data-is-guest={isGuest ? "true" : "false"}
      data-wallet-address={walletAddress || ""}
      class="mx-auto grid max-w-screen-md grid-cols-1 gap-8 md:grid-cols-3"
    >
      <!-- Mensajes flotantes de alerta/éxito -->
      {successMsg && (
        <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[9999] flex items-center gap-2 rounded-xl border border-green-200/50 bg-green-50 px-4 py-3 text-sm text-green-800 shadow-lg dark:border-green-850/50 dark:bg-green-950/40 dark:text-green-200">
          <span class="material-symbols-outlined text-[18px]">check_circle</span>
          {successMsg}
        </div>
      )}
      {errorMsg && (
        <div class="fixed top-6 left-1/2 -translate-x-1/2 z-[9999] flex items-center gap-2 rounded-xl border border-rose-200/50 bg-rose-50 px-4 py-3 text-sm text-rose-800 shadow-lg dark:border-rose-850/50 dark:bg-rose-950/40 dark:text-rose-200">
          <span class="material-symbols-outlined text-[18px]">error</span>
          {errorMsg}
        </div>
      )}

      {isGuest && (
        <div id="is-guest-flag" class="hidden"></div>
      )}

      <!-- Columna Izquierda: Tarjeta de Perfil -->
      <div class="flex flex-col justify-start md:col-span-1">
        <div class="relative mx-auto w-full max-w-sm rounded-[2rem] border border-slate-200/60 bg-white shadow-lg dark:border-slate-800/60 dark:bg-slate-900">
          <!-- Banner Superior -->
          <div class="relative h-40 overflow-hidden rounded-t-[2rem] bg-gradient-to-br from-brand-500 to-purple-600">
            <div class="absolute inset-0 bg-black/10"></div>
          </div>

          <!-- Botón de Opciones -->
          <div class="absolute right-4 top-4 z-30">
            <button
              id="settings-btn"
              class="rounded-full border border-white/30 bg-white/20 p-2 text-white shadow-sm backdrop-blur-md transition-all hover:bg-white/30"
              aria-label="Configuración"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
              >
                <circle cx="12" cy="12" r="1"></circle>
                <circle cx="12" cy="5" r="1"></circle>
                <circle cx="12" cy="19" r="1"></circle>
              </svg>
            </button>

            <!-- Menú Desplegable -->
            <div
              id="settings-dropdown"
              class="absolute right-0 z-50 mt-2 hidden w-48 rounded-2xl border border-slate-200/50 bg-white/95 p-2 text-slate-800 shadow-xl backdrop-blur-md transition-all duration-200 dark:border-slate-800/50 dark:bg-slate-900/95 dark:text-white"
            >
              <button
                id="edit-profile-btn"
                class="flex w-full items-center gap-3 rounded-xl px-3 py-2 text-left text-sm transition-colors hover:bg-slate-100 dark:hover:bg-slate-800"
              >
                <span class="material-symbols-outlined text-[18px] text-brand-500">edit</span>
                <span>Editar Perfil</span>
              </button>
              <hr class="my-1 border-slate-200/60 dark:border-slate-800/60" />
              <form method="POST" action="/yo" class="w-full">
                <input type="hidden" name="action" value="logout" />
                <button
                  type="submit"
                  class="flex w-full items-center gap-3 rounded-xl px-3 py-2 text-left text-sm text-red-600 transition-colors hover:bg-red-50 dark:hover:bg-red-950/20"
                >
                  <span class="material-symbols-outlined text-[18px]">logout</span>
                  <span>{isGuest ? 'Salir de Invitado' : 'Cerrar Sesión'}</span>
                </button>
              </form>
            </div>
          </div>

          <!-- Contenido del Perfil -->
          <div class="-mt-12 px-6 pb-6">
            <!-- Avatar -->
            <div class="relative mb-4 h-24 w-24" id="avatar-container-outer">
              {user.avatar_url && isEmoji(user.avatar_url) ? (
                <div class="flex h-full w-full items-center justify-center rounded-full border-4 border-white bg-brand-50 text-4xl shadow-lg dark:border-slate-900 dark:bg-slate-850" id="profile-avatar-emoji">
                  {user.avatar_url}
                </div>
              ) : (
                <div class="h-full w-full overflow-hidden rounded-full border-4 border-white bg-white shadow-lg dark:border-slate-900 dark:bg-slate-900">
                  <img
                    src={user.avatar_url ?? ''}
                    alt={user.name}
                    class="h-full w-full object-cover"
                    id="profile-avatar-img"
                  />
                </div>
              )}
            </div>

            <!-- Experiencia (Puntos / Nivel) -->
            <div class="mb-4">
              <div class="mb-1 flex items-center justify-between text-xs">
                <span id="level-label" class="font-bold text-brand-500 uppercase tracking-wider">Nivel {Math.floor(user.points / 500) + 1}</span>
                <span id="exp-label" class="text-slate-400">{user.points % 500} / 500 exp</span>
              </div>
              <div class="h-2 w-full overflow-hidden rounded-full bg-slate-100 dark:bg-slate-800">
                <div
                  id="exp-bar"
                  data-percent={`${((user.points % 500) / 500) * 100}%`}
                  class="h-full w-0 bg-gradient-to-r from-brand-500 to-purple-600 transition-all duration-[1300ms] ease-out"
                >
                </div>
              </div>
            </div>

            <!-- Nombre e Info -->
            <h2 class="mb-1 text-2xl font-bold text-slate-800 dark:text-white" id="profile-user-name">
              {user.name}
            </h2>
            <p class="mb-4 text-xs font-medium text-slate-400 dark:text-slate-500">
              {isGuest ? 'Cuenta Temporal de Invitado' : `Edificador desde ${new Date(user.created_at).toLocaleDateString('es-MX', { month: 'long', year: 'numeric' })}`}
            </p>
            <p class="mb-6 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
              {user.bio}
            </p>

            <!-- Estadísticas D1 -->
            <div class="grid grid-cols-3 gap-4 border-t border-slate-100 pt-4 dark:border-slate-800">
              <div class="text-center">
                <div class="mb-1 text-xl font-bold text-slate-800 dark:text-white">
                  {user.likes}
                </div>
                <div class="text-[10px] uppercase font-bold tracking-wider text-slate-400">Me gusta</div>
              </div>
              <div class="border-l border-r border-slate-100 text-center dark:border-slate-800">
                <div id="stats-visits" class="mb-1 text-xl font-bold text-slate-800 dark:text-white">
                  {user.visits}
                </div>
                <div class="text-[10px] uppercase font-bold tracking-wider text-slate-400">Visitas</div>
              </div>
              <div class="text-center">
                <div id="stats-points" class="mb-1 text-xl font-bold text-slate-800 dark:text-white">
                  {user.points}
                </div>
                <div class="text-[10px] uppercase font-bold tracking-wider text-slate-400">Puntos</div>
              </div>
            </div>
          </div>
        </div>
        {isGuest && (
          <div class="mt-4 rounded-3xl border border-[#3f043a]/10 bg-gradient-to-br from-[#3f043a]/5 to-purple-500/5 p-5 text-center shadow-sm backdrop-blur-md">
            <span class="material-symbols-outlined text-[30px] text-[#3f043a] mb-2 select-none">cloud_upload</span>
            <h4 class="text-xs font-bold text-slate-800 dark:text-white uppercase tracking-wider">Guardar Progreso</h4>
            <p class="mt-1 text-[11px] leading-relaxed text-slate-500 dark:text-slate-400">
              Registrate para guardar tu progreso, insignias y visitas de forma permanente en la nube.
            </p>
            <button
              id="btn-guest-register-cta"
              class="mt-3.5 w-full rounded-xl bg-[#3f043a] py-2.5 text-xs font-bold text-white shadow-sm hover:bg-[#3f043a]/90 transition-all active:scale-[0.97]"
            >
              Registrarse ahora
            </button>
          </div>
        )}

        {!isGuest && walletAddress && (
          <div class="mt-4 rounded-3xl border border-emerald-500/10 bg-gradient-to-br from-emerald-500/5 to-teal-500/5 p-5 text-center shadow-sm backdrop-blur-md">
            <span class="material-symbols-outlined text-[30px] text-emerald-500 mb-2 select-none">account_balance_wallet</span>
            <h4 class="text-xs font-bold text-slate-800 dark:text-white uppercase tracking-wider">Wallet Vinculada</h4>
            <p class="mt-1 text-[11px] font-mono text-slate-500 dark:text-slate-400 break-all bg-slate-50 dark:bg-slate-900/60 p-2 rounded-xl">
              {walletAddress}
            </p>
            <a
              href={`https://polygonscan.com/address/${walletAddress}`}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3.5 inline-flex w-full items-center justify-center gap-1 rounded-xl border border-slate-200/80 bg-white py-2 text-xs font-bold text-slate-600 hover:bg-slate-50 dark:border-slate-800 dark:bg-slate-950/40 dark:text-slate-400 transition-all"
            >
              <span>Ver en PolygonScan</span>
              <span class="material-symbols-outlined text-[14px]">open_in_new</span>
            </a>
          </div>
        )}

        {!isGuest && !walletAddress && (
          <div class="mt-4 rounded-3xl border border-indigo-500/10 bg-gradient-to-br from-indigo-500/5 to-purple-500/5 p-5 text-center shadow-sm backdrop-blur-md">
            <span class="material-symbols-outlined text-[30px] text-indigo-500 mb-2 select-none">account_balance_wallet</span>
            <h4 class="text-xs font-bold text-slate-800 dark:text-white uppercase tracking-wider">¿Vincular Billetera?</h4>
            <p class="mt-1 text-[11px] leading-relaxed text-slate-500 dark:text-slate-400">
              Vinculá tu wallet para que tus visitas y logros se guarden automáticamente como coleccionables NFT.
            </p>
            <button
              id="btn-profile-wallet-connect"
              class="mt-3.5 w-full rounded-xl bg-indigo-600 py-2.5 text-xs font-bold text-white shadow-sm hover:bg-indigo-700 transition-all active:scale-[0.97]"
            >
              Conectar Wallet
            </button>
          </div>
        )}
      </div>

      <!-- Columna Derecha: Insignias -->
      <div class="space-y-8 md:col-span-2">
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">
              Mis Coleccionables (Badges)
            </h2>
            <span id="badges-count-label" class="rounded-full bg-brand-50 px-2.5 py-1 text-xs font-semibold text-brand-600 dark:bg-brand-950/40 dark:text-brand-400">
              {badges.filter((b) => b.unlocked).length} Ganados
            </span>
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {badges.map((badge) => (
              <div id={`badge-card-${badge.id}`} class="group flex flex-col items-center justify-center space-y-3 rounded-2xl border border-slate-200/60 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:border-brand-200/50 hover:shadow-md dark:border-slate-800/60 dark:bg-slate-900 dark:hover:border-brand-900">
                <div class="relative flex h-16 w-16 items-center justify-center overflow-hidden rounded-full border border-slate-200/80 bg-slate-50 shadow-inner dark:border-slate-800">
                  <img
                    src={badge.image}
                    alt={badge.name}
                    class={`h-full w-full object-cover transition-all duration-500 group-hover:scale-110 ${badge.unlocked ? '' : 'opacity-35 grayscale'}`}
                  />
                  <div class={`lock-icon-container absolute inset-0 flex items-center justify-center bg-black/20 ${badge.unlocked ? 'hidden' : ''}`}>
                    <span class="material-symbols-outlined text-[20px] text-white drop-shadow">lock</span>
                  </div>
                </div>
                <div>
                  <h3 class={`text-sm font-bold ${badge.unlocked ? 'text-slate-800 dark:text-slate-200' : 'text-slate-400 dark:text-slate-600'}`}>
                    {badge.name}
                  </h3>
                  <p class="mt-1 text-[11px] leading-snug text-slate-400 dark:text-slate-500">
                    {badge.unlocked
                      ? '¡Completado! Ya tienes esta insignia en tu billetera.'
                      : badge.description}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Mis Reservas (tours) — leído de localStorage -->
        <section class="space-y-4" aria-labelledby="reservations-heading">
          <div class="flex items-center justify-between">
            <h2 id="reservations-heading" class="text-lg font-bold text-slate-800 dark:text-slate-200">
              Mis Reservas
            </h2>
            <span id="reservations-count-label" class="rounded-full bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-950/30 dark:text-amber-300">
              0 Reservas
            </span>
          </div>

          <div id="reservations-list" class="grid grid-cols-1 gap-3 sm:grid-cols-2"></div>

          <div id="reservations-empty" class="hidden rounded-2xl border border-dashed border-slate-200 bg-white/60 p-6 text-center dark:border-slate-800 dark:bg-slate-900/40">
            <span class="material-symbols-outlined text-[28px] text-slate-300 dark:text-slate-600 select-none">event_busy</span>
            <p class="mt-2 text-xs font-semibold text-slate-500 dark:text-slate-400">
              Aún no tenés reservas de recorridos guiados.
            </p>
            <p class="mt-1 text-[11px] text-slate-400 dark:text-slate-500">
              Explorá la sección Turismo de la página principal para reservar tu primer tour.
            </p>
          </div>
        </section>

        <!-- Mis Favoritos — leído de localStorage -->
        <section class="space-y-4" aria-labelledby="favorites-heading">
          <div class="flex items-center justify-between">
            <h2 id="favorites-heading" class="text-lg font-bold text-slate-800 dark:text-slate-200">
              Mis Favoritos
            </h2>
            <span id="favorites-count-label" class="rounded-full bg-rose-50 px-2.5 py-1 text-xs font-semibold text-rose-600 dark:bg-rose-950/30 dark:text-rose-300">
              0 Favoritos
            </span>
          </div>

          <div id="favorites-list" class="grid grid-cols-2 gap-3 sm:grid-cols-3"></div>

          <div id="favorites-empty" class="hidden rounded-2xl border border-dashed border-slate-200 bg-white/60 p-6 text-center dark:border-slate-800 dark:bg-slate-900/40">
            <span class="material-symbols-outlined text-[28px] text-slate-300 dark:text-slate-600 select-none">favorite</span>
            <p class="mt-2 text-xs font-semibold text-slate-500 dark:text-slate-400">
              Aún no tenés favoritos guardados.
            </p>
            <p class="mt-1 text-[11px] text-slate-400 dark:text-slate-500">
              Pulsá el ♥ en cualquier experiencia para guardarla aquí.
            </p>
          </div>
        </section>
      </div>

      <!-- Modal de Edición de Perfil (Oculto) -->
      <div id="edit-profile-modal" class="fixed inset-0 z-[100] [&:not(.hidden)]:flex hidden items-center justify-center bg-black/50 p-4 backdrop-blur-sm">
        <div class="w-full max-w-md rounded-3xl border border-slate-200/50 bg-white/95 p-6 shadow-2xl backdrop-blur-xl dark:border-slate-800/50 dark:bg-slate-900/95">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold text-slate-800 dark:text-white">Editar Perfil</h3>
            <button id="close-modal-btn" class="rounded-full p-1 text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
          <form method="POST" action="/yo" class="space-y-4">
            <input type="hidden" name="action" value="edit_profile" />
            
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Nombre</label>
              <input
                type="text"
                name="name"
                required
                value={user.name}
                class="w-full rounded-xl border border-slate-200 bg-transparent px-4 py-2.5 text-sm outline-none focus:border-brand-500 dark:border-slate-800"
              />
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Biografía</label>
              <textarea
                name="bio"
                rows="3"
                class="w-full rounded-xl border border-slate-200 bg-transparent px-4 py-2.5 text-sm outline-none focus:border-brand-500 dark:border-slate-800 resize-none"
              >{user.bio}</textarea>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-3">Elige tu Avatar (Emoji)</label>
              <input
                type="hidden"
                id="avatar-emoji-input"
                name="avatar_url"
                value={user.avatar_url}
              />
              <div class="grid grid-cols-6 gap-2" id="emoji-selector-grid">
                {['👷', '🏛️', '🧭', '🎨', '🎒', '👑', '🦊', '🚀', '🐱', '🦖', '🐼', '🌮'].map((emoji) => (
                  <button
                    type="button"
                    data-emoji={emoji}
                    class={`flex h-11 w-11 items-center justify-center rounded-2xl text-2xl border transition-all active:scale-90 hover:bg-slate-100 dark:hover:bg-slate-800 ${
                      user.avatar_url === emoji
                        ? 'border-brand-500 bg-brand-50 dark:bg-brand-950/40'
                        : 'border-slate-100 dark:border-slate-800 bg-transparent'
                    }`}
                  >
                    {emoji}
                  </button>
                ))}
              </div>
            </div>

            <button
              type="submit"
              class="w-full rounded-xl bg-brand-500 py-3 text-sm font-semibold text-white shadow-md hover:bg-brand-600 transition-all active:scale-95"
            >
              Guardar Cambios
            </button>
          </form>
        </div>
      </div>
    </div>
  ) : (
    /* =========================================================================
       VISTA DE INICIO DE SESIÓN / REGISTRO (GUEST)
       ========================================================================= */
    <div class="mx-auto max-w-md py-6">
      <div class="relative overflow-hidden rounded-[2.5rem] border border-white/20 bg-white/80 p-8 shadow-2xl backdrop-blur-xl dark:border-slate-800/60 dark:bg-slate-900/80">
        <!-- Glowing Ambient Circle -->
        <div class="absolute -right-20 -top-20 -z-10 h-48 w-48 rounded-full bg-brand-500/10 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 -z-10 h-48 w-48 rounded-full bg-purple-500/10 blur-3xl"></div>

        <!-- Header -->
        <div class="text-center mb-6">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-tr from-brand-500 to-purple-600 text-white shadow-lg mb-4">
            <span class="material-symbols-outlined text-[30px]">account_balance</span>
          </div>
          <h2 class="text-2xl font-bold tracking-tight text-slate-800 dark:text-white">EdificARTE</h2>
          <p class="mt-1 text-sm text-slate-400 dark:text-slate-500">Colecciona insignias e historia urbana</p>
        </div>

        <!-- Selector de Pestañas (Tabs) -->
        <div class="flex rounded-xl bg-slate-100/80 p-1 mb-6 dark:bg-slate-800/80">
          <button
            type="button"
            id="tab-login"
            class={`flex-1 rounded-lg py-2 text-xs font-bold transition-all ${
              activeTab === 'login'
                ? 'bg-white text-slate-800 shadow-sm dark:bg-slate-700 dark:text-white'
                : 'text-slate-400 hover:text-slate-600'
            }`}
          >
            Iniciar Sesión
          </button>
          <button
            type="button"
            id="tab-register"
            class={`flex-1 rounded-lg py-2 text-xs font-bold transition-all ${
              activeTab === 'register'
                ? 'bg-white text-slate-800 shadow-sm dark:bg-slate-700 dark:text-white'
                : 'text-slate-400 hover:text-slate-600'
            }`}
          >
            Registrarse
          </button>
        </div>

        <!-- Alertas de Error -->
        {errorMsg && (
          <div class="mb-4 flex items-center gap-2 rounded-xl bg-rose-50 border border-rose-100 p-3 text-xs font-semibold text-rose-700 dark:bg-rose-950/20 dark:border-rose-900/30 dark:text-rose-400">
            <span class="material-symbols-outlined text-[16px]">error</span>
            {errorMsg}
          </div>
        )}

        <!-- Formulario de Iniciar Sesión -->
        <form
          id="form-login"
          method="POST"
          action="/yo"
          class={`space-y-4 ${activeTab === 'login' ? '' : 'hidden'}`}
        >
          <input type="hidden" name="action" value="login" />
          
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[18px] text-slate-400">mail</span>
            <input
              type="email"
              name="email"
              required
              placeholder="Correo electrónico"
              class="w-full rounded-2xl border border-slate-200/60 bg-white/40 py-3 pl-12 pr-4 text-sm outline-none focus:border-brand-500 focus:bg-white dark:border-slate-800 dark:bg-slate-950/40 dark:focus:bg-slate-950 transition-all"
            />
          </div>

          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[18px] text-slate-400">lock</span>
            <input
              type="password"
              name="password"
              required
              placeholder="Contraseña"
              class="w-full rounded-2xl border border-slate-200/60 bg-white/40 py-3 pl-12 pr-4 text-sm outline-none focus:border-brand-500 focus:bg-white dark:border-slate-800 dark:bg-slate-950/40 dark:focus:bg-slate-950 transition-all"
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-2xl bg-gradient-to-r from-brand-500 to-brand-600 py-3.5 text-sm font-semibold text-white shadow-lg hover:from-brand-600 hover:to-brand-700 transition-all active:scale-[0.98]"
          >
            Entrar
          </button>
        </form>

        <!-- Formulario de Registro -->
        <form
          id="form-register"
          method="POST"
          action="/yo"
          class={`space-y-4 ${activeTab === 'register' ? '' : 'hidden'}`}
        >
          <input type="hidden" name="action" value="register" />

          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[18px] text-slate-400">person</span>
            <input
              type="text"
              name="name"
              required
              placeholder="Nombre completo"
              value={guestPrefillName}
              class="w-full rounded-2xl border border-slate-200/60 bg-white/40 py-3 pl-12 pr-4 text-sm outline-none focus:border-brand-500 focus:bg-white dark:border-slate-800 dark:bg-slate-950/40 dark:focus:bg-slate-950 transition-all"
            />
          </div>
          
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[18px] text-slate-400">mail</span>
            <input
              type="email"
              name="email"
              required
              placeholder="Correo electrónico"
              class="w-full rounded-2xl border border-slate-200/60 bg-white/40 py-3 pl-12 pr-4 text-sm outline-none focus:border-brand-500 focus:bg-white dark:border-slate-800 dark:bg-slate-950/40 dark:focus:bg-slate-950 transition-all"
            />
          </div>

          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[18px] text-slate-400">lock</span>
            <input
              type="password"
              name="password"
              required
              placeholder="Contraseña"
              class="w-full rounded-2xl border border-slate-200/60 bg-white/40 py-3 pl-12 pr-4 text-sm outline-none focus:border-brand-500 focus:bg-white dark:border-slate-800 dark:bg-slate-950/40 dark:focus:bg-slate-950 transition-all"
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-2xl bg-gradient-to-r from-purple-500 to-purple-600 py-3.5 text-sm font-semibold text-white shadow-lg hover:from-purple-600 hover:to-purple-700 transition-all active:scale-[0.98]"
          >
            Registrarse
          </button>

          {/* Link "¿Ya tienes cuenta? Inicia sesión" — solo visible en tab register */}
          {activeTab === 'register' && (
            <p class="text-center text-xs text-slate-500 dark:text-slate-400 pt-1">
              ¿Ya tenés cuenta?{' '}
              <button
                type="button"
                id="link-switch-to-login"
                class="font-bold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 transition-colors"
              >
                Iniciá sesión
              </button>
            </p>
          )}
        </form>

        <!-- Separador -->
        <div class="my-5 flex items-center justify-between gap-3 text-xs text-slate-400 select-none">
          <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
          <span>o también</span>
          <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
        </div>

        <!-- Botón de Conectar Wallet (EIP-191 / Sign-In with Ethereum) -->
        <button
          type="button"
          id="btn-wallet-connect"
          class="w-full inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-brand-300 transition-all active:scale-[0.98] dark:border-slate-800 dark:bg-slate-950/40 dark:text-slate-300 dark:hover:bg-slate-900 dark:hover:border-brand-700"
        >
          <span class="material-symbols-outlined text-[18px]">account_balance_wallet</span>
          <span id="btn-wallet-connect-label">Conectar Wallet</span>
        </button>
        <p id="btn-wallet-connect-help" class="text-center text-[10px] text-slate-400 dark:text-slate-500 mt-1.5">
          Inicia sesión firmando un mensaje. Sin gas, sin transacciones.
        </p>

        <!-- Botón de Invitado -->
        <form method="POST" action="/yo" class="w-full">
          <input type="hidden" name="action" value="guest" />
          <button
            type="submit"
            class="w-full rounded-2xl border border-slate-200 bg-white py-3 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition-all active:scale-[0.98] dark:border-slate-800 dark:bg-slate-950/40 dark:text-slate-400 dark:hover:bg-slate-900"
          >
            Continuar como Invitado
          </button>
        </form>
      </div>
    </div>
  )}
</Layout>

<script>
  // Script que corre únicamente del lado del cliente
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Selector de Pestañas (Guest View)
    const tabLogin = document.getElementById('tab-login');
    const tabRegister = document.getElementById('tab-register');
    const formLogin = document.getElementById('form-login');
    const formRegister = document.getElementById('form-register');

    if (tabLogin && tabRegister && formLogin && formRegister) {
      tabLogin.addEventListener('click', () => {
        tabLogin.className = 'flex-1 rounded-lg py-2 text-xs font-bold transition-all bg-white text-slate-800 shadow-sm dark:bg-slate-700 dark:text-white';
        tabRegister.className = 'flex-1 rounded-lg py-2 text-xs font-bold transition-all text-slate-400 hover:text-slate-600';
        formLogin.classList.remove('hidden');
        formRegister.classList.add('hidden');
      });

      tabRegister.addEventListener('click', () => {
        tabRegister.className = 'flex-1 rounded-lg py-2 text-xs font-bold transition-all bg-white text-slate-800 shadow-sm dark:bg-slate-700 dark:text-white';
        tabLogin.className = 'flex-1 rounded-lg py-2 text-xs font-bold transition-all text-slate-400 hover:text-slate-600';
        formRegister.classList.remove('hidden');
        formLogin.classList.add('hidden');
      });
    }

    // 1b. Link "¿Ya tenés cuenta? Iniciá sesión" — switch a tab login
    // desde el form de registro. Simula click en el tab login.
    const linkSwitchToLogin = document.getElementById('link-switch-to-login');
    if (linkSwitchToLogin && tabLogin) {
      linkSwitchToLogin.addEventListener('click', () => {
        tabLogin.click();
        tabLogin.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    // 1c. Wallet Connect (EIP-191 / Sign-In with Ethereum)
    // Flujo: connect() -> pedir nonce -> firmar -> POST /api/wallet-login.
    // Reusa BrowserWalletProvider de src/lib/onchain/client.ts.
    const btnWallet = document.getElementById('btn-wallet-connect') as HTMLButtonElement | null;
    const btnWalletHelp = document.getElementById('btn-wallet-connect-help');

    function setWalletStatus(text: string | null) {
      if (!btnWalletHelp) return;
      if (text === null) {
        btnWalletHelp.textContent = 'Inicia sesión firmando un mensaje. Sin gas, sin transacciones.';
        btnWalletHelp.classList.remove('text-rose-500', 'dark:text-rose-400');
        btnWalletHelp.classList.add('text-slate-400', 'dark:text-slate-500');
      } else {
        btnWalletHelp.textContent = text;
        btnWalletHelp.classList.add('text-rose-500', 'dark:text-rose-400');
        btnWalletHelp.classList.remove('text-slate-400', 'dark:text-slate-500');
      }
    }

    async function connectWallet(isProfileLinking = false, customBtn?: HTMLButtonElement, customBtnLabel?: HTMLElement) {
      const activeBtn = customBtn || (isProfileLinking ? document.getElementById('btn-profile-wallet-connect') : document.getElementById('btn-wallet-connect')) as HTMLButtonElement | null;
      const activeBtnLabel = customBtnLabel || (isProfileLinking ? document.getElementById('btn-profile-wallet-connect') : document.getElementById('btn-wallet-connect-label')) as HTMLElement | null;

      if (!activeBtn) return;
      const originalLabel = activeBtnLabel ? activeBtnLabel.textContent || 'Conectar Wallet' : 'Conectar Wallet';
      
      activeBtn.disabled = true;
      if (activeBtnLabel) activeBtnLabel.textContent = 'Conectando…';
      if (!isProfileLinking) {
        setWalletStatus(null);
      }

      try {
        const { BrowserWalletProvider } = await import('../lib/onchain/client');
        const wallet = new BrowserWalletProvider();

        const address = await wallet.connect();
        if (activeBtnLabel) activeBtnLabel.textContent = 'Pidiendo nonce…';

        const nonceRes = await fetch(`/api/wallet-nonce?address=${encodeURIComponent(address)}`);
        if (!nonceRes.ok) {
          const data = await nonceRes.json().catch(() => ({}));
          throw new Error(data.error || 'No pudimos generar el nonce.');
        }
        const { message, nonce } = (await nonceRes.json()) as { message: string; nonce: string };

        if (activeBtnLabel) activeBtnLabel.textContent = 'Esperando firma…';

        let signature: string;
        try {
          signature = await wallet.signMessage(message);
        } catch (signErr: unknown) {
          const code = (signErr as { code?: number | string })?.code;
          if (code === 4001 || code === 'ACTION_REJECTED') {
            if (!isProfileLinking) {
              setWalletStatus('Cancelaste la firma.');
            } else {
              alert('Cancelaste la firma de la wallet.');
            }
          } else {
            throw signErr;
          }
          if (activeBtnLabel) activeBtnLabel.textContent = originalLabel;
          activeBtn.disabled = false;
          return;
        }

        // Pedir teléfono
        let phone: string | null = null;
        const wantsPhone = confirm('¿Querés asociar un número de teléfono a tu cuenta para recibir notificaciones y seguridad adicional?');
        if (wantsPhone) {
          phone = prompt('Ingresá tu número de teléfono:');
          if (phone) phone = phone.trim();
        }

        // Recuperar insignias de invitado desde localStorage
        let guestBadges: number[] = [];
        try {
          guestBadges = JSON.parse(localStorage.getItem('edificarte_guest_badges') || '[]');
        } catch {}

        if (activeBtnLabel) activeBtnLabel.textContent = 'Verificando…';
        const loginRes = await fetch('/api/wallet-login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            address,
            nonce,
            signature,
            phone: phone || undefined,
            guestBadges: guestBadges.length > 0 ? guestBadges : undefined
          }),
        });

        if (!loginRes.ok) {
          const data = await loginRes.json().catch(() => ({}));
          throw new Error(data.error || 'No pudimos verificar tu wallet.');
        }

        // Si es guest, borrar cookies y storage de guest
        if (guestBadges.length > 0) {
          localStorage.removeItem('edificarte_guest_badges');
          localStorage.removeItem('edificarte_guest_points');
          localStorage.removeItem('edificarte_guest_visits');
        }
        
        // Exito -> redirect
        window.location.href = '/yo';
      } catch (err: unknown) {
        const msg = err instanceof Error ? err.message : 'Error desconocido.';
        if (!isProfileLinking) {
          setWalletStatus(msg);
        } else {
          alert('Error vinculando wallet: ' + msg);
        }
        if (activeBtnLabel) activeBtnLabel.textContent = originalLabel;
        activeBtn.disabled = false;
      }
    }

    btnWallet?.addEventListener('click', () => {
      connectWallet(false);
    });

    const btnProfileWallet = document.getElementById('btn-profile-wallet-connect') as HTMLButtonElement | null;
    btnProfileWallet?.addEventListener('click', () => {
      connectWallet(true);
    });

    // Event listener para las medallas/insignias
    const profileContainer = document.getElementById('profile-container');
    const hasWalletVal = profileContainer?.getAttribute('data-has-wallet') === 'true';
    const isGuestVal = profileContainer?.getAttribute('data-is-guest') === 'true';
    
    const badgeCards = document.querySelectorAll('[id^="badge-card-"]');
    badgeCards.forEach((card) => {
      card.classList.add('cursor-pointer');
      card.addEventListener('click', () => {
        // Verificar si está desbloqueada en el DOM
        const isUnlocked = !card.querySelector('.lock-icon-container') || card.querySelector('.lock-icon-container')?.classList.contains('hidden');

        if (!hasWalletVal) {
          const confirmConnect = confirm(
            '¡Para guardar tu insignia en tu billetera y acuñarla como un NFT on-chain, necesitas conectar tu wallet! ¿Querés conectarla ahora?'
          );
          if (confirmConnect) {
            connectWallet(isGuestVal ? false : true);
          }
        } else {
          if (isUnlocked) {
            alert('¡Esta insignia ya está en tu billetera de forma segura en la blockchain!');
          } else {
            alert('Esta insignia está bloqueada. Escuchá la audioguía del monumento correspondiente en el mapa para desbloquearla y acuñar tu NFT.');
          }
        }
      });
    });

    // 2. Opciones de Configuración (User View)
    const settingsBtn = document.getElementById('settings-btn');
    const settingsDropdown = document.getElementById('settings-dropdown');

    if (settingsBtn && settingsDropdown) {
      settingsBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        settingsDropdown.classList.toggle('hidden');
      });

      document.addEventListener('click', (e: MouseEvent) => {
        const target = e.target as HTMLElement;
        if (!settingsDropdown.contains(target) && target !== settingsBtn && !settingsBtn.contains(target)) {
          settingsDropdown.classList.add('hidden');
        }
      });
    }

    // 3. Modal de Edición de Perfil (User View)
    const editProfileBtn = document.getElementById('edit-profile-btn');
    const editModal = document.getElementById('edit-profile-modal');
    const closeModalBtn = document.getElementById('close-modal-btn');

    if (editProfileBtn && editModal && closeModalBtn) {
      editProfileBtn.addEventListener('click', () => {
        editModal.classList.remove('hidden');
        settingsDropdown?.classList.add('hidden');
        document.body.classList.add('modal-open');
      });

      closeModalBtn.addEventListener('click', () => {
        editModal.classList.add('hidden');
        document.body.classList.remove('modal-open');
      });

      // Cerrar al hacer clic fuera del contenido
      editModal.addEventListener('click', (e) => {
        if (e.target === editModal) {
          editModal.classList.add('hidden');
          document.body.classList.remove('modal-open');
        }
      });
    }

    // Emoji Selector Event Listener
    const emojiGrid = document.getElementById('emoji-selector-grid');
    const emojiInput = document.getElementById('avatar-emoji-input');
    if (emojiGrid && emojiInput) {
      emojiGrid.querySelectorAll('button').forEach((btn) => {
        btn.addEventListener('click', () => {
          const emoji = btn.getAttribute('data-emoji') || '👷';
          (emojiInput as HTMLInputElement).value = emoji;
          
          // Clear active styles from all buttons
          emojiGrid.querySelectorAll('button').forEach((b) => {
            b.classList.remove('border-brand-500', 'bg-brand-50', 'dark:bg-brand-950/40');
            b.classList.add('border-slate-100', 'dark:border-slate-800', 'bg-transparent');
          });
          
          // Add active styles to clicked button
          btn.classList.remove('border-slate-100', 'dark:border-slate-800', 'bg-transparent');
          btn.classList.add('border-brand-500', 'bg-brand-50', 'dark:bg-brand-950/40');
        });
      });
    }

    // 4. Animación de la Barra de Experiencia
    const expBar = document.getElementById('exp-bar');
    if (expBar) {
      const targetPercent = expBar.getAttribute('data-percent') || '0%';
      setTimeout(() => {
        expBar.style.width = targetPercent;
      }, 300);
    }

    // 5. Carga de progreso del invitado desde localStorage y sincronización
    const guestFlag = document.getElementById('is-guest-flag');
    if (guestFlag) {
      const guestVisits = parseInt(localStorage.getItem('edificarte_guest_visits') || '0', 10);
      const guestPoints = parseInt(localStorage.getItem('edificarte_guest_points') || '0', 10);
      let guestBadges: number[] = [];
      try {
        guestBadges = JSON.parse(localStorage.getItem('edificarte_guest_badges') || '[]');
      } catch {}

      // Actualizar visitas y puntos en el DOM
      const visitsEl = document.getElementById('stats-visits');
      const pointsEl = document.getElementById('stats-points');
      if (visitsEl) visitsEl.textContent = guestVisits.toString();
      if (pointsEl) pointsEl.textContent = guestPoints.toString();

      // Calcular nivel y experiencia
      const level = Math.floor(guestPoints / 500) + 1;
      const exp = guestPoints % 500;
      
      const levelLabel = document.getElementById('level-label');
      const expLabel = document.getElementById('exp-label');
      if (levelLabel) levelLabel.textContent = `Nivel ${level}`;
      if (expLabel) expLabel.textContent = `${exp} / 500 exp`;

      if (expBar) {
        const percent = `${(exp / 500) * 100}%`;
        expBar.setAttribute('data-percent', percent);
        // Volver a aplicar el ancho para que empiece de 0 con transición
        expBar.style.width = '0%';
        setTimeout(() => {
          expBar.style.width = percent;
        }, 300);
      }

      // Actualizar contador de insignias
      const countLabel = document.getElementById('badges-count-label');
      if (countLabel) {
        countLabel.textContent = `${guestBadges.length} Ganados`;
      }

      // Desbloquear visualmente las insignias obtenidas localmente
      guestBadges.forEach((id) => {
        const card = document.getElementById(`badge-card-${id}`);
        if (card) {
          const img = card.querySelector('img');
          if (img) {
            img.classList.remove('opacity-35', 'grayscale');
          }
          const lock = card.querySelector('.lock-icon-container');
          if (lock) {
            lock.classList.add('hidden');
          }
          const title = card.querySelector('h3');
          if (title) {
            title.classList.remove('text-slate-400', 'dark:text-slate-600');
            title.classList.add('text-slate-800', 'dark:text-slate-200');
          }
          const desc = card.querySelector('p');
          if (desc) {
            desc.textContent = '¡Completado! Ya tienes esta insignia en tu billetera.';
          }
        }
      });

      // Registrarse / Crear cuenta: limpiar cookies de guest server-side
      // antes de recargar para que /yo renderice el form de login/register
      // (en vez del panel de guest).
      const registerBtns = ['btn-guest-register', 'btn-guest-register-cta'];
      registerBtns.forEach(id => {
        const btn = document.getElementById(id);
        if (btn) {
          btn.addEventListener('click', async () => {
            btn.setAttribute('disabled', 'true');
            try {
              await fetch('/api/exit-guest', { method: 'POST' });
            } catch (err) {
              console.warn('No se pudo limpiar guest en el servidor, recargando igual:', err);
            }
            window.location.reload();
          });
        }
      });

      // Interceptar envío del formulario de edición para invitados
      if (editModal) {
        const editModalForm = editModal.querySelector('form');
        if (editModalForm) {
          editModalForm.addEventListener('submit', (e) => {
            if (guestFlag) {
              e.preventDefault();
              const formData = new FormData(editModalForm);
              const name = formData.get('name')?.toString().trim() || 'Edificador Invitado';
              const avatarUrl = formData.get('avatar_url')?.toString().trim() || '👷';

              localStorage.setItem('edificarte_guest_name', name);
              localStorage.setItem('edificarte_guest_avatar', avatarUrl);

              window.location.reload();
            }
          });
        }
      }

      // Pre-cargar valores de invitado en la UI al cargar la página
      const savedGuestName = localStorage.getItem('edificarte_guest_name');
      const savedGuestAvatar = localStorage.getItem('edificarte_guest_avatar');
      
      if (savedGuestName) {
        const nameEl = document.getElementById('profile-user-name');
        if (nameEl) nameEl.textContent = savedGuestName;

        if (editModal) {
          const modalNameInput = editModal.querySelector('input[name="name"]') as HTMLInputElement;
          if (modalNameInput) modalNameInput.value = savedGuestName;
        }
      }
      
      if (savedGuestAvatar) {
        // Reemplazar o renderizar el avatar de emoji correspondiente
        const avatarContainer = document.getElementById('avatar-container-outer');
        if (avatarContainer) {
          avatarContainer.innerHTML = `<div class="flex h-full w-full items-center justify-center rounded-full border-4 border-white bg-brand-50 text-4xl shadow-lg dark:border-slate-900 dark:bg-slate-850" id="profile-avatar-emoji">${savedGuestAvatar}</div>`;
        }
        
        const modalEmojiInput = document.getElementById('avatar-emoji-input') as HTMLInputElement;
        if (modalEmojiInput) modalEmojiInput.value = savedGuestAvatar;
      }
    } else {
      // Usuario real autenticado: Sincronizar progreso local si existía antes de loguearse/registrarse
      let guestBadges: number[] = [];
      try {
        guestBadges = JSON.parse(localStorage.getItem('edificarte_guest_badges') || '[]');
      } catch {}

      if (guestBadges.length > 0) {
        // Enviar las insignias locales al backend D1 para guardarlas de forma definitiva
        Promise.all(
          guestBadges.map(id =>
            fetch('/api/unlock-badge', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ badgeId: id })
            }).then(r => r.json())
          )
        ).then(() => {
          // Limpiar el progreso de invitado para evitar envíos duplicados
          localStorage.removeItem('edificarte_guest_badges');
          localStorage.removeItem('edificarte_guest_points');
          localStorage.removeItem('edificarte_guest_visits');
          // Recargar para mostrar los datos finales guardados en la BD
          window.location.reload();
        }).catch(err => {
          console.error('Error al sincronizar progreso de invitado:', err);
        });
      }
    }

    // Ocultar notificaciones flotantes de éxito/error después de 3.5 segundos
    const floatingAlerts = document.querySelectorAll('.fixed.top-6.left-1\\/2');
    floatingAlerts.forEach((alert) => {
      setTimeout(() => {
        alert.classList.add('scale-95', 'opacity-0');
        setTimeout(() => alert.remove(), 500);
      }, 3500);
    });

    // 6. Renderizar "Mis Reservas" y "Mis Favoritos" desde localStorage
    renderReservations();
    renderFavorites();
  });

  /**
   * Renderiza las reservas de tours guardadas en localStorage bajo
   * 'edificarte_reservations'. Usa textContent y atributos para datos
   * user-controlled → evita XSS. Mantiene orden: más recientes primero.
   */
  function renderReservations(): void {
    const STORAGE_KEY = 'edificarte_reservations';
    const listEl = document.getElementById('reservations-list');
    const emptyEl = document.getElementById('reservations-empty');
    const countEl = document.getElementById('reservations-count-label');
    if (!listEl || !emptyEl || !countEl) return;

    let reservations: Array<Record<string, unknown>> = [];
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) reservations = JSON.parse(raw);
      if (!Array.isArray(reservations)) reservations = [];
    } catch (e) {
      console.warn('No se pudo leer el storage de reservas:', e);
      reservations = [];
    }

    // Orden: más recientes primero
    reservations.sort((a, b) => {
      const at = new Date(a.createdAt as string).getTime() || 0;
      const bt = new Date(b.createdAt as string).getTime() || 0;
      return bt - at;
    });

    // Limpiar contenedor
    listEl.innerHTML = '';

    if (reservations.length === 0) {
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      countEl.textContent = '0 Reservas';
      return;
    }

    emptyEl.classList.add('hidden');
    listEl.classList.remove('hidden');
    countEl.textContent = `${reservations.length} ${reservations.length === 1 ? 'Reserva' : 'Reservas'}`;

    reservations.forEach((r) => {
      const card = document.createElement('div');
      card.className =
        'group flex gap-3 rounded-2xl border border-slate-200/60 bg-white p-3 shadow-sm transition-all duration-300 hover:border-brand-200/50 hover:shadow-md dark:border-slate-800/60 dark:bg-slate-900 dark:hover:border-brand-900';

      const tourTitle = (r.tourTitle as string) || 'Tour';
      const tourImage = (r.tourImage as string) || '';
      const name = (r.name as string) || '';
      const date = (r.date as string) || '';
      const people = (r.people as number) || 1;
      const totalMXN = (r.totalMXN as number) || 0;
      const status = (r.status as string) || 'pending';
      const reservationId = (r.id as string) || '';

      // Thumb (imagen vía atributo para evitar XSS)
      const thumb = document.createElement('div');
      thumb.className =
        'flex h-20 w-20 flex-shrink-0 items-center justify-center overflow-hidden rounded-xl border border-slate-200/60 bg-amber-50 dark:border-slate-800/60 dark:bg-amber-950/30';
      if (tourImage) {
        const img = document.createElement('img');
        img.src = tourImage;
        img.alt = '';
        img.loading = 'lazy';
        img.className = 'h-full w-full object-cover';
        img.referrerPolicy = 'no-referrer';
        thumb.appendChild(img);
      } else {
        const icon = document.createElement('span');
        icon.className = 'material-symbols-outlined text-[28px] text-amber-500';
        icon.textContent = 'tour';
        thumb.appendChild(icon);
      }
      card.appendChild(thumb);

      // Body
      const body = document.createElement('div');
      body.className = 'flex min-w-0 flex-1 flex-col justify-between';

      const titleEl = document.createElement('h3');
      titleEl.className = 'truncate text-sm font-bold text-slate-800 dark:text-slate-200';
      titleEl.textContent = tourTitle;
      body.appendChild(titleEl);

      const meta = document.createElement('div');
      meta.className = 'mt-1 flex flex-wrap items-center gap-x-2 gap-y-0.5 text-[11px] text-slate-500 dark:text-slate-400';

      const dateEl = document.createElement('span');
      dateEl.className = 'inline-flex items-center gap-0.5 font-semibold';
      const dateIcon = document.createElement('span');
      dateIcon.className = 'material-symbols-outlined text-[12px]';
      dateIcon.textContent = 'event';
      dateEl.appendChild(dateIcon);
      dateEl.appendChild(document.createTextNode(` ${formatDate(date)}`));
      meta.appendChild(dateEl);

      const peopleEl = document.createElement('span');
      peopleEl.className = 'inline-flex items-center gap-0.5';
      const peopleIcon = document.createElement('span');
      peopleIcon.className = 'material-symbols-outlined text-[12px]';
      peopleIcon.textContent = 'group';
      peopleEl.appendChild(peopleIcon);
      peopleEl.appendChild(document.createTextNode(` ${people} ${people === 1 ? 'persona' : 'personas'}`));
      meta.appendChild(peopleEl);

      if (name) {
        const nameEl = document.createElement('span');
        nameEl.className = 'inline-flex items-center gap-0.5 truncate';
        const personIcon = document.createElement('span');
        personIcon.className = 'material-symbols-outlined text-[12px]';
        personIcon.textContent = 'person';
        nameEl.appendChild(personIcon);
        nameEl.appendChild(document.createTextNode(` ${name}`));
        meta.appendChild(nameEl);
      }
      body.appendChild(meta);

      // Footer: total + status
      const footer = document.createElement('div');
      footer.className = 'mt-1.5 flex items-center justify-between gap-2';

      const totalEl = document.createElement('span');
      totalEl.className = 'text-xs font-bold text-slate-700 dark:text-slate-300';
      totalEl.textContent = `$${totalMXN.toLocaleString('es-MX')} MXN`;
      footer.appendChild(totalEl);

      const statusEl = document.createElement('span');
      const isConfirmed = status === 'confirmed';
      statusEl.className =
        'inline-flex items-center gap-0.5 rounded-full px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider ' +
        (isConfirmed
          ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-300'
          : 'bg-amber-50 text-amber-700 dark:bg-amber-950/30 dark:text-amber-300');
      const statusIcon = document.createElement('span');
      statusIcon.className = 'material-symbols-outlined text-[11px]';
      statusIcon.textContent = isConfirmed ? 'check_circle' : 'schedule';
      statusEl.appendChild(statusIcon);
      statusEl.appendChild(document.createTextNode(isConfirmed ? ' Confirmada' : ' Pendiente'));
      footer.appendChild(statusEl);

      body.appendChild(footer);

      if (reservationId) {
        const idEl = document.createElement('span');
        idEl.className =
          'mt-1 block rounded-md bg-slate-100 px-1.5 py-0.5 font-mono text-[9px] font-medium text-slate-400 dark:bg-slate-800 dark:text-slate-500';
        idEl.textContent = reservationId;
        body.appendChild(idEl);
      }

      card.appendChild(body);
      listEl.appendChild(card);
    });
  }

  /** Formato corto de fecha YYYY-MM-DD → "12 mar 2026" en es-MX. */
  function formatDate(iso: string): string {
    if (!iso) return '-';
    const parts = iso.split('-');
    if (parts.length !== 3) return iso;
    const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
    const day = parseInt(parts[2], 10);
    const monthIdx = parseInt(parts[1], 10) - 1;
    const year = parts[0];
    if (isNaN(day) || monthIdx < 0 || monthIdx > 11) return iso;
    return `${day} ${months[monthIdx]} ${year}`;
  }

  /**
   * Renderiza la sección "Mis Favoritos" desde localStorage.
   * Lee 'edificarte_favorites' (array de IDs) y cruza con los datos
   * embebidos de monumentos para construir mini-cards.
   */
  function renderFavorites(): void {
    const listEl = document.getElementById('favorites-list');
    const emptyEl = document.getElementById('favorites-empty');
    const countEl = document.getElementById('favorites-count-label');
    if (!listEl || !emptyEl || !countEl) return;

    let favIds: string[] = [];
    try {
      favIds = JSON.parse(localStorage.getItem('edificarte_favorites') || '[]');
      if (!Array.isArray(favIds)) favIds = [];
    } catch { favIds = []; }

    // Monumentos embebidos desde los datos de la sesión
    // Los favoritos son IDs de experiencias (exp.id) que pueden ser
    // IDs de monumentos ('bellas-artes', 'el-rule', …) o de experiencias
    // estáticas ('turismo-regenerativo', …). Guardamos imagen y título
    // desde data-attributes de las cards si las hubiera, o sólo el ID.
    // Para una solución robusta leemos una tabla embebida al final del script.
    const knownExp: Record<string, { title: string; image: string; category: string }> = {};
    try {
      const raw = (window as any).__EDIFICARTE_EXPERIENCES__;
      if (raw) Object.assign(knownExp, raw);
    } catch {}

    listEl.innerHTML = '';

    if (favIds.length === 0) {
      listEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      countEl.textContent = '0 Favoritos';
      return;
    }

    emptyEl.classList.add('hidden');
    listEl.classList.remove('hidden');
    countEl.textContent = `${favIds.length} ${favIds.length === 1 ? 'Favorito' : 'Favoritos'}`;

    favIds.forEach((id) => {
      const exp = knownExp[id];
      const card = document.createElement('a');
      card.href = '/';
      card.className = 'group flex flex-col overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-sm transition-all duration-300 hover:border-rose-200/60 hover:shadow-md dark:border-slate-800/60 dark:bg-slate-900 dark:hover:border-rose-900/40';

      const imgWrap = document.createElement('div');
      imgWrap.className = 'relative h-24 w-full overflow-hidden bg-slate-100 dark:bg-slate-850';

      if (exp?.image) {
        const img = document.createElement('img');
        img.src = exp.image;
        img.alt = exp.title || id;
        img.loading = 'lazy';
        img.className = 'h-full w-full object-cover transition-transform duration-500 group-hover:scale-105';
        imgWrap.appendChild(img);
      } else {
        const icon = document.createElement('span');
        icon.className = 'material-symbols-outlined absolute inset-0 m-auto text-[32px] text-slate-300';
        icon.textContent = 'location_on';
        imgWrap.appendChild(icon);
      }

      // Heart badge
      const heart = document.createElement('span');
      heart.className = 'absolute top-2 right-2 flex h-5 w-5 items-center justify-center rounded-full bg-rose-500 text-white shadow';
      heart.innerHTML = '<svg class="h-3 w-3 fill-current" viewBox="0 0 24 24"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>';
      imgWrap.appendChild(heart);

      card.appendChild(imgWrap);

      const body = document.createElement('div');
      body.className = 'p-2';

      const titleEl = document.createElement('p');
      titleEl.className = 'text-[11px] font-bold text-slate-800 dark:text-slate-200 line-clamp-2 leading-tight';
      titleEl.textContent = exp?.title || id;
      body.appendChild(titleEl);

      if (exp?.category) {
        const catEl = document.createElement('p');
        catEl.className = 'mt-0.5 text-[9px] font-semibold uppercase tracking-wider text-rose-500';
        catEl.textContent = exp.category;
        body.appendChild(catEl);
      }

      card.appendChild(body);
      listEl.appendChild(card);
    });
  }
</script>
