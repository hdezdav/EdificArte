---
import Layout from '../layouts/Layout.astro';
---

<Layout title="EdificARTE — Mapa" fullScreen={true}>
  <!-- Floating Search Bar -->
  <div
    class="pointer-events-none absolute left-0 right-0 top-0 z-30 flex flex-col items-center gap-2 px-5"
    style="padding-top: calc(env(safe-area-inset-top, 0px) + 16px);"
  >
    <div class="relative w-full max-w-lg">
      <div class="pointer-events-auto flex w-full items-center rounded-full border border-black/[0.06] bg-white/90 px-4 py-3 shadow-[0_2px_16px_rgba(0,0,0,0.08)] backdrop-blur-xl transition-all">
        <span class="material-symbols-outlined mr-2.5 text-[20px] text-[#3f043a]">search</span>
        <input
          type="text"
          id="search-input"
          placeholder="Buscar monumentos o audioguías..."
          class="w-full min-w-0 flex-grow border-none bg-transparent p-0 text-[13px] font-medium text-[#1b1c1c] placeholder-[#999] outline-none focus:ring-0"
        />
        <button id="btn-search-filters" class="ml-2 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[#3f043a] text-white transition-all active:scale-90" aria-label="Filtros avanzados">
          <span class="material-symbols-outlined text-[16px]">tune</span>
        </button>
      </div>

      <!-- Search Filters Dropdown -->
      <div
        id="search-filters-dropdown"
        class="hidden pointer-events-auto absolute left-0 right-0 mt-2 z-40 rounded-3xl border border-white/50 bg-white/95 p-4 shadow-[0_8px_32px_rgba(0,0,0,0.12)] backdrop-blur-2xl transition-all duration-200"
      >
        <h3 class="mb-3 text-[13px] font-bold text-[#1b1c1c] flex items-center gap-1.5">
          <span class="material-symbols-outlined text-[16px]">tune</span> Filtros de Búsqueda
        </h3>
        
        <div class="space-y-4">
          <!-- Sort Option -->
          <div>
            <span class="block mb-1.5 text-[10px] font-bold uppercase tracking-wider text-[#5c5c5c]">Ordenar por</span>
            <div class="grid grid-cols-2 gap-2">
              <label class="flex items-center gap-2 rounded-xl border border-black/[0.04] bg-white/50 p-2 text-[12px] font-medium text-[#1b1c1c] cursor-pointer hover:bg-white/80">
                <input type="radio" name="sort-by" value="distance" checked class="text-[#3f043a] focus:ring-[#3f043a]" />
                <span>Distancia</span>
              </label>
              <label class="flex items-center gap-2 rounded-xl border border-black/[0.04] bg-white/50 p-2 text-[12px] font-medium text-[#1b1c1c] cursor-pointer hover:bg-white/80">
                <input type="radio" name="sort-by" value="name" class="text-[#3f043a] focus:ring-[#3f043a]" />
                <span>Nombre</span>
              </label>
            </div>
          </div>

          <!-- Visited Option -->
          <div>
            <span class="block mb-1.5 text-[10px] font-bold uppercase tracking-wider text-[#5c5c5c]">Estado de Visita</span>
            <div class="grid grid-cols-3 gap-1.5">
              <label class="flex flex-col items-center justify-center rounded-xl border border-black/[0.04] bg-white/50 p-2 text-[11px] font-medium text-[#1b1c1c] cursor-pointer hover:bg-white/80 text-center">
                <input type="radio" name="filter-visited" value="all" checked class="mb-1 text-[#3f043a]" />
                <span>Todos</span>
              </label>
              <label class="flex flex-col items-center justify-center rounded-xl border border-black/[0.04] bg-white/50 p-2 text-[11px] font-medium text-[#1b1c1c] cursor-pointer hover:bg-white/80 text-center">
                <input type="radio" name="filter-visited" value="visited" class="mb-1 text-[#3f043a]" />
                <span>Visitados</span>
              </label>
              <label class="flex flex-col items-center justify-center rounded-xl border border-black/[0.04] bg-white/50 p-2 text-[11px] font-medium text-[#1b1c1c] cursor-pointer hover:bg-white/80 text-center">
                <input type="radio" name="filter-visited" value="unvisited" class="mb-1 text-[#3f043a]" />
                <span>No Visitados</span>
              </label>
            </div>
          </div>

          <!-- Feature Toggles -->
          <div>
            <span class="block mb-1.5 text-[10px] font-bold uppercase tracking-wider text-[#5c5c5c]">Características</span>
            <div class="space-y-2">
              <label class="flex items-center justify-between rounded-xl border border-black/[0.04] bg-white/50 p-2 px-3 text-[12px] font-medium text-[#1b1c1c] cursor-pointer hover:bg-white/80">
                <span class="flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-[16px] text-[#3f043a]">headphones</span>
                  Con Audioguía
                </span>
                <input type="checkbox" id="filter-audioguide" class="rounded text-[#3f043a] focus:ring-[#3f043a]" />
              </label>
              <label class="flex items-center justify-between rounded-xl border border-black/[0.04] bg-white/50 p-2 px-3 text-[12px] font-medium text-[#1b1c1c] cursor-pointer hover:bg-white/80">
                <span class="flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-[16px] text-yellow-500">star</span>
                  Sitio Destacado
                </span>
                <input type="checkbox" id="filter-featured" class="rounded text-[#3f043a] focus:ring-[#3f043a]" />
              </label>
            </div>
          </div>
        </div>

        <div class="mt-4 flex gap-2">
          <button id="btn-reset-filters" class="flex-1 rounded-xl bg-slate-100 py-2 text-[12px] font-bold text-[#5c5c5c] hover:bg-slate-200 transition-colors">
            Restablecer
          </button>
          <button id="btn-apply-filters" class="flex-1 rounded-xl bg-[#3f043a] py-2 text-[12px] font-bold text-white hover:bg-[#52074c] transition-colors">
            Aplicar
          </button>
        </div>
      </div>
    </div>

    <!-- Filter Chips -->
    <div class="no-scrollbar pointer-events-auto flex w-full max-w-lg gap-2 overflow-x-auto -mx-5 px-5 pt-2 pb-4 scroll-smooth">
      <button data-filter="all" class="filter-chip active flex-shrink-0 rounded-full bg-[#3f043a] px-4 py-[7px] text-[11px] font-semibold text-white shadow-sm transition-all active:scale-95">
        Todos
      </button>
      <button data-filter="museo" class="filter-chip flex-shrink-0 rounded-full border border-white/50 bg-white/75 px-4 py-[7px] text-[11px] font-semibold text-[#1b1c1c] shadow-sm backdrop-blur-lg transition-all active:scale-95">
        🏛️ Museos
      </button>
      <button data-filter="templo" class="filter-chip flex-shrink-0 rounded-full border border-white/50 bg-white/75 px-4 py-[7px] text-[11px] font-semibold text-[#1b1c1c] shadow-sm backdrop-blur-lg transition-all active:scale-95">
        ⛪ Templos
      </button>
      <button data-filter="arqueologia" class="filter-chip flex-shrink-0 rounded-full border border-white/50 bg-white/75 px-4 py-[7px] text-[11px] font-semibold text-[#1b1c1c] shadow-sm backdrop-blur-lg transition-all active:scale-95">
        🏺 Arqueología
      </button>
      <button data-filter="rascacielos" class="filter-chip flex-shrink-0 rounded-full border border-white/50 bg-white/75 px-4 py-[7px] text-[11px] font-semibold text-[#1b1c1c] shadow-sm backdrop-blur-lg transition-all active:scale-95">
        🗼 Miradores
      </button>
    </div>
  </div>

  <!-- Fullscreen Map -->
  <div id="map" class="absolute inset-0 z-0 h-full w-full"></div>

  <!-- Floating Controls -->
  <div class="absolute bottom-56 right-3 z-20 flex flex-col gap-2 sm:right-4">
    <button
      id="btn-locate"
      class="flex h-10 w-10 items-center justify-center rounded-full bg-[#3f043a] text-white shadow-lg transition-all active:scale-90 sm:h-11 sm:w-11"
      aria-label="Centrar ubicación"
    >
      <span class="material-symbols-outlined text-[18px] sm:text-[20px]" id="locate-icon">my_location</span>
    </button>
    <button
      id="btn-style-toggle"
      class="flex h-10 w-10 items-center justify-center rounded-full bg-[#3f043a] text-white shadow-lg transition-all active:scale-90 sm:h-11 sm:w-11"
      aria-label="Cambiar estilo"
    >
      <span class="material-symbols-outlined text-[18px] sm:text-[20px]">layers</span>
    </button>
  </div>

  <!-- Bottom Sheet -->
  <div
    id="bottom-sheet"
    class="absolute bottom-20 left-3 right-3 z-20 mx-auto max-w-lg overflow-hidden rounded-3xl border border-white/50 bg-white/85 shadow-[0_-8px_40px_rgba(0,0,0,0.12)] backdrop-blur-2xl transition-all duration-300"
  >
    <!-- Drag Handle & Toggle Header -->
    <div id="sheet-header" class="w-full cursor-pointer pb-2 pt-3 flex flex-col items-center select-none">
      <div class="h-[5px] w-10 rounded-full bg-black/15 mb-2"></div>
      <div class="px-4 w-full flex items-center justify-between">
        <h2 class="text-[14px] font-bold text-[#1b1c1c] flex items-center gap-1.5">
          <span class="material-symbols-outlined text-[18px]">location_on</span>
          Monumentos Cercanos
        </h2>
        <div class="flex items-center gap-2">
          <span id="geo-status" class="inline-flex items-center gap-1 text-[10px] font-semibold text-[#5c5c5c]">
            <span id="geo-dot" class="h-1.5 w-1.5 rounded-full bg-[#c0c0c0]"></span>
            <span id="geo-text">Inactivo</span>
          </span>
          <span id="sheet-chevron" class="material-symbols-outlined text-[20px] text-black/40 transition-transform duration-300">keyboard_arrow_up</span>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div
      id="sheet-body"
      class="overflow-y-auto px-4 pb-5 transition-all duration-300 ease-in-out"
      style="max-height: 0px; opacity: 0; pointer-events: none;"
    >
      <!-- List View -->
      <div id="view-list">
        <div class="no-scrollbar flex flex-col gap-2" id="monuments-list-container"></div>
      </div>

      <!-- Detail View -->
      <div id="view-detail" class="hidden">
        <!-- Monument Image -->
        <div class="mb-3 overflow-hidden rounded-2xl h-36 bg-slate-100 border border-black/[0.04]">
          <img id="detail-image" src="" alt="Monument image" class="w-full h-full object-cover" />
        </div>

        <div class="mb-3 flex items-start justify-between">
          <div class="flex gap-3">
            <span id="detail-emoji" class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-[#f5f3ff] text-2xl">🏛️</span>
            <div>
              <h3 id="detail-name" class="text-[15px] font-bold leading-tight text-[#1b1c1c]">Palacio de Bellas Artes</h3>
              <p id="detail-category" class="mt-0.5 text-[12px] font-medium text-[#5c5c5c]">
                Museo / Teatro · <span id="detail-dist" class="font-semibold text-[#1b1c1c]">0.3 km</span>
              </p>
            </div>
          </div>
          <button id="btn-close-detail" class="rounded-full p-1.5 text-[#a0a0a0] transition-colors hover:bg-black/5">
            <span class="material-symbols-outlined text-[20px]">close</span>
          </button>
        </div>

        <p id="detail-desc" class="mb-3 text-[12px] leading-relaxed text-[#5c5c5c]">
          Una de las casas de ópera más famosas del mundo.
        </p>

        <!-- Audio Player -->
        <div class="rounded-2xl border border-black/5 bg-[#f8f7f7] p-3.5 mb-3">
          <button
            id="btn-play-audio"
            class="flex w-full items-center justify-center gap-2 rounded-xl bg-[#3f043a] px-4 py-2.5 font-semibold text-white shadow-md shadow-[#3f043a]/20 transition-all active:scale-[0.97]"
          >
            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings:'FILL' 1">play_arrow</span>
            <span class="text-[12px]">Escuchar Audioguía (<span id="detail-duration">4:15</span>)</span>
          </button>

          <div id="audio-player" class="hidden space-y-3 pt-3">
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-1.5 text-[11px] font-bold text-[#3f043a]">
                <span class="relative flex h-2 w-2">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#3f043a] opacity-60"></span>
                  <span class="relative inline-flex h-2 w-2 rounded-full bg-[#3f043a]"></span>
                </span>
                Reproduciendo...
              </span>
              <span id="player-time" class="font-mono text-[10px] font-semibold text-[#5c5c5c]">0:00 / 4:15</span>
            </div>
            <div class="h-1.5 w-full cursor-pointer overflow-hidden rounded-full bg-black/8" id="progress-bar-container">
              <div id="progress-bar-fill" class="h-full w-0 rounded-full bg-[#3f043a] transition-all duration-100"></div>
            </div>
            <div class="flex items-center justify-center gap-6">
              <button id="btn-player-rw" class="text-[#5c5c5c] active:scale-90"><span class="material-symbols-outlined text-[20px]">replay_10</span></button>
              <button id="btn-player-toggle" class="flex h-10 w-10 items-center justify-center rounded-full bg-[#f5f3ff] text-[#3f043a] transition-all active:scale-90">
                <span class="material-symbols-outlined text-[22px]" id="player-toggle-icon">pause</span>
              </button>
              <button id="btn-player-ff" class="text-[#5c5c5c] active:scale-90"><span class="material-symbols-outlined text-[20px]">forward_10</span></button>
            </div>
          </div>
        </div>

        <!-- Visited & Review Section -->
        <div id="visit-section" class="rounded-2xl border border-black/5 bg-[#fbfbfa] p-3.5 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-[12px] font-bold text-[#1b1c1c] flex items-center gap-1">
              <span class="material-symbols-outlined text-[16px] text-[#3f043a]">task_alt</span>
              Registro de Visita
            </span>
            <span id="visit-status-tag" class="text-[10px] font-semibold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full">No visitado</span>
          </div>

          <!-- GPS distance warning if far -->
          <div id="visit-far-warning" class="text-[11px] text-[#854d0e] bg-amber-50 rounded-xl p-2.5 flex items-start gap-1.5">
            <span class="material-symbols-outlined text-[16px] flex-shrink-0">info</span>
            <span>Debes estar a menos de 200 metros para registrar tu visita y opinar. <span id="visit-distance-text" class="font-bold"></span></span>
          </div>

          <!-- Active form if near -->
          <div id="visit-near-form" class="hidden space-y-2.5">
            <button id="btn-mark-visited" class="w-full py-2 bg-[#3f043a] hover:bg-[#3f043a]/90 text-white rounded-xl text-[12px] font-bold shadow-md transition-all active:scale-[0.98]">
              Marcar como visitado
            </button>
            <div id="review-fields" class="hidden space-y-2">
              <div class="flex items-center gap-1">
                <span class="text-[11px] font-semibold text-slate-600 mr-1">Tu calificación:</span>
                <div class="flex gap-0.5 text-amber-400" id="rating-stars">
                  <span class="material-symbols-outlined cursor-pointer text-[18px]" data-val="1" style="font-variation-settings:'FILL' 1">star</span>
                  <span class="material-symbols-outlined cursor-pointer text-[18px]" data-val="2" style="font-variation-settings:'FILL' 1">star</span>
                  <span class="material-symbols-outlined cursor-pointer text-[18px]" data-val="3" style="font-variation-settings:'FILL' 1">star</span>
                  <span class="material-symbols-outlined cursor-pointer text-[18px]" data-val="4" style="font-variation-settings:'FILL' 1">star</span>
                  <span class="material-symbols-outlined cursor-pointer text-[18px]" data-val="5" style="font-variation-settings:'FILL' 1">star</span>
                </div>
              </div>
              <textarea id="review-input" placeholder="Escribe tu reseña..." class="w-full text-[11px] p-2.5 rounded-xl border border-black/10 bg-white placeholder-[#aaa] focus:ring-1 focus:ring-brand-500 focus:border-transparent outline-none h-16 resize-none"></textarea>
              <button id="btn-save-review" class="w-full py-2 bg-[#3f043a] text-white rounded-xl text-[11px] font-semibold transition-all hover:bg-[#3f043a]/90 active:scale-[0.98]">
                Guardar opinión
              </button>
            </div>
          </div>

          <!-- Visited and reviewed display state -->
          <div id="visit-saved-display" class="hidden space-y-2 rounded-xl bg-green-50/50 border border-green-200/40 p-2.5">
            <p class="text-[11px] text-green-700 font-bold flex items-center gap-1">
              <span class="material-symbols-outlined text-[14px]">done_all</span>
              ¡Ya visitaste este lugar!
            </p>
            <div class="flex gap-0.5 text-amber-400" id="saved-stars-display"></div>
            <p id="saved-review-text" class="text-[11px] italic text-[#5c5c5c] leading-snug"></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Language Selection Modal (Overlay) -->
  <div
    id="lang-modal"
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-md p-5 transition-opacity duration-300"
  >
    <div class="w-full max-w-sm rounded-[2rem] border border-white/40 bg-white/80 p-8 text-center shadow-2xl backdrop-blur-2xl transition-all duration-300 transform scale-100">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[#f5f3ff] text-[#3f043a] shadow-inner">
        <span class="material-symbols-outlined text-[28px]">translate</span>
      </div>
      <h2 class="text-xl font-bold text-slate-800">Bienvenido a EdificARTE</h2>
      <p class="mt-2 text-xs text-slate-500 leading-relaxed">
        Selecciona tu idioma para comenzar a explorar la historia y arquitectura de la CDMX.
      </p>

      <div class="mt-6 flex flex-col gap-2.5">
        <button data-lang="es" class="lang-btn flex items-center justify-between w-full px-5 py-3 rounded-2xl border border-black/5 bg-white shadow-sm hover:bg-slate-50 transition-all font-semibold text-slate-800 text-[13px] active:scale-[0.98]">
          <span class="flex items-center gap-2.5"><span>🇪🇸</span> Español</span>
          <span class="material-symbols-outlined text-[#3f043a] text-[16px]">arrow_forward</span>
        </button>
        <button data-lang="en" class="lang-btn flex items-center justify-between w-full px-5 py-3 rounded-2xl border border-black/5 bg-white shadow-sm hover:bg-slate-50 transition-all font-semibold text-slate-800 text-[13px] active:scale-[0.98]">
          <span class="flex items-center gap-2.5"><span>🇺🇸</span> English</span>
          <span class="material-symbols-outlined text-[#3f043a] text-[16px]">arrow_forward</span>
        </button>
        <button data-lang="señas" class="lang-btn flex items-center justify-between w-full px-5 py-3 rounded-2xl border border-black/5 bg-white shadow-sm hover:bg-slate-50 transition-all font-semibold text-slate-800 text-[13px] active:scale-[0.98]">
          <span class="flex items-center gap-2.5"><span>🤟</span> Lengua de Señas</span>
          <span class="material-symbols-outlined text-[#3f043a] text-[16px]">arrow_forward</span>
        </button>
      </div>
    </div>
  </div>
</Layout>

<style>
  :global(.leaflet-container) {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  }
  :global(.leaflet-control-zoom),
  :global(.leaflet-control-attribution) {
    display: none !important;
  }
  :global(.leaflet-popup-content-wrapper) {
    border-radius: 1rem !important;
    border: 1px solid rgba(0, 0, 0, 0.06) !important;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1) !important;
    padding: 0 !important;
  }
  :global(.leaflet-popup-content) {
    margin: 12px 16px !important;
  }
  :global(.leaflet-popup-tip) {
    background: white !important;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05) !important;
  }

  .filter-chip.active {
    background-color: #3f043a !important;
    color: #ffffff !important;
    border-color: transparent !important;
  }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  :global(.monument-pin) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: white;
    border: 2.5px solid #e0d0ff;
    border-radius: 50%;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
  }
  :global(.monument-pin:hover) {
    transform: scale(1.12);
  }
  :global(.monument-pin.selected) {
    border-color: #3f043a;
    box-shadow: 0 0 0 4px rgba(63, 4, 58, 0.18), 0 4px 16px rgba(0, 0, 0, 0.15);
    transform: scale(1.2) translateY(-3px);
    z-index: 1000 !important;
  }

  :global(.user-dot) {
    position: relative;
    width: 18px;
    height: 18px;
    background: #3f043a;
    border: 3px solid white;
    border-radius: 50%;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
  }
  :global(.user-dot::after) {
    content: '';
    position: absolute;
    inset: -7px;
    border-radius: 50%;
    background: rgba(63, 4, 58, 0.25);
    animation: loc-pulse 2s ease-out infinite;
  }
  @keyframes loc-pulse {
    0% { transform: scale(0.5); opacity: 1; }
    100% { transform: scale(2); opacity: 0; }
  }
</style>

<script>
  import 'leaflet/dist/leaflet.css';
  import L from 'leaflet';

  const MONUMENTS = [
    {
      id: 'bellas-artes',
      name: 'Palacio de Bellas Artes',
      category: 'Museo / Teatro',
      dist: '0.3 km',
      lat: 19.4352,
      lng: -99.1412,
      emoji: '🏛️',
      desc: 'Una de las casas de ópera más famosas del mundo, conocida por su arquitectura Art Nouveau exterior y Art Déco interior.',
      audioDuration: '4:15',
      type: 'museo',
      image: 'https://images.unsplash.com/photo-1512813583145-ac554ac82e4a?auto=format&fit=crop&w=400&h=250&q=80'
    },
    {
      id: 'catedral',
      name: 'Catedral Metropolitana',
      category: 'Iglesia / Templo',
      dist: '0.5 km',
      lat: 19.4326,
      lng: -99.1332,
      emoji: '⛪',
      desc: 'La catedral más antigua de América Latina, sede de la Arquidiócesis Primada de México.',
      audioDuration: '5:30',
      type: 'templo',
      image: 'https://images.unsplash.com/photo-1627918361099-c85264b4c3bf?auto=format&fit=crop&w=400&h=250&q=80'
    },
    {
      id: 'templo-mayor',
      name: 'Templo Mayor',
      category: 'Zona Arqueológica',
