<!-- Modal logic runs inline, independent of Leaflet/mapa-app to prevent breakage -->
<script is:inline>
  (function() {
    // Memory fallback para navegadores con localStorage bloqueado (Safari/Firefox ITP)
    var memoryStore = {};
    function safeGet(key) {
      try { return localStorage.getItem(key); }
      catch (e) { return Object.prototype.hasOwnProperty.call(memoryStore, key) ? memoryStore[key] : null; }
    }
    function safeSet(key, value) {
      try { localStorage.setItem(key, value); }
      catch (e) { memoryStore[key] = String(value); }
    }

    var langModal = document.getElementById('lang-modal');
    var welcomeModal = document.getElementById('welcome-modal');
    var langButtons = document.querySelectorAll('.lang-btn');
    var btnWelcomeStart = document.getElementById('btn-welcome-start');

    function showModal(modal) {
      if (!modal) return;
      modal.classList.remove('hidden');
      // Force reflow for transition
      void modal.offsetHeight;
      modal.classList.remove('opacity-0');
    }

    function hideModal(modal, cb) {
      if (!modal) return;
      modal.classList.add('opacity-0');
      setTimeout(function() {
        modal.classList.add('hidden');
        if (cb) cb();
      }, 300);
    }

    function showWelcomeModal() {
      showModal(welcomeModal);
    }

    // Entry logic — decide which modal to show
    var hasLang = safeGet('edificarte_lang');
    var hasWelcome = safeGet('edificarte_welcome_shown');

    if (!hasLang) {
      // No language chosen yet — show lang picker
      showModal(langModal);
    } else if (!hasWelcome) {
      // Language chosen but never welcomed — show welcome
      showWelcomeModal();
    }
    // else: both done, go straight to map

    // Language button clicks
    langButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var selectedLang = btn.getAttribute('data-lang');
        if (!selectedLang) return;
        safeSet('edificarte_lang', selectedLang);
        hideModal(langModal, function() {
          if (!safeGet('edificarte_welcome_shown')) {
            showWelcomeModal();
          }
          // Signal to mapa-app that modals are done
          window.dispatchEvent(new CustomEvent('edificarte-modals-done'));
        });
      });
    });

    // Welcome start button
    if (btnWelcomeStart) {
      btnWelcomeStart.addEventListener('click', function() {
        safeSet('edificarte_welcome_shown', 'true');
        hideModal(welcomeModal, function() {
          // Setear flag ANTES de dispatchar (para fallback anti-race-condition).
          // Usar safeSet (con memoryStore fallback) + window global como respaldo,
          // porque en Safari ITP localStorage puede estar bloqueado.
          safeSet('edificarte_request_gps_pending', 'true');
          window.__edificarteGpsPending = true;
          // Signal to mapa-app to start geolocation
          window.dispatchEvent(new CustomEvent('edificarte-modals-done'));
          window.dispatchEvent(new CustomEvent('edificarte-request-gps'));
        });
      });
    }
  })();
</script>

<script>
  import '../scripts/mapa-app.ts';
</script>

<script is:inline>
  // Toast de bienvenida post-registro (cuando venís de /yo con ?welcome=1).
  // Lee el query param, muestra un toast verde y limpia la URL sin recargar.
  (function () {
    var params = new URLSearchParams(window.location.search);
    if (params.get('welcome') === '1') {
      var toast = document.createElement('div');
      toast.setAttribute('role', 'status');
      toast.className =
        'fixed top-6 left-1/2 -translate-x-1/2 z-[9999] flex items-center gap-2 rounded-xl border border-emerald-200/50 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-lg dark:border-emerald-800/50 dark:bg-emerald-950/40 dark:text-emerald-200';
      toast.innerHTML =
        '<span class="material-symbols-outlined text-[18px]">check_circle</span>' +
        '<span>¡Bienvenido a EdificARTE! Tu cuenta está activa.</span>';
      document.body.appendChild(toast);
      // Limpia la URL para que un refresh no vuelva a mostrar el toast
      var url = new URL(window.location.href);
      url.searchParams.delete('welcome');
      window.history.replaceState({}, '', url.toString());
      setTimeout(function () {
        toast.style.transition = 'opacity 300ms';
        toast.style.opacity = '0';
        setTimeout(function () { toast.remove(); }, 350);
      }, 4500);
    }
  })();
</script>
