                        class={`exp-card group relative flex h-[350px] w-[250px] sm:w-[270px] flex-none snap-start flex-col overflow-hidden rounded-2xl border border-slate-200/50 dark:border-slate-800/50 bg-white dark:bg-slate-900 shadow-sm transition-all duration-300 hover:shadow-md ${exp.translations ? 'cursor-pointer' : ''}`}
                      >
                        <div class="relative h-44 w-full overflow-hidden rounded-t-2xl bg-slate-100 dark:bg-slate-850">
                          <img src={exp.image} alt={exp.title} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                          <span class={`absolute top-3 left-3 rounded-lg px-2 py-0.5 font-bold text-[10px] uppercase tracking-wider backdrop-blur-md border ${tagStyles[exp.tagColor].badge}`}>
                            {exp.customBadge ?? categoryLabel[exp.category]}
                          </span>
                        </div>
                        <div class="flex flex-1 flex-col justify-between p-4 bg-white dark:bg-slate-900">
                          <div>
                            <p class="text-slate-400 dark:text-slate-500 text-[10px] font-bold uppercase tracking-wider">México / Ciudad de México</p>
                            <h2 class="text-sm font-bold tracking-tight text-slate-800 dark:text-slate-100 mt-1 line-clamp-1 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{exp.title}</h2>
                            <p class="text-slate-500 dark:text-slate-400 text-xs tracking-tight mt-1.5 line-clamp-2 leading-relaxed">{exp.description}</p>
                          </div>
                          <div class="mt-auto pt-3 flex items-center gap-1.5 text-[11px] font-semibold text-slate-700 dark:text-slate-300 border-t border-slate-100 dark:border-slate-800/60">
                            {exp.rating && (
                              <span class="flex items-center gap-0.5 text-amber-500">
                                <span class="material-symbols-outlined text-[14px] !font-bold">star</span>
                                <span class="text-slate-800 dark:text-slate-200">{exp.rating.toFixed(2)}</span>
                              </span>
                            )}
                            {exp.reviewCount && <span class="text-slate-400 dark:text-slate-500 font-normal">({exp.reviewCount})</span>}
                            {exp.price && <span class="text-slate-400 dark:text-slate-500 font-normal ml-0.5">· {exp.price}</span>}
                            {exp.translations && (
                              <button type="button" class="guide-trigger-btn ml-auto inline-flex items-center gap-1 rounded-xl bg-brand-50 hover:bg-brand-100 dark:bg-brand-950/20 dark:hover:bg-brand-950/40 text-brand-600 dark:text-brand-400 font-bold px-3 py-1.5 text-[11px] shadow-sm transition-all active:scale-[0.97]">
                                {exp.cta}
                                <span class="material-symbols-outlined text-[12px]">arrow_forward</span>
                              </button>
                            )}
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          );
        })()
      }
      {/* Artesanías: última sección, full-width */}
      {
        lastCategories.map((cat) => {
          const catExp = todasLasExperiencias.filter(exp => exp.category === cat);
          if (catExp.length === 0) return null;
          return (
            <section
              data-category={cat}
              data-render-categories={cat}
              class="category-section w-full py-2 border-b border-slate-100/60 dark:border-slate-800/60 last:border-0"
            >
              <div class="mb-3 flex items-center justify-between">
                <h2 class="font-bold text-base md:text-lg tracking-tight text-slate-800 dark:text-slate-100 flex items-center gap-1.5">
                  <span class="h-2 w-2 rounded-full bg-brand-500"></span>
                  {categoryLabel[cat]}
                </h2>
                <div class="flex items-center gap-1.5">
                  <button type="button" class="scroll-left-btn h-7 w-7 rounded-full border border-slate-200 dark:border-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center transition-all active:scale-90" title="Deslizar izquierda">
                    <span class="material-symbols-outlined text-[16px]">chevron_left</span>
                  </button>
                  <button type="button" class="scroll-right-btn h-7 w-7 rounded-full border border-slate-200 dark:border-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center transition-all active:scale-90" title="Deslizar derecha">
                    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                  </button>
                </div>
              </div>
              <div class="scroll-container no-scrollbar -mx-1 flex snap-x snap-mandatory gap-4 overflow-x-auto px-1 pb-3 scroll-smooth">
                {(() => {
                  const chunks = [];
                  for (let i = 0; i < catExp.length; i += 4) chunks.push(catExp.slice(i, i + 4));
                  return chunks.map((chunk) => (
                    <div class="grid grid-cols-2 gap-3 w-[calc(100vw-32px)] sm:w-[704px] flex-none snap-start">
                      {chunk.map((exp) => (
                        <article
                          data-category={exp.category}
                          data-is-product="true"
                          data-title={exp.title}
                          data-desc={exp.description}
                          data-price={exp.price}
                          data-sku={exp.sku}
                          data-image={exp.image}
                          data-images={exp.images ? JSON.stringify(exp.images) : undefined}
                          class="exp-card group relative aspect-square overflow-hidden rounded-2xl border border-slate-200/50 dark:border-slate-800/50 bg-white dark:bg-slate-900 shadow-sm transition-all duration-300 hover:shadow-md cursor-pointer active:scale-[0.98]"
                        >
                          <img src={exp.image} alt={exp.title} loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-950/90 via-slate-950/40 to-transparent p-3 pt-8 flex flex-col justify-end text-white">
                            <h3 class="text-[11px] font-bold truncate tracking-tight">{exp.title}</h3>
                            <p class="text-[9px] font-extrabold text-purple-300 mt-0.5">{exp.price}</p>
                          </div>
                        </article>
                      ))}
                    </div>
                  ));
                })()}
              </div>
            </section>
          );
        })
      }

