        <div>
          <label for="tour-email" class="block text-[11px] font-bold text-slate-700 dark:text-slate-300 mb-1">Email</label>
          <input type="email" id="tour-email" name="email" required class="text-[16px] w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2.5 text-slate-800 dark:text-white placeholder-slate-400 outline-none focus:border-brand-400 focus:ring-1 focus:ring-brand-400" placeholder="tu@email.com" />
        </div>

        <div>
          <label for="tour-phone" class="block text-[11px] font-bold text-slate-700 dark:text-slate-300 mb-1">Teléfono</label>
          <input type="tel" id="tour-phone" name="phone" required class="text-[16px] w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2.5 text-slate-800 dark:text-white placeholder-slate-400 outline-none focus:border-brand-400 focus:ring-1 focus:ring-brand-400" placeholder="+52 55 1234 5678" />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="tour-date" class="block text-[11px] font-bold text-slate-700 dark:text-slate-300 mb-1">Fecha preferida</label>
            <input type="date" id="tour-date" name="date" required class="text-[16px] w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2.5 text-slate-800 dark:text-white outline-none focus:border-brand-400 focus:ring-1 focus:ring-brand-400" />
          </div>
          <div>
            <label for="tour-people" class="block text-[11px] font-bold text-slate-700 dark:text-slate-300 mb-1">Personas</label>
            <input type="number" id="tour-people" name="people" required min="1" max="20" value="2" class="text-[16px] w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2.5 text-slate-800 dark:text-white outline-none focus:border-brand-400 focus:ring-1 focus:ring-brand-400" />
          </div>
        </div>

        <div>
          <label for="tour-notes" class="block text-[11px] font-bold text-slate-700 dark:text-slate-300 mb-1">Notas (opcional)</label>
          <textarea id="tour-notes" name="notes" rows="2" class="text-[16px] w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2 text-slate-800 dark:text-white placeholder-slate-400 outline-none focus:border-brand-400 focus:ring-1 focus:ring-brand-400 resize-none" placeholder="Algún requerimiento especial..."></textarea>
        </div>

        <!-- Total -->
        <div class="flex items-center justify-between rounded-xl bg-slate-100 dark:bg-slate-800 p-3">
          <span class="text-[12px] font-bold text-slate-700 dark:text-slate-300">Total estimado</span>
          <div class="text-right">
            <span id="tour-total" class="text-base font-extrabold text-brand-700 dark:text-brand-400">$960 MXN</span>
            <span id="tour-total-usdc" class="block text-[11px] font-semibold text-slate-400 dark:text-slate-500">≈ $0.00 USDC</span>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col gap-2 pt-1">
          <button type="button" id="tour-pay-usdc-btn" class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-[#3f043a] hover:bg-[#3f043a]/90 text-white font-bold py-3 text-sm shadow-sm transition-all active:scale-[0.97]">
            <span class="material-symbols-outlined text-[18px]">account_balance_wallet</span>
            <span id="tour-pay-usdc-label">Pagar con USDC en Polygon</span>
          </button>
          <button type="submit" id="tour-submit-btn" class="w-full inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white hover:bg-slate-50 dark:bg-transparent dark:hover:bg-slate-900 text-slate-700 dark:text-slate-300 font-bold py-2.5 text-xs shadow-sm transition-all active:scale-[0.97]">
            <span class="material-symbols-outlined text-[14px]">send</span>
            Solo enviar solicitud (pendiente de pago)
          </button>
        </div>
      </form>

      <!-- Success state (hidden by default) -->
      <div id="tour-success-state" class="hidden mt-4 rounded-2xl bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-800/50 p-5 text-center">
        <span class="material-symbols-outlined text-4xl text-emerald-600 dark:text-emerald-400">check_circle</span>
        <h3 class="mt-2 text-base font-bold text-emerald-900 dark:text-emerald-200">¡Solicitud enviada!</h3>
        <p class="mt-1 text-[12px] text-emerald-800 dark:text-emerald-300 leading-relaxed">
          Te contactaremos por email y WhatsApp para confirmar disponibilidad y coordinar el pago.
        </p>
        <button type="button" id="tour-success-close" class="mt-4 w-full inline-flex items-center justify-center gap-1.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2 text-[12px] transition-all">
          Entendido
        </button>
      </div>
    </div>
  </div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .filter-chip[aria-pressed='true'] {
    background-color: #3f043a;
    color: #ffffff;
    border-color: #3f043a;
  }

  .exp-card.hidden-card {
    display: none !important;
  }
  .category-section.hidden-section {
    display: none !important;
  }

  @keyframes bounce-slow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
</style>

<script>
  // Filtrado y búsqueda client-side de experiencias con secciones horizontales.
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const sections = document.querySelectorAll<HTMLElement>('.category-section');
  const emptyState = document.getElementById('empty-state');
  const searchInput = document.getElementById('explore-search-input') as HTMLInputElement;

  let activeCategory = 'todos';
  let searchQuery = '';

  function updateList() {
    let totalVisibleCount = 0;

    sections.forEach((section) => {
      const sectionCategory = section.dataset.category || '';
      const renderCats = (section.dataset.renderCategories || sectionCategory).split(',');
      const cards = section.querySelectorAll<HTMLElement>('.exp-card');
      let visibleCardsInSection = 0;

      cards.forEach((card) => {
        const title = card.querySelector('h2')?.textContent?.toLowerCase() || '';
        const desc = card.querySelector('p')?.textContent?.toLowerCase() || '';

        const matchesCategory = activeCategory === 'todos' || renderCats.includes(activeCategory);
        const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery);

        const isVisible = matchesCategory && matchesSearch;
        card.classList.toggle('hidden-card', !isVisible);
        if (isVisible) {
          visibleCardsInSection++;
        }
      });

      // Si la categoría activa no aplica a esta sección, o si no hay cartas visibles, ocultamos la sección
      const isSectionVisible = renderCats.includes(activeCategory) && (visibleCardsInSection > 0);
      section.classList.toggle('hidden-section', !isSectionVisible);

      totalVisibleCount += visibleCardsInSection;
    });

    if (emptyState) {
      emptyState.classList.toggle('hidden', totalVisibleCount > 0);
      emptyState.classList.toggle('flex', totalVisibleCount === 0);
    }
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => {
        c.setAttribute('aria-pressed', 'false');
        c.classList.remove('shadow-sm');
      });
      chip.setAttribute('aria-pressed', 'true');
      chip.classList.add('shadow-sm');
      activeCategory = chip.dataset.filter ?? 'todos';
      updateList();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    updateList();
  });

  // Manejar el scroll horizontal con los botones chevron
  document.querySelectorAll('.category-section').forEach((section) => {
    const container = section.querySelector('.scroll-container');
    const leftBtn = section.querySelector('.scroll-left-btn');
    const rightBtn = section.querySelector('.scroll-right-btn');

    if (container) {
      leftBtn?.addEventListener('click', () => {
        container.scrollBy({ left: -280, behavior: 'smooth' });
      });
      rightBtn?.addEventListener('click', () => {
        container.scrollBy({ left: 280, behavior: 'smooth' });
      });
    }
  });

  // Hacer interactivos los botones de favoritos (corazón) y persistirlos
  function loadFavoritesState() {
    let favorites: string[] = [];
    try {
      favorites = JSON.parse(localStorage.getItem('edificarte_favorites') || '[]');
    } catch {}

    document.querySelectorAll<HTMLButtonElement>('.favorite-btn').forEach(btn => {
      const card = btn.closest<HTMLElement>('.exp-card');
      if (!card) return;
      const expId = card.dataset.id;
      if (!expId) return;

      const svg = btn.querySelector('svg');
      if (svg) {
        const isFav = favorites.includes(expId);
        if (isFav) {
          svg.classList.remove('fill-none', 'text-neutral-700', 'dark:text-neutral-300');
          svg.classList.add('fill-rose-500', 'text-rose-500');
        } else {
          svg.classList.remove('fill-rose-500', 'text-rose-500');
          svg.classList.add('fill-none', 'text-neutral-700', 'dark:text-neutral-300');
        }
      }
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.favorite-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = btn.closest<HTMLElement>('.exp-card');
      if (!card) return;
      const expId = card.dataset.id;
      if (!expId) return;

      let favorites: string[] = [];
      try {
        favorites = JSON.parse(localStorage.getItem('edificarte_favorites') || '[]');
      } catch {}

      const svg = btn.querySelector('svg');
      if (svg) {
        const index = favorites.indexOf(expId);
        if (index > -1) {
          favorites.splice(index, 1);
          svg.classList.remove('fill-rose-500', 'text-rose-500');
          svg.classList.add('fill-none', 'text-neutral-700', 'dark:text-neutral-300');
        } else {
          favorites.push(expId);
          svg.classList.remove('fill-none', 'text-neutral-700', 'dark:text-neutral-300');
          svg.classList.add('fill-rose-500', 'text-rose-500');
        }
      }
      localStorage.setItem('edificarte_favorites', JSON.stringify(favorites));
    });
  });

  loadFavoritesState();

  // Lógica del modal de guías y traducciones
  const guideModal = document.getElementById('guide-modal');
  const btnCloseGuide = document.getElementById('btn-close-guide');
  const btnGoToMapRoute = document.getElementById('btn-go-to-map-route');

  const guideTitle = document.getElementById('guide-modal-title');
  const guideBadge = document.getElementById('guide-modal-badge');
  const guideImage = document.getElementById('guide-modal-image') as HTMLImageElement;
  const guideText = document.getElementById('guide-modal-text');
  const guideRating = document.getElementById('guide-modal-rating');
  const guideVideoContainer = document.getElementById('guide-modal-video-container');
  const guideVideo = document.getElementById('guide-modal-video') as HTMLIFrameElement;

  const langTabs = document.querySelectorAll<HTMLButtonElement>('.guide-lang-tab');

  type TranslationData = { name: string; desc: string; category: string; cta: string; guide: string; videoUrl?: string };
  let currentTranslations: Record<string, TranslationData> | null = null;
  let currentMuseumId = '';
  let currentIsVR = false;
  let currentVRUrl = '';

  function openGuideModal(card: HTMLElement) {
    const rawTranslations = card.getAttribute('data-translations');
    if (!rawTranslations) return;

    try {
      currentTranslations = JSON.parse(rawTranslations);
    } catch (e) {
      console.error('Error parsing translations JSON:', e);
      return;
    }

    currentMuseumId = card.getAttribute('data-id') || '';
    const reviewTargetInput = document.querySelector<HTMLInputElement>('#guide-modal-review-form input[name="targetId"]');
    if (reviewTargetInput) reviewTargetInput.value = currentMuseumId;
    const rating = card.getAttribute('data-rating') || '4.8';
    const imageSrc = card.getAttribute('data-image') || '';
    const cardLat = parseFloat(card.getAttribute('data-lat') || '');
    const cardLng = parseFloat(card.getAttribute('data-lng') || '');

    // --- Proximity gate for reviews ---
    const proximityGate = document.getElementById('review-proximity-gate');
    const proximityMsg  = document.getElementById('review-proximity-msg');
    const reviewForm    = document.getElementById('guide-modal-review-form');

    function showReviewForm() {
      proximityGate?.classList.add('hidden');
      reviewForm?.classList.remove('hidden');
    }
    function showProximityMsg(msg: string) {
      if (proximityMsg) proximityMsg.textContent = msg;
      proximityGate?.classList.remove('hidden');
      proximityGate?.classList.add('flex');
      reviewForm?.classList.add('hidden');
    }

    if (!cardLat || !cardLng) {
      // Sin coordenadas → permitir siempre (tienda, tours sin lat/lng)
      showReviewForm();
    } else if (!('geolocation' in navigator)) {
      showProximityMsg('Tu navegador no soporta geolocalización. No podés dejar una reseña.');
    } else {
      showProximityMsg('Verificando tu ubicación…');
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          // Haversine simplificado (metros)
          const R = 6371000;
          const dLat = (cardLat - pos.coords.latitude) * Math.PI / 180;
          const dLng = (cardLng - pos.coords.longitude) * Math.PI / 180;
          const a = Math.sin(dLat/2)**2 +
            Math.cos(pos.coords.latitude * Math.PI / 180) *
            Math.cos(cardLat * Math.PI / 180) *
            Math.sin(dLng/2)**2;
          const dist = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
          if (dist <= 500) {
            showReviewForm();
          } else {
            showProximityMsg(`Necesitás estar a menos de 500 m del lugar para dejar una reseña. Estás a ${Math.round(dist)} m.`);
          }
        },
        () => {
          showProximityMsg('No se pudo obtener tu ubicación. Acercate al lugar para dejar una reseña.');
        },
        { timeout: 8000, maximumAge: 60000 }
      );
    }

    if (guideTitle) guideTitle.textContent = currentTranslations?.es?.name || '';
    if (guideImage) {
      guideImage.src = imageSrc;
      guideImage.alt = currentTranslations?.es?.name || '';
    }
    if (guideRating) guideRating.textContent = parseFloat(rating).toFixed(2);

    // Mostrar u ocultar pestaña de lengua nativa
    const nativeTab = document.getElementById('btn-guide-lang-native');
    if (nativeTab) {
      if (currentTranslations && currentTranslations.native) {
        nativeTab.classList.remove('hidden');
      } else {
        nativeTab.classList.add('hidden');
      }
    }

    // Default a español
    setGuideLanguage('es');

    // Si la card tiene experiencia VR, mostrar el iframe en el slot del video
    // y renombrar el título del bloque. La lógica de tabs sigue funcionando encima.
    currentIsVR = card.getAttribute('data-is-vr') === 'true';
    currentVRUrl = card.getAttribute('data-vr-url') || '';
    const vrTitle = guideVideoContainer?.querySelector('h4');
    if (currentIsVR && currentVRUrl && guideVideoContainer && guideVideo) {
      guideVideoContainer.classList.remove('hidden');
      if (vrTitle) vrTitle.textContent = 'Experiencia Inmersiva VR (YouTube 360°)';
      guideVideo.src = currentVRUrl;
    }

    if (guideModal) {
      guideModal.classList.remove('hidden');
      // Forzar reflow
      void guideModal.offsetHeight;
      guideModal.classList.remove('opacity-0');
      document.body.classList.add('modal-open');
      const innerContent = guideModal.querySelector('div');
      if (innerContent) {
        innerContent.classList.remove('scale-95');
        innerContent.classList.add('scale-100');
      }
    }
  }

  function closeGuideModal() {
    if (guideModal) {
      guideModal.classList.add('opacity-0');
      const innerContent = guideModal.querySelector('div');
      if (innerContent) {
        innerContent.classList.remove('scale-100');
        innerContent.classList.add('scale-95');
      }
      setTimeout(() => {
        guideModal.classList.add('hidden');
        if (guideVideo) guideVideo.src = ''; // Detener video si se está reproduciendo
        document.body.classList.remove('modal-open');
        currentIsVR = false;
        currentVRUrl = '';
      }, 300);
    }
  }

  function setGuideLanguage(lang: string) {
    if (!currentTranslations || !currentTranslations[lang]) return;

    const data = currentTranslations[lang];

    if (guideTitle) guideTitle.textContent = data.name;
    if (guideBadge) guideBadge.textContent = data.category;
    if (guideText) {
      let guideHtml = data.guide || '';
      // Convertir URLs en enlaces cliqueables
      guideHtml = guideHtml.replace(
        /(https?:\/\/[^\s)]+)/g,
        (url: string) => `<a href="${url}" target="_blank" rel="noopener noreferrer" class="text-indigo-600 dark:text-indigo-400 underline font-semibold hover:text-indigo-700">${url.replace('https://', '')}</a>`
      );
      // Reemplazar saltos de línea por <br>
      guideHtml = guideHtml.replace(/\n/g, '<br>');
      guideText.innerHTML = guideHtml;
    }

    // Actualizar tabs activas visualmente
    langTabs.forEach((tab) => {
      const isSelected = tab.getAttribute('data-guide-lang') === lang;
      tab.classList.toggle('bg-white', isSelected);
      tab.classList.toggle('dark:bg-slate-700', isSelected);
      tab.classList.toggle('shadow-sm', isSelected);
      tab.classList.toggle('text-brand-700', isSelected);
      tab.classList.toggle('dark:text-brand-300', isSelected);

      tab.classList.toggle('text-slate-500', !isSelected);
      tab.classList.toggle('dark:text-slate-400', !isSelected);
      tab.classList.toggle('hover:text-slate-700', !isSelected);
      tab.classList.toggle('dark:hover:text-slate-350', !isSelected);
    });

    // Manejar video de LSM o VR
    if (currentIsVR && currentVRUrl) {
      // Experiencia VR: el iframe queda fijo, los tabs solo cambian el texto guía
      if (guideVideoContainer) guideVideoContainer.classList.remove('hidden');
      if (guideVideo) guideVideo.src = currentVRUrl;
    } else if (lang === 'señas' && data.videoUrl) {
      if (guideVideoContainer) guideVideoContainer.classList.remove('hidden');
      if (guideVideo) guideVideo.src = data.videoUrl;
    } else {
      if (guideVideoContainer) guideVideoContainer.classList.add('hidden');
      if (guideVideo) guideVideo.src = '';
    }
  }

  // Escuchar clics en tarjetas (museos y tienda)
  document.querySelectorAll<HTMLElement>('.exp-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      // Ignorar si pulsó el botón de favoritos u otros botones internos
      const target = e.target as HTMLElement;
      if (target.closest('.favorite-btn') || target.closest('.guide-trigger-btn') || target.closest('.product-trigger-btn')) {
        if (target.closest('.favorite-btn')) return;
      }

      const isProduct = card.getAttribute('data-is-product') === 'true';
      if (isProduct) {
        openProductModal(card);
      } else if (card.getAttribute('data-translations')) {
        openGuideModal(card);
      }
    });
  });

  // También escuchar en botones específicos de acción
  document.querySelectorAll<HTMLButtonElement>('.guide-trigger-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = btn.closest('.exp-card') as HTMLElement;
      if (card) openGuideModal(card);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.product-trigger-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = btn.closest('.exp-card') as HTMLElement;
      if (card) openProductModal(card);
    });
  });

  // Escuchar clics en los tabs de idioma del modal de guía
  langTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const lang = tab.getAttribute('data-guide-lang');
      if (lang) setGuideLanguage(lang);
    });
  });

  btnCloseGuide?.addEventListener('click', closeGuideModal);

  // Cerrar haciendo clic afuera del modal de guía
  guideModal?.addEventListener('click', (e) => {
    if (e.target === guideModal) {
      closeGuideModal();
    }
  });

  // Redirigir al mapa con la ruta activa
  btnGoToMapRoute?.addEventListener('click', () => {
    if (currentMuseumId) {
      window.location.href = `/mapa?route=${currentMuseumId}&play=true`;
    }
  });

  // --- LÓGICA DE TIENDA Y CARRITO DE COMPRAS ---

  // Elementos de la Tienda
  const productModal = document.getElementById('product-modal');
  const btnCloseProduct = document.getElementById('btn-close-product');
  const productTitle = document.getElementById('product-modal-title');
  const productImage = document.getElementById('product-modal-image') as HTMLImageElement;
  const productPrice = document.getElementById('product-modal-price');
  const productDesc = document.getElementById('product-modal-desc');
  const productSku = document.getElementById('product-modal-sku');
  const productImageDots = document.getElementById('product-image-dots');
  const btnProductPrevImg = document.getElementById('btn-product-prev-img');
  const btnProductNextImg = document.getElementById('btn-product-next-img');

  const btnQtyMinus = document.getElementById('btn-qty-minus');
  const btnQtyPlus = document.getElementById('btn-qty-plus');
  const qtyValueEl = document.getElementById('product-qty-value');
  const btnAddToCart = document.getElementById('btn-add-to-cart');

  const btnCartToggle = document.getElementById('btn-cart-toggle');
  const btnCloseCart = document.getElementById('btn-close-cart');
  const cartDrawer = document.getElementById('cart-drawer');
  const cartDrawerContent = document.getElementById('cart-drawer-content');
  const cartItemsContainer = document.getElementById('cart-items-container');
  const cartEmptyState = document.getElementById('cart-empty-state');
  const cartSubtotalEl = document.getElementById('cart-subtotal');
  const cartTotalEl = document.getElementById('cart-total');
  const cartBadge = document.getElementById('cart-badge');
  const btnCheckout = document.getElementById('btn-checkout');

  // Estado de la Tienda
  interface CartItem {
    sku: string;
    name: string;
    price: number;
    image: string;
    qty: number;
  }

  let cart: CartItem[] = [];
  let productImages: string[] = [];
  let currentImageIdx = 0;
  let currentQty = 1;
  let activeProduct: { sku: string; name: string; price: number; image: string } | null = null;

  // Cargar Carrito desde LocalStorage
  function loadCart() {
    try {
      const stored = localStorage.getItem('edificarte_cart');
      if (stored) {
        cart = JSON.parse(stored);
      }
    } catch (e) {
      console.error('Error loading cart:', e);
      cart = [];
    }
    updateCartUI();
  }

  // Guardar Carrito en LocalStorage
  function saveCart() {
    localStorage.setItem('edificarte_cart', JSON.stringify(cart));
    updateCartUI();
  }

  // Actualizar la interfaz del carrito y contador
  function updateCartUI() {
    const totalItems = cart.reduce((acc, item) => acc + item.qty, 0);
    const subtotal = cart.reduce((acc, item) => acc + (item.price * item.qty), 0);

    // Actualizar badge del botón flotante e integrar visibilidad del botón en sí
    if (cartBadge) {
      cartBadge.textContent = totalItems.toString();
      cartBadge.classList.toggle('hidden', totalItems === 0);
      cartBadge.classList.toggle('flex', totalItems > 0);
    }
    if (btnCartToggle) {
      btnCartToggle.classList.toggle('hidden', totalItems === 0);
      btnCartToggle.classList.toggle('flex', totalItems > 0);
    }

    // Renderizar items del carrito
    if (cartItemsContainer) {
      // Remover todo excepto el empty state
      const itemEls = cartItemsContainer.querySelectorAll('.cart-item-row');
      itemEls.forEach(el => el.remove());

      if (cart.length === 0) {
        if (cartEmptyState) cartEmptyState.classList.remove('hidden');
      } else {
        if (cartEmptyState) cartEmptyState.classList.add('hidden');

        cart.forEach((item) => {
          const row = document.createElement('div');
          row.className = 'cart-item-row flex items-center gap-3 p-3 rounded-2xl bg-slate-50 dark:bg-slate-850 border border-slate-100 dark:border-slate-800/40';

          // Helper local para construir elementos sin innerHTML (XSS hardening)
          const el = (tag: string, className: string, text?: string): HTMLElement => {
            const node = document.createElement(tag);
            if (className) node.className = className;
            if (text !== undefined) node.textContent = text;
            return node;
          };

          const img = document.createElement('img');
          img.src = item.image;
          img.alt = item.name;
          img.className = 'h-16 w-16 rounded-xl object-cover bg-slate-100 dark:bg-slate-800 flex-none';
          row.appendChild(img);

          const info = el('div', 'flex-1 min-w-0');
          const title = el('h4', 'text-xs font-bold text-slate-800 dark:text-white truncate', item.name);
          info.appendChild(title);

          const price = el('p', 'text-[11px] font-extrabold text-purple-600 dark:text-purple-400 mt-0.5', `$${item.price.toFixed(2)} MXN`);
          info.appendChild(price);

          const controlsRow = el('div', 'flex items-center justify-between mt-2');

          const qtyBox = el('div', 'flex items-center border border-slate-200 dark:border-slate-700 rounded-lg px-1.5 py-0.5 bg-white dark:bg-slate-900');

          const btnMinus = document.createElement('button');
          btnMinus.type = 'button';
          btnMinus.className = 'btn-cart-minus p-0.5 hover:bg-slate-100 dark:hover:bg-slate-800 rounded text-slate-500 active:scale-90';
          btnMinus.setAttribute('data-sku', item.sku);
          const minusIcon = el('span', 'material-symbols-outlined text-[12px] font-bold', 'remove');
          btnMinus.appendChild(minusIcon);
          qtyBox.appendChild(btnMinus);

          const qtyLabel = el('span', 'px-2 text-[11px] font-bold text-slate-700 dark:text-slate-200', String(item.qty));
          qtyBox.appendChild(qtyLabel);

          const btnPlus = document.createElement('button');
          btnPlus.type = 'button';
          btnPlus.className = 'btn-cart-plus p-0.5 hover:bg-slate-100 dark:hover:bg-slate-800 rounded text-slate-500 active:scale-90';
          btnPlus.setAttribute('data-sku', item.sku);
          const plusIcon = el('span', 'material-symbols-outlined text-[12px] font-bold', 'add');
          btnPlus.appendChild(plusIcon);
          qtyBox.appendChild(btnPlus);

          controlsRow.appendChild(qtyBox);

          const btnRemove = document.createElement('button');
          btnRemove.type = 'button';
          btnRemove.className = 'btn-cart-remove text-rose-500 hover:text-rose-600 p-1 rounded-full hover:bg-rose-50 dark:hover:bg-rose-950/20 active:scale-90 transition-all';
          btnRemove.setAttribute('data-sku', item.sku);
          btnRemove.title = 'Eliminar artículo';
          const removeIcon = el('span', 'material-symbols-outlined text-[16px]', 'delete');
          btnRemove.appendChild(removeIcon);

          controlsRow.appendChild(btnRemove);
          info.appendChild(controlsRow);
          row.appendChild(info);

          // Bindear eventos
          btnMinus.addEventListener('click', () => {
            if (item.qty > 1) {
              updateItemQty(item.sku, item.qty - 1);
            } else {
              removeItem(item.sku);
            }
          });

          btnPlus.addEventListener('click', () => {
            updateItemQty(item.sku, item.qty + 1);
          });

          btnRemove.addEventListener('click', () => {
            removeItem(item.sku);
          });

          cartItemsContainer.appendChild(row);
        });
      }
    }

    // Totales
    if (cartSubtotalEl) cartSubtotalEl.textContent = `$${subtotal.toFixed(2)} MXN`;
    if (cartTotalEl) cartTotalEl.textContent = `$${subtotal.toFixed(2)} MXN`;
  }

  function updateItemQty(sku: string, qty: number) {
    const item = cart.find(i => i.sku === sku);
    if (item) {
      item.qty = qty;
      saveCart();
    }
  }

  function removeItem(sku: string) {
    cart = cart.filter(i => i.sku !== sku);
    saveCart();
  }

  // Abrir Modal de Producto
  function openProductModal(card: HTMLElement) {
    const title = card.getAttribute('data-title') || '';
    const desc = card.getAttribute('data-desc') || '';
    const priceText = card.getAttribute('data-price') || '';
    const sku = card.getAttribute('data-sku') || '';
    const rawImages = card.getAttribute('data-images');
    const defaultImage = card.getAttribute('data-image') || '';

    try {
      productImages = rawImages ? JSON.parse(rawImages) : [defaultImage];
    } catch (_) {
      productImages = [defaultImage];
    }

    currentImageIdx = 0;
    currentQty = 1;

    // Parsear precio numérico
    let numericPrice = 0;
    if (priceText) {
      const match = priceText.match(/[\d.]+/);
      if (match) numericPrice = parseFloat(match[0]);
    }

    activeProduct = {
      sku: sku || title,
      name: title,
      price: numericPrice,
      image: productImages[0] || defaultImage
    };

    if (productTitle) productTitle.textContent = title;
    if (productDesc) productDesc.textContent = desc;
    if (productPrice) productPrice.textContent = priceText || 'Consultar';
    if (productSku) productSku.textContent = sku || 'N/A';
    if (qtyValueEl) qtyValueEl.textContent = currentQty.toString();

    updateProductGallery();

    if (productModal) {
      productModal.classList.remove('hidden');
      void productModal.offsetHeight;
      productModal.classList.remove('opacity-0');
      document.body.classList.add('modal-open');
      const innerContent = productModal.querySelector('div');
      if (innerContent) {
        innerContent.classList.remove('scale-95');
        innerContent.classList.add('scale-100');
      }
    }
  }

  // Cerrar Modal de Producto
  function closeProductModal() {
    if (productModal) {
      productModal.classList.add('opacity-0');
      const innerContent = productModal.querySelector('div');
      if (innerContent) {
        innerContent.classList.remove('scale-100');
        innerContent.classList.add('scale-95');
      }
      setTimeout(() => {
        productModal.classList.add('hidden');
        document.body.classList.remove('modal-open');
      }, 300);
    }
  }

  // Actualizar Galería de Imágenes
  function updateProductGallery() {
    if (productImages.length === 0) return;

    if (productImage) {
      productImage.src = productImages[currentImageIdx];
      productImage.alt = activeProduct?.name || 'Producto';
    }

    // Ocultar flechas si solo hay 1 imagen
    if (btnProductPrevImg && btnProductNextImg) {
      const showArrows = productImages.length > 1;
      btnProductPrevImg.classList.toggle('hidden', !showArrows);
      btnProductNextImg.classList.toggle('hidden', !showArrows);
    }

    // Renderizar puntitos indicadores
    if (productImageDots) {
      productImageDots.innerHTML = '';
      if (productImages.length > 1) {
        productImages.forEach((_, idx) => {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = `h-1.5 rounded-full transition-all duration-300 ${idx === currentImageIdx ? 'w-4 bg-purple-600' : 'w-1.5 bg-slate-300 dark:bg-slate-700'}`;
          dot.addEventListener('click', () => {
            currentImageIdx = idx;
            updateProductGallery();
          });
          productImageDots.appendChild(dot);
        });
      }
    }
  }

  // Eventos de Navegación de Imágenes
  btnProductPrevImg?.addEventListener('click', () => {
    if (productImages.length > 1) {
      currentImageIdx = (currentImageIdx - 1 + productImages.length) % productImages.length;
      updateProductGallery();
    }
  });

  btnProductNextImg?.addEventListener('click', () => {
    if (productImages.length > 1) {
      currentImageIdx = (currentImageIdx + 1) % productImages.length;
      updateProductGallery();
    }
  });

  // Eventos de Cantidad
  btnQtyMinus?.addEventListener('click', () => {
    if (currentQty > 1) {
      currentQty--;
      if (qtyValueEl) qtyValueEl.textContent = currentQty.toString();
    }
  });

  btnQtyPlus?.addEventListener('click', () => {
    currentQty++;
    if (qtyValueEl) qtyValueEl.textContent = currentQty.toString();
  });

  // Agregar al Carrito
  btnAddToCart?.addEventListener('click', () => {
    if (!activeProduct) return;

    const existingIdx = cart.findIndex(item => item.sku === activeProduct!.sku);
    if (existingIdx !== -1) {
      cart[existingIdx].qty += currentQty;
    } else {
      cart.push({
        sku: activeProduct.sku,
        name: activeProduct.name,
        price: activeProduct.price,
        image: activeProduct.image,
        qty: currentQty
      });
    }

    saveCart();
    closeProductModal();

    // Feedback visual breve del botón de carrito flotante (animación de rebote)
    if (btnCartToggle) {
      btnCartToggle.classList.add('scale-110');
      setTimeout(() => {
        btnCartToggle.classList.remove('scale-110');
      }, 300);
    }
  });

  // Cerrar Modal Producto al hacer clic afuera
  productModal?.addEventListener('click', (e) => {
    if (e.target === productModal) {
      closeProductModal();
    }
  });

  btnCloseProduct?.addEventListener('click', closeProductModal);

  // --- GESTIÓN DEL DRAWER DEL CARRITO ---

  function openCartDrawer() {
    if (cartDrawer && cartDrawerContent) {
      cartDrawer.classList.remove('hidden');
      void cartDrawer.offsetHeight;
      cartDrawer.classList.remove('opacity-0');
      cartDrawerContent.classList.remove('translate-x-full');
      cartDrawerContent.classList.add('translate-x-0');
      document.body.classList.add('modal-open');
    }
  }

  function closeCartDrawer() {
    if (cartDrawer && cartDrawerContent) {
      cartDrawer.classList.add('opacity-0');
      cartDrawerContent.classList.remove('translate-x-0');
      cartDrawerContent.classList.add('translate-x-full');
      setTimeout(() => {
        cartDrawer.classList.add('hidden');
        document.body.classList.remove('modal-open');
      }, 300);
    }
  }

  btnCartToggle?.addEventListener('click', openCartDrawer);
  btnCloseCart?.addEventListener('click', closeCartDrawer);

  cartDrawer?.addEventListener('click', (e) => {
    if (e.target === cartDrawer) {
      closeCartDrawer();
    }
  });

  // Checkout USDC + WhatsApp post-pago
  // Tipo de cambio hardcoded por simplicidad — reemplazar por oracle cuando
  // exista la necesidad (ej. Chainlink MATIC/USD o API tipo CoinGecko).
  const MXN_PER_USDC = 17; // 1 USDC ≈ 17 MXN
  const btnCheckoutLabel = document.getElementById('btn-checkout-label');
  const btnCheckoutHelp = document.getElementById('btn-checkout-help');
  const cartTotalUsdcEl = document.getElementById('cart-total-usdc');

  function mxnToUsdc(mxn: number): number {
    return Math.round((mxn / MXN_PER_USDC) * 100) / 100;
  }

  function rawUsdc(usdc: number): string {
    // 12.50 USDC → "12500000" (6 decimales)
    const [w, d = ''] = String(usdc).split('.');
    const decPadded = (d + '0'.repeat(6)).slice(0, 6);
    const raw = BigInt(w) * BigInt(1000000) + BigInt(decPadded || '0');
    return raw.toString();
  }

  // Mantener visible el equivalente USDC en el cart drawer
  const usdcObserver = new MutationObserver(() => {
    const mxnText = cartTotalEl?.textContent ?? '$0.00 MXN';
    const mxn = parseFloat(mxnText.replace(/[^\d.]/g, '') || '0');
    if (cartTotalUsdcEl) {
      const usdc = mxnToUsdc(mxn);
      cartTotalUsdcEl.textContent = `$${usdc.toFixed(2)} USDC`;
    }
  });
  if (cartTotalEl) usdcObserver.observe(cartTotalEl, { childList: true, characterData: true, subtree: true });

  let walletAddress: string | null = null;

  async function ensureWallet(): Promise<string | null> {
    const { BrowserWalletProvider } = await import('../lib/onchain/client');
    const wallet = new BrowserWalletProvider();
    walletAddress = await wallet.connect();
    if (btnCheckoutLabel) btnCheckoutLabel.textContent = 'Pagar con USDC';
    if (btnCheckoutHelp) btnCheckoutHelp.textContent = `Wallet: ${walletAddress.slice(0, 6)}…${walletAddress.slice(-4)} · Polygon`;
    return walletAddress;
  }

  btnCheckout?.addEventListener('click', async () => {
    if (cart.length === 0) return;
    if (!btnCheckoutLabel) return;

    const originalLabel = btnCheckoutLabel.textContent;

    // 1. Si no hay wallet, conectar primero.
    if (!walletAddress) {
      try {
        btnCheckoutLabel.textContent = 'Conectando…';
        await ensureWallet();
        return; // el próximo click paga
      } catch (err: unknown) {
        btnCheckoutLabel.textContent = originalLabel;
        alert((err as Error)?.message || 'No se pudo conectar la wallet. ¿Tenés MetaMask o Rabby instalado?');
        return;
      }
    }

    // 2. Calcular total USDC y abrir MetaMask para firmar la tx.
    const totalMXN = cart.reduce((acc, item) => acc + item.price * item.qty, 0);
    const totalUSDC = mxnToUsdc(totalMXN);
    const rawAmount = rawUsdc(totalUSDC);

    btnCheckoutLabel.textContent = 'Esperando firma…';

    try {
      const { BrowserWalletProvider } = await import('../lib/onchain/client');
      const wallet = new BrowserWalletProvider();

      const txHash = await wallet.sendUsdcTransfer({
        to: window.__EDIFICARTE_PAYMENT_ADDRESS__ || '0xD540067d763bc792b81f816a677bB25d7e6d4B0B',
        rawAmount,
      });

      btnCheckoutLabel.textContent = 'Confirmando pago…';

      // 3. Server valida y registra la orden.
      const orderRes = await fetch('/api/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          txHash,
          walletAddress,
          totalUSDC,
          items: cart.map((item) => ({
            sku: item.sku,
            name: item.name,
            qty: item.qty,
            priceMXN: item.price,
            priceUSDC: mxnToUsdc(item.price),
          })),
        }),
      });

      const orderData = await orderRes.json();
      if (!orderRes.ok) {
        alert(orderData.error || 'No pudimos registrar el pago. Contactanos por WhatsApp.');
        btnCheckoutLabel.textContent = originalLabel;
        return;
      }

      // 4. Pago OK: limpiar carrito y mandar WhatsApp con resumen + txHash.
      cart = [];
      saveCart();
      closeCartDrawer();

      const phoneNumber = '5215512345678';
      let message = '¡Hola! Acabo de pagar mi pedido de Tianquiztlis Mercado en USDC:\n\n';
      cart.forEach((item, index) => {
        message += `${index + 1}. ${item.name} (Cant: ${item.qty}) - ${item.qty * item.price} MXN\n`;
      });
      message += `\n*Total:* ${totalMXN.toFixed(2)} MXN (${totalUSDC.toFixed(2)} USDC)\n`;
      message += `*Order ID:* ${orderData.orderId}\n`;
      message += `*Tx Hash:* ${txHash}\n\n`;
      message += '¿Coordinamos la entrega?';

      window.open(`https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`, '_blank');
      btnCheckoutLabel.textContent = originalLabel;
    } catch (err: unknown) {
      console.error('Error en checkout USDC:', err);
      alert((err as Error)?.message || 'No se pudo completar el pago.');
      btnCheckoutLabel.textContent = originalLabel;
    }
  });

  // Inicializar carrito en la carga
  loadCart();

  // --- TOUR RESERVATION MODAL ---

  const tourModal = document.getElementById('tour-modal');
  const tourModalClose = document.getElementById('tour-modal-close');
  const tourModalTitle = document.getElementById('tour-modal-title');
  const tourModalSubtitle = document.getElementById('tour-modal-subtitle');
  const tourIdInput = document.getElementById('tour-id-input') as HTMLInputElement | null;
  const tourForm = document.getElementById('tour-reservation-form') as HTMLFormElement | null;
  const tourTotalEl = document.getElementById('tour-total');
  const tourTotalUsdcEl = document.getElementById('tour-total-usdc');
  const tourPayUsdcBtn = document.getElementById('tour-pay-usdc-btn') as HTMLButtonElement | null;
  const tourPayUsdcLabel = document.getElementById('tour-pay-usdc-label');
  const tourSuccess = document.getElementById('tour-success-state');
  const tourSuccessClose = document.getElementById('tour-success-close');
  const tourPeopleInput = document.getElementById('tour-people') as HTMLInputElement | null;
  const tourSubmitBtn = document.getElementById('tour-submit-btn') as HTMLButtonElement | null;

  const TOUR_PRICE = 480;

  function openTourModal(tourId: string, title: string, subtitle: string) {
    if (!tourModal) return;
    if (tourIdInput) tourIdInput.value = tourId;
    if (tourModalTitle) tourModalTitle.textContent = title;
    if (tourModalSubtitle) tourModalSubtitle.textContent = subtitle;
    updateTourTotal();
    if (tourSuccess) tourSuccess.classList.add('hidden');
    if (tourForm) tourForm.classList.remove('hidden');
    tourModal.classList.remove('hidden');
    void tourModal.offsetHeight;
    tourModal.classList.remove('opacity-0');
    document.body.classList.add('modal-open');
    if (tourPeopleInput) tourPeopleInput.value = '2';
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    const dateInput = document.getElementById('tour-date') as HTMLInputElement | null;
    if (dateInput) dateInput.min = tomorrow.toISOString().split('T')[0];
  }

  function closeTourModal() {
    if (!tourModal) return;
    tourModal.classList.add('opacity-0');
    setTimeout(() => {
      tourModal.classList.add('hidden');
      document.body.classList.remove('modal-open');
    }, 250);
  }

  function updateTourTotal() {
    const n = parseInt(tourPeopleInput?.value || '1', 10) || 1;
    const mxn = n * TOUR_PRICE;
    if (tourTotalEl) {
      tourTotalEl.textContent = `$${mxn.toLocaleString('es-MX')} MXN`;
    }
    if (tourTotalUsdcEl) {
      const usdc = mxnToUsdc(mxn);
      tourTotalUsdcEl.textContent = `≈ $${usdc.toFixed(2)} USDC`;
    }
  }

  document.querySelectorAll<HTMLButtonElement>('.tour-reserve-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = btn.closest<HTMLElement>('[data-tour-id]');
      if (!card) return;
      openTourModal(
        card.dataset.tourId || '',
        card.dataset.tourTitle || 'Tour',
        card.dataset.tourMeeting || ''
      );
    });
  });

  // Listener para el AI Agent
  window.addEventListener('ai-reserve-tour', (e: Event) => {
    const monumentId = (e as CustomEvent<{ monumentId?: string }>).detail?.monumentId;
    if (!monumentId) return;
    const btn = document.querySelector(`[data-tour-id="${monumentId}"]`) as HTMLElement;
    if (btn) {
      openTourModal(
        btn.dataset.tourId || '',
        btn.dataset.tourTitle || 'Tour',
        btn.dataset.tourMeeting || ''
      );
    } else {
      // Fallback genérico si no se encuentra en el DOM actual
      openTourModal(monumentId, 'Recorrido Especial', '');
    }
  });

  tourPeopleInput?.addEventListener('input', updateTourTotal);

  tourModalClose?.addEventListener('click', closeTourModal);
  tourSuccessClose?.addEventListener('click', closeTourModal);
  tourModal?.addEventListener('click', (e) => {
    if (e.target === tourModal) closeTourModal();
  });

  tourPayUsdcBtn?.addEventListener('click', async (e) => {
    e.preventDefault();
    if (!tourForm || !tourPayUsdcBtn || !tourPayUsdcLabel) return;

    // Obtener los datos del formulario
    const tourId = tourIdInput?.value || '';
    const tourCard = document.querySelector<HTMLElement>(`[data-tour-id="${tourId}"]`);
    const tourTitle = tourCard?.dataset.tourTitle || 'Tour';
    const tourImage = tourCard?.dataset.tourImage || '';

    const formData = new FormData(tourForm);
    const data: Record<string, unknown> = {
      tourId,
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      date: formData.get('date'),
      people: parseInt(formData.get('people') as string, 10) || 1,
      notes: formData.get('notes') || '',
    };

    if (!data.name || !data.email || !data.phone || !data.date || !data.people) {
      alert('Por favor completá todos los campos obligatorios para el pago y registro.');
      return;
    }

    // 1. Conectar wallet
    let walletAddress = '';
    try {
      if (typeof (window as unknown as { ethereum?: unknown }).ethereum === 'undefined') {
        alert('MetaMask o un navegador Web3 es requerido para pagar con USDC.');
        return;
      }
      const accounts = await (window as unknown as { ethereum: { request: (args: { method: string }) => Promise<string[]> } }).ethereum.request({ method: 'eth_requestAccounts' });
      walletAddress = accounts[0];
    } catch (err: unknown) {
      alert((err as Error)?.message || 'No se pudo conectar la wallet.');
      return;
    }

    // 2. Calcular total USDC y firmar la tx
    const totalMXN = (data.people as number) * TOUR_PRICE;
    const totalUSDC = mxnToUsdc(totalMXN);
    const rawAmount = rawUsdc(totalUSDC);

    const originalLabel = tourPayUsdcLabel.textContent;
    tourPayUsdcLabel.textContent = 'Esperando firma…';
    tourPayUsdcBtn.disabled = true;

    try {
      const { BrowserWalletProvider } = await import('../lib/onchain/client');
      const wallet = new BrowserWalletProvider();

      const txHash = await wallet.sendUsdcTransfer({
        to: window.__EDIFICARTE_PAYMENT_ADDRESS__ || '0xD540067d763bc792b81f816a677bB25d7e6d4B0B',
        rawAmount,
      });

      tourPayUsdcLabel.textContent = 'Confirmando pago…';

      // 3. Enviar al server la reserva con el txHash de USDC
      data.txHash = txHash;
      data.walletAddress = walletAddress;
      data.totalUSDC = totalUSDC;

      const response = await fetch('/api/reservar-tour', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!response.ok) {
        const errData = await response.json();
        throw new Error(errData.error || 'Error en el servidor al registrar el pago');
      }

      const result = await response.json();

      // Persistir reserva en localStorage
      try {
        const STORAGE_KEY = 'edificarte_reservations';
        const existing = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]') as Array<Record<string, unknown>>;
        const reservation = {
          id: result.reservationId || `RES-${Date.now()}`,
          tourId: data.tourId,
          tourTitle,
          tourImage,
          name: data.name,
          email: data.email,
          phone: data.phone,
          date: data.date,
          people: data.people,
          totalMXN,
          totalUSDC,
          txHash,
          status: 'paid',
          createdAt: new Date().toISOString(),
        };
        existing.push(reservation);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(existing));
      } catch (storageErr) {
        console.warn('No se pudo guardar la reserva en localStorage:', storageErr);
      }

      // Cerrar y mostrar éxito
      if (tourSuccess) tourSuccess.classList.remove('hidden');
      if (tourForm) tourForm.classList.add('hidden');
      tourForm.reset();
      if (tourPeopleInput) tourPeopleInput.value = '2';
    } catch (err: unknown) {
      console.error('Error al realizar el pago del tour:', err);
      alert((err as Error)?.message || 'Hubo un error al procesar el pago con USDC.');
    } finally {
      tourPayUsdcBtn.disabled = false;
      tourPayUsdcLabel.textContent = originalLabel;
    }
  });

  tourForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!tourSubmitBtn || !tourForm) return;

    // Snapshot de datos de la card ANTES del await (puede re-renderizarse)
    const tourId = tourIdInput?.value || '';
    const tourCard = document.querySelector<HTMLElement>(`[data-tour-id="${tourId}"]`);
    const tourTitle = tourCard?.dataset.tourTitle || 'Tour';
    const tourImage = tourCard?.dataset.tourImage || '';

    const formData = new FormData(tourForm);
    const data = {
      tourId,
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      date: formData.get('date'),
      people: parseInt(formData.get('people') as string, 10) || 1,
      notes: formData.get('notes') || '',
    };

    if (!data.name || !data.email || !data.phone || !data.date || !data.people) {
      alert('Por favor completá todos los campos obligatorios.');
      return;
    }

    tourSubmitBtn.disabled = true;
    const originalText = tourSubmitBtn.innerHTML;
    tourSubmitBtn.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">progress_activity</span> Enviando...';

    try {
      const response = await fetch('/api/reservar-tour', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!response.ok) throw new Error('Error en el servidor');

      const result = await response.json();

      // Persistir reserva en localStorage para que aparezca en /yo
      try {
        const STORAGE_KEY = 'edificarte_reservations';
        const existing = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]') as Array<Record<string, unknown>>;
        const reservation = {
          id: result.reservationId || `RES-${Date.now()}`,
          tourId: data.tourId,
          tourTitle,
          tourImage,
          name: data.name,
          email: data.email,
          phone: data.phone,
          date: data.date,
          people: data.people,
          totalMXN: result.totalMXN || 0,
          status: 'pending',
          createdAt: new Date().toISOString(),
        };
        existing.push(reservation);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(existing));
      } catch (storageErr) {
        console.warn('No se pudo guardar la reserva en localStorage:', storageErr);
      }

      if (tourSuccess) tourSuccess.classList.remove('hidden');
      if (tourForm) tourForm.classList.add('hidden');
      tourForm.reset();
      if (tourPeopleInput) tourPeopleInput.value = '2';
    } catch (err) {
      console.error('Error al reservar:', err);
      alert('Hubo un error al enviar la solicitud. Por favor intentá de nuevo o contactanos por WhatsApp.');
    } finally {
      tourSubmitBtn.disabled = false;
      tourSubmitBtn.innerHTML = originalText;
    }
  });
</script>
</Layout>
