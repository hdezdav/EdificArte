---
import Layout from '../layouts/Layout.astro';

const explorarCards = [
  {
    title: 'Turismo Regenerativo México',
    description: 'Experiencias inmersivas con comunidades locales que impulsan el cambio social y la regeneración cultural.',
    url: 'https://turismoregenerativomexico.com',
    cta: 'Conoce más',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
    </svg>`,
    tag: 'Turismo',
    tagColor: 'emerald',
  },
  {
    title: 'Fundación EdificARTE',
    description: 'Preservamos el patrimonio arquitectónico y cultural de México a través de la educación y la tecnología.',
    url: 'https://www.fundacionedificate.org/',
    cta: 'Visitar sitio',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
    </svg>`,
    tag: 'Fundación',
    tagColor: 'brand',
  },
];

const tagStyles: Record<string, { badge: string; icon: string; bg: string }> = {
  emerald: {
    badge: 'border-emerald-200/50 bg-emerald-50 text-emerald-700 dark:border-emerald-800/50 dark:bg-emerald-950/40 dark:text-emerald-400',
    icon: 'bg-emerald-50 text-emerald-600 dark:bg-emerald-950/30 dark:text-emerald-400',
    bg: 'from-emerald-600 to-emerald-800',
  },
  brand: {
    badge: 'border-brand-200/50 bg-brand-50 text-brand-700 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-400',
    icon: 'bg-brand-50 text-brand-600 dark:bg-brand-950/30 dark:text-brand-400',
    bg: 'from-brand-600 to-brand-800',
  },
};
---

<Layout title="EdificARTE — Explorar">
  <script is:inline>
    if (!localStorage.getItem('edificarte_lang')) {
      window.location.href = '/mapa';
    }
  </script>
  <div class="space-y-6">
    <!-- Header -->
    <div
      class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 p-6 text-white shadow-xl"
    >
      <div
        class="pointer-events-none absolute -bottom-10 -right-10 h-40 w-40 rounded-full bg-white/5 blur-xl"
      >
      </div>
      <h1 class="text-3xl font-extrabold tracking-tight">Explorar</h1>
      <p class="mt-2 max-w-md text-brand-100">
        Descubrí experiencias, proyectos y organizaciones que impulsan el
        patrimonio y el turismo regenerativo en México.
      </p>
    </div>

    <!-- Explore Cards -->
    {
      explorarCards.map((card) => {
        const styles = tagStyles[card.tagColor] ?? tagStyles.brand;
        return (
          <a
            href={card.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col gap-4 rounded-2xl border border-slate-200/60 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md dark:border-slate-800/60 dark:bg-slate-900"
          >
            <!-- Icon + Tag row -->
            <div class="flex items-start justify-between">
              <div class={`rounded-2xl p-3 ${styles.icon}`} set:html={card.icon} />
              <span
                class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold ${styles.badge}`}
              >
                {card.tag}
              </span>
            </div>

            <!-- Content -->
            <div class="space-y-1.5">
              <h2 class="text-lg font-bold text-slate-800 group-hover:text-brand-600 dark:text-slate-100 dark:group-hover:text-brand-400 transition-colors duration-200">
                {card.title}
              </h2>
              <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">
                {card.description}
              </p>
            </div>

            <!-- CTA -->
            <div class="flex items-center gap-1.5 text-sm font-semibold text-brand-600 dark:text-brand-400">
              {card.cta}
              <svg
                class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                />
              </svg>
            </div>
          </a>
        );
      })
    }
    <!-- Coming Soon Card -->
    <div
      class="flex flex-col items-center space-y-4 rounded-2xl border border-slate-200/60 bg-white p-8 text-center shadow-sm dark:border-slate-800/60 dark:bg-slate-900"
    >
      <div
        class="rounded-2xl bg-brand-50 p-4 text-brand-500 dark:bg-brand-950/30 dark:text-brand-400"
      >
        <svg
          class="h-10 w-10"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
          />
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-slate-800 dark:text-slate-200">
          Más experiencias próximamente
        </h2>
        <p class="mt-2 max-w-sm text-sm text-slate-500 dark:text-slate-400">
          Seguimos sumando proyectos, rutas y organizaciones que transforman el
          turismo y el patrimonio cultural de México.
        </p>
      </div>
      <span
        class="inline-flex items-center gap-1.5 rounded-full border border-brand-200/50 bg-brand-50 px-3.5 py-1.5 text-xs font-semibold text-brand-600 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-400"
      >
        <span
          class="h-2 w-2 animate-ping rounded-full bg-brand-500 dark:bg-brand-400"
        ></span>
        En construcción
      </span>
    </div>
  </div>
</Layout>