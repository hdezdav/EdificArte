---
import Layout from '../layouts/Layout.astro';
import { MONUMENTS } from '../data/monuments';
import tianquiztlisProducts from '../data/tianquiztlis_products.json';
import { TOURS } from '../data/tours';
import type { Tour } from '../data/tours';

type Category = 'todos' | 'turismo' | 'patrimonio' | 'cultura' | 'gastronomia' | 'museo' | 'tienda' | 'sitio-remoto' | 'eventos';

interface Experience {
  id: string;
  title: string;
  description: string;
  image: string;
  category: Exclude<Category, 'todos'>;
  tagColor: 'emerald' | 'brand' | 'amber' | 'rose' | 'indigo' | 'purple' | 'blue';
  url: string;
  cta: string;
  rating?: number;
  reviewCount?: number;
  price?: string;
  images?: string[];
  sku?: string;
  videoUrl?: string;
  isVRAvailable?: boolean;
  meetingPoint?: string;
  customBadge?: string;
  currency?: string;
  duration?: string;
  highlights?: string[];
  isTour?: boolean;
  lat?: number;
  lng?: number;
  translations?: {
    es: { name: string; desc: string; category: string; cta: string; guide: string };
    en: { name: string; desc: string; category: string; cta: string; guide: string };
    señas: { name: string; desc: string; category: string; cta: string; guide: string; videoUrl: string };
    native?: { name: string; desc: string; category: string; cta: string; guide: string };
  };
}

const experiencias: Experience[] = [
  {
    id: 'turismo-regenerativo',
    title: 'Turismo Regenerativo México',
    description:
      'Experiencias inmersivas con comunidades locales que impulsan el cambio social y la regeneración cultural.',
    image:
      'https://www.turismoregenerativomexico.com/wp-content/uploads/2025/08/Copia-de-DSCN4585-768x576.jpg',
    category: 'turismo',
    tagColor: 'emerald',
    url: 'https://turismoregenerativomexico.com',
    cta: 'Conoce más',
    rating: 4.95,
    reviewCount: 124,
    price: '$250 MXN',
  },
  {
    id: 'fundacion-edificate',
    title: 'Fundación Edificate',
    description:
      'Preservamos el patrimonio arquitectónico y cultural de México a través de la educación y la tecnología.',
    image:
      'https://www.fundacionedificate.org/wp-content/uploads/2025/01/Edificate.jpg',
    category: 'turismo',
    tagColor: 'brand',
    url: 'https://www.fundacionedificate.org/',
    cta: 'Visitar sitio',
    rating: 4.9,
    reviewCount: 98,
    customBadge: 'Voluntariado',
    price: 'Gratis',
  },
  {
    id: 'casa-lamm',
    title: 'Casa Lamm - Cultura & Academia',
    description:
      'Centro cultural en una casona porfiriana de la CDMX: exposiciones, librería, taller de arte y academia de historia del arte.',
    image:
      'https://stanzahotel.com/wp-content/uploads/2024/07/casa_lamm_1.jpg',
    category: 'cultura',
    tagColor: 'amber',
    url: 'https://casalamm.com.mx/',
    cta: 'Ver agenda',
    rating: 4.88,
    reviewCount: 156,
    price: 'Varios',
  },
  {
    id: 'mercado-san-juan',
    title: 'Mercado de San Juan',
    description:
      'Gastronomía local en su máxima expresión: quesos artesanales, carnes exóticas, dulces tradicionales y chef en residencia.',
    image:
      'https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'gastronomia',
    tagColor: 'rose',
    url: 'https://www.mercadodesanjuan.com.mx/',
    cta: 'Visitar mercado',
    rating: 4.92,
    reviewCount: 342,
    price: 'Gratis',
  },

  {
    id: 'museo-anahuacalli',
    title: 'Museo Anahuacalli',
    description:
      'Pirámide de basalto diseñada por Diego Rivera para albergar su colección de arte prehispánico, rodeada de reserva ecológica.',
    image:
      'https://cdn0.bodas.com.mx/vendor/0011/3_2/960/jpeg/vista-aerea-de-costado-dron_5_320011-162250734231083.jpeg',
    category: 'patrimonio',
    tagColor: 'brand',
    url: 'https://www.museoanahuacalli.org.mx/',
    cta: 'Conoce más',
    rating: 4.96,
    reviewCount: 210,
    price: '$80 MXN',
  },
];

// Generar experiencias a partir de los museos de Monuments
const museosExperiencias: Experience[] = MONUMENTS.filter((m) => m.type === 'museo').map((m) => {
  const ratings: Record<string, { rating: number; reviewCount: number; price: string }> = {
    'bellas-artes': { rating: 4.97, reviewCount: 382, price: '$85 MXN' },
    'palacio-nacional': { rating: 4.89, reviewCount: 145, price: 'Gratis' },
    'revolucion': { rating: 4.92, reviewCount: 204, price: '$120 MXN' },
    'angel': { rating: 4.96, reviewCount: 412, price: 'Gratis' },
    'chapultepec': { rating: 4.98, reviewCount: 520, price: '$90 MXN' },
    'memorial-68': { rating: 4.88, reviewCount: 95, price: '$30 MXN' },
    'el-rule': { rating: 4.85, reviewCount: 78, price: 'Gratis' },
  };

  const translations = {
    es: {
      name: m.name,
      desc: m.desc,
      category: m.id === 'el-rule' ? 'Exposición / Evento' : m.category,
      cta: m.id === 'el-rule' ? 'Ver Evento' : 'Ver guía',
      guide: m.id === 'el-rule'
        ? '¡Bienvenido al Centro Cultural El Rule! Te invitamos a la exposición multilingüe y multisensorial "Nombrar el Orgullo Neo". Esta exhibición, presentada por Metalingua en alianza con Edificarte y Unesco, celebra la identidad y la diversidad cultural a través del arte contemporáneo, el diálogo social y la inclusión.'
        : `¡Bienvenido al ${m.name}! Este emblemático espacio es parte fundamental del patrimonio histórico de la Ciudad de México. Aquí podrás contemplar una arquitectura imponente y aprender sobre su evolución artística, social e histórica a través del tiempo. Disfrutá del recorrido detallado por sus salas principales y descubrí los secretos que sus paredes guardan.`,
    },
    en: {
      name: m.id === 'el-rule' ? 'El Rule Cultural Center' : (m.name === 'Palacio de Bellas Artes' ? 'Palace of Fine Arts' : (m.name === 'Palacio Nacional' ? 'National Palace' : (m.name === 'Castillo de Chapultepec' ? 'Chapultepec Castle' : (m.name === 'Ángel de la Independencia' ? 'Angel of Independence' : (m.name === 'Museo Memorial del 68' ? '68 Memorial Museum' : (m.name === 'Hotel Virreyes' ? 'Hotel Virreyes' : 'Monument to the Revolution')))))),
      desc: m.id === 'el-rule' ? 'Multidisciplinary cultural space in the historic center of Mexico City.' : (m.name === 'Palacio de Bellas Artes' ? 'One of the world\'s most famous opera houses, known for its Art Nouveau exterior and Art Deco interior.' : m.desc),
      category: m.id === 'el-rule' ? 'Exhibition / Event' : (m.category === 'Museo / Teatro' ? 'Museum / Theater' : (m.category === 'Museo / Castillo' ? 'Museum / Castle' : (m.category === 'Museo Histórico' ? 'Historical Museum' : 'Historical Monument'))),
      cta: m.id === 'el-rule' ? 'View Event' : 'View guide',
      guide: m.id === 'el-rule'
        ? 'Welcome to El Rule Cultural Center! We invite you to the multilingual and multisensorial exhibition "Nombrar el Orgullo Neo". This exhibition, presented by Metalingua in partnership with Edificarte and Unesco, celebrates identity and cultural diversity through contemporary art, social dialogue, and inclusion.'
        : `Welcome to the ${m.name}! This emblematic site is a key piece of Mexico City's historical heritage. Here, you can contemplate stunning architecture and learn about its artistic, social, and historical evolution through time. Enjoy the detailed self-guided tour through its main halls and uncover the secrets written in its walls.`,
    },
    señas: {
      name: `${m.name} (LSM)`,
      desc: 'Guía adaptada en Lengua de Señas Mexicana (LSM) con subtítulos y videos de alta visibilidad.',
      category: 'Accesibilidad / LSM',
      cta: 'Ver LSM',
      guide: `Esta es la guía accesible en Lengua de Señas Mexicana (LSM) para el ${m.name}. Explicamos la historia, el contexto y los murales o detalles artísticos más representativos para garantizar el acceso pleno a la cultura para la comunidad con discapacidad auditiva.`,
      videoUrl: 'https://www.youtube.com/embed/82pGUhn0CsY?si=H7ZvUDJAPU3THjjU',
    },
    ...(m.id === 'el-rule' ? {
      native: {
        name: 'El Rule (Lenguas Originarias)',
        desc: 'Traducción multilingüe y multisensorial de la exposición "Nombrar el Orgullo Neo" en lenguas originarias.',
        category: 'Multilingüe',
        cta: 'Ver Trad.',
        guide: 'Esta guía y exposición cuenta con traducción a lenguas originarias mexicanas.\n\nPodés acceder a la página traducida a las lenguas originarias visitando el portal oficial de MetaLingua: https://www.metalinguamx.org/\n\nLeé la nota de prensa de la exposición "Nombrar el Orgullo Neo" en SinEmbargo: https://www.sinembargo.mx/4810195/nombrar-el-orgullo-neo-exposicion-multilingue-y-multisensorial-de-la-unesco/',
      }
    } : {})
  };

  const rData = ratings[m.id] || { rating: 4.8, reviewCount: 15, price: 'Gratis' };

  return {
    id: m.id,
    title: m.name,
    description: m.desc,
    image: m.image,
    lat: m.lat,
    lng: m.lng,
    category: m.id === 'el-rule' ? 'eventos' : 'museo',
    tagColor: m.id === 'el-rule' ? 'blue' : 'indigo',
    url: '#',
    cta: m.id === 'el-rule' ? 'Ver Evento' : 'Ver guía',
    rating: rData.rating,
    reviewCount: rData.reviewCount,
    price: rData.price,
    translations,
  };
});

// Generar experiencias a partir de los productos de Tianquiztlis Mercado (filtrando duplicados por nombre)
const uniqueTianquiztlisProducts = tianquiztlisProducts.filter(
  (p, index, self) => self.findIndex((t) => t.name === p.name) === index
);

const tiendaExperiencias: Experience[] = uniqueTianquiztlisProducts.map((p, index) => {
  return {
    id: `prod-${p.sku || index}`,
    title: p.name,
    description: p.description,
    image: p.images[0] || 'https://images.unsplash.com/photo-1513519245088-0e12902e5a38?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'tienda',
    tagColor: 'purple',
    url: '#',
    cta: 'Ver Detalles',
    rating: parseFloat((4.75 + (index % 5) * 0.05).toFixed(2)),
    reviewCount: 14 + (index * 7) % 43,
    price: p.price ? `$${p.price} ${p.currency}` : 'Consultar',
    images: p.images,
    sku: p.sku
  };
});

// Generar experiencias para monumentos remotos (sitio-remoto), por ejemplo Pirámides del Sol.
// Estos monumentos NO aparecen en el mapa (filtrados en mapa-app.ts) pero sí en Explorar.
const sitioRemotoExperiencias: Experience[] = MONUMENTS.filter((m) => m.type === 'sitio-remoto').map((m) => {
  const translations = {
    es: {
      name: m.name,
      desc: m.desc,
      category: m.category,
      cta: 'Ver experiencia',
      guide: `¡Bienvenido a ${m.name}! Esta experiencia remota forma parte del patrimonio cultural de México. A través de esta guía podés conocer la historia, el contexto y los detalles más importantes del sitio, complementado con una experiencia inmersiva en realidad virtual (VR) que te permite recorrerlo sin salir de tu casa.`,
    },
    en: {
      name: m.name,
      desc: m.desc,
      category: m.category,
      cta: 'View experience',
      guide: `Welcome to ${m.name}! This remote experience is part of Mexico's cultural heritage. Through this guide you can learn the history, context, and most important details of the site, complemented by an immersive virtual reality (VR) experience that lets you tour it from anywhere.`,
    },
    señas: {
      name: `${m.name} (LSM)`,
      desc: 'Guía accesible en Lengua de Señas Mexicana (LSM) con subtítulos y descripción visual del sitio.',
      category: 'Accesibilidad / LSM',
      cta: 'Ver LSM',
      guide: `Esta es la guía accesible en Lengua de Señas Mexicana (LSM) para ${m.name}. Explicamos la historia, el contexto arqueológico y los detalles más representativos del sitio para garantizar el acceso pleno a la cultura para la comunidad con discapacidad auditiva.`,
      videoUrl: 'https://www.youtube.com/embed/WEvDk9y1e_E?si=m8XYBMkzBom_wtPl',
    },
  };

  return {
    id: m.id,
    title: m.name,
    description: m.desc,
    image: m.image,
    lat: m.lat,
    lng: m.lng,
    category: 'sitio-remoto',
    tagColor: 'purple',
    url: '#',
    cta: 'Ver experiencia VR',
    rating: 4.95,
    reviewCount: 287,
    price: 'Gratis',
    translations,
    videoUrl: m.videoUrl,
    isVRAvailable: m.isVRAvailable,
  };
});

const todasLasExperiencias: Experience[] = [...experiencias, ...museosExperiencias, ...sitioRemotoExperiencias, ...tiendaExperiencias];

const tagStyles: Record<
  Experience['tagColor'],
  { badge: string; pill: string }
> = {
  emerald: {
    badge:
      'border-emerald-200/50 bg-emerald-50 text-emerald-700 dark:border-emerald-800/50 dark:bg-emerald-950/40 dark:text-emerald-400',
    pill: 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-400',
  },
  brand: {
    badge:
      'border-brand-200/50 bg-brand-50 text-brand-700 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-400',
    pill: 'border-brand-200 bg-brand-50 text-brand-700 dark:border-brand-800 dark:bg-brand-950/30 dark:text-brand-400',
  },
  amber: {
    badge:
      'border-amber-200/50 bg-amber-50 text-amber-700 dark:border-amber-800/50 dark:bg-amber-950/40 dark:text-amber-400',
    pill: 'border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-800 dark:bg-amber-950/30 dark:text-amber-400',
  },
  rose: {
    badge:
      'border-rose-200/50 bg-rose-50 text-rose-700 dark:border-rose-800/50 dark:bg-rose-950/40 dark:text-rose-400',
    pill: 'border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-800 dark:bg-rose-950/30 dark:text-rose-400',
  },
  indigo: {
    badge:
      'border-indigo-200/50 bg-indigo-50 text-indigo-700 dark:border-indigo-800/50 dark:bg-indigo-950/40 dark:text-indigo-400',
    pill: 'border-indigo-200 bg-indigo-50 text-indigo-700 dark:border-indigo-800 dark:bg-indigo-950/30 dark:text-indigo-400',
  },
  purple: {
    badge:
      'border-purple-200/50 bg-purple-50 text-purple-700 dark:border-purple-800/50 dark:bg-purple-950/40 dark:text-purple-400',
    pill: 'border-purple-200 bg-purple-50 text-purple-700 dark:border-purple-800 dark:bg-purple-950/30 dark:text-purple-400',
  },
  blue: {
    badge:
      'border-blue-200/50 bg-blue-50 text-blue-700 dark:border-blue-800/50 dark:bg-blue-950/40 dark:text-blue-400',
    pill: 'border-blue-200 bg-blue-50 text-blue-700 dark:border-blue-800 dark:bg-blue-950/30 dark:text-blue-400',
  },
};

// Orden visual de los chips (izquierda → derecha) y de las secciones
// en el feed. La sección 'sitio-remoto' absorbe también las experiencias
// con category 'patrimonio' y 'cultura' (ver categorias.map); ambas se
// mantienen como filtros de chip pero no renderizan secciones propias
// para evitar duplicados.
const categoryLabel: Record<Category, string> = {
  todos: 'Todos',
  turismo: 'Turismo',
  'sitio-remoto': 'Sitios Turísticos',
  patrimonio: 'Patrimonio',
  cultura: 'Cultura',
  museo: 'Museos',
  gastronomia: 'Gastronomía',
  tienda: 'Artesanías',
  eventos: 'Eventos / Exposiciones',
};

const categories: Exclude<Category, 'todos'>[] = [
  'turismo',
  'sitio-remoto',
  'museo',
];
// gastronomia & eventos: misma fila (grid 2 col)
const pairedCategories: [Exclude<Category,'todos'>, Exclude<Category,'todos'>] = ['gastronomia', 'eventos'];
// tienda va al final sola
const lastCategories: Exclude<Category,'todos'>[] = ['tienda'];

// Helper: convierte un Tour en Experience para mezclarlo en el carousel de Turismo
function toExperience(tour: Tour): Experience {
  return {
    id: tour.id,
    title: tour.title,
    description: tour.description,
    image: tour.image,
    category: 'turismo',
    tagColor: 'brand',
    url: '#',
    cta: 'Reservar',
    rating: 4.98,
    reviewCount: 67,
    price: `$${tour.pricePerPerson} MXN`,
    highlights: tour.highlights,
    meetingPoint: tour.meetingPoint,
    currency: tour.currency,
    duration: tour.duration,
    isTour: true,
  };
}

const paymentAddress = (Astro.locals.runtime.env as Record<string, unknown>).EDIFICARTE_PAYMENT_ADDRESS as string | undefined;
---

<Layout title="EdificARTE - Explorar">
  <script is:inline define:vars={{ paymentAddress }}>
    window.__EDIFICARTE_PAYMENT_ADDRESS__ = paymentAddress || '';
  </script>
  <script is:inline define:vars={{ experiencesMap: Object.fromEntries(todasLasExperiencias.map(e => [e.id, { title: e.title, image: e.image, category: e.category }])) }}>
    window.__EDIFICARTE_EXPERIENCES__ = experiencesMap;
  </script>
  <script is:inline define:vars={{ monumentsList: MONUMENTS.map(m => ({ id: m.id, name: m.name, lat: m.lat, lng: m.lng, image: m.image })) }}>
    // For proximity notifications in Layout.astro
    window.__EDIFICARTE_MONUMENTS__ = monumentsList;
  </script>
  <script is:inline>
    // Primera carga del navegador: si nunca se mostró la bienvenida, la
    // mostramos ahora. Una vez aceptada, redirigimos a /mapa en próximas
    // cargas nuevas del sitio.
    (function () {
      try {
        if (!sessionStorage.getItem('edificarte_session_active')) {
          sessionStorage.setItem('edificarte_session_active', 'true');
          if (localStorage.getItem('edificarte_welcome_shown') === 'true') {
            window.location.href = '/mapa';
          }
        }
      } catch (_) {
        // localStorage/sessionStorage no disponible: continuar sin bienvenida.
      }
    })();
  </script>

  <!-- Modal de Bienvenida: pide nombre y crea cuenta local (no DB).
       Aparece una sola vez por navegador. El nombre queda en localStorage y
       se copia a la cookie edificarte_guest para que /yo lo detecte como
       invitado con nombre. Cuando el usuario se registre formalmente en /yo
       conservará ese nombre automáticamente. -->
  <div
    id="welcome-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4 backdrop-blur-md"
    role="dialog"
    aria-modal="true"
    aria-labelledby="welcome-modal-title"
  >
    <div class="w-full max-w-md scale-95 transform rounded-[2rem] border border-white/20 bg-white/95 p-7 shadow-2xl backdrop-blur-2xl transition-all duration-300 dark:border-slate-800/60 dark:bg-slate-900/95">
      <div class="text-center mb-5">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-tr from-brand-500 to-purple-600 text-white shadow-lg mb-4">
          <span class="material-symbols-outlined text-[30px]">account_balance</span>
        </div>
        <h2 id="welcome-modal-title" class="text-2xl font-bold tracking-tight text-slate-800 dark:text-white">¡Bienvenido a EdificARTE!</h2>
        <p class="mt-1.5 text-sm text-slate-500 dark:text-slate-400">Decinos tu nombre para empezar a explorar el patrimonio de la CDMX.</p>
      </div>

      <form id="welcome-form" class="space-y-4" novalidate>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[18px] text-slate-400">person</span>
          <input
            type="text"
            id="welcome-name-input"
            name="name"
            required
            autocomplete="given-name"
            placeholder="Tu nombre"
            class="w-full rounded-2xl border border-slate-200/60 bg-white/60 py-3 pl-12 pr-4 text-sm outline-none focus:border-brand-500 focus:bg-white dark:border-slate-800 dark:bg-slate-950/40 dark:focus:bg-slate-950 transition-all"
          />
        </div>

        <div id="welcome-error" class="hidden items-center gap-2 rounded-xl bg-rose-50 border border-rose-100 p-3 text-xs font-semibold text-rose-700 dark:bg-rose-950/20 dark:border-rose-900/30 dark:text-rose-400">
          <span class="material-symbols-outlined text-[16px]">error</span>
          <span id="welcome-error-text">Necesitamos tu nombre para continuar.</span>
        </div>

        <button
          type="submit"
          class="w-full rounded-2xl bg-gradient-to-r from-brand-500 to-purple-600 py-3.5 text-sm font-semibold text-white shadow-lg hover:from-brand-600 hover:to-purple-700 transition-all active:scale-[0.98]"
        >
          Comenzar a explorar
        </button>

        <p class="text-center text-[11px] text-slate-400 dark:text-slate-500">
          Tu progreso se guarda en este dispositivo. Podés crear una cuenta formal más tarde desde <span class="font-semibold text-brand-600 dark:text-brand-400">Yo</span> para conservarlo en la nube.
        </p>
      </form>
    </div>
  </div>

  <script>
    const lang = localStorage.getItem('edificarte_lang');
    const banner = document.getElementById('lang-soft-cta');
    if (!lang && banner) {
      banner.classList.remove('hidden');
      document
        .getElementById('lang-soft-cta-link')
        ?.addEventListener('click', () => {
          window.location.href = '/mapa';
        });
    }

    // ─── Modal de Bienvenida ──────────────────────────────────────────────
    // Solo aparece si edificarte_welcome_shown no está marcado en localStorage.
    // Al enviar el nombre: persiste en localStorage (edificarte_guest_name)
    // y setea cookie edificarte_guest=true para que /yo lo detecte.
    (function setupWelcome() {
      try {
        if (localStorage.getItem('edificarte_welcome_shown') === 'true') return;
      } catch (_) {
        return; // localStorage no disponible → no insistir
      }

      const modal = document.getElementById('welcome-modal');
      const form = document.getElementById('welcome-form') as HTMLFormElement | null;
      const input = document.getElementById('welcome-name-input') as HTMLInputElement | null;
      const errorBox = document.getElementById('welcome-error');
      const errorText = document.getElementById('welcome-error-text');

      if (!modal || !form || !input) return;

      // Mostrar modal (flex hidden → flex)
      modal.classList.remove('hidden');
      modal.classList.add('flex');

      // Forzar reflow para activar la animación scale-100
      void modal.offsetHeight;
      const inner = modal.querySelector('div');
      if (inner) {
        inner.classList.remove('scale-95');
        inner.classList.add('scale-100');
      }

      // Bloquear scroll del body mientras el modal está abierto
      document.body.classList.add('modal-open');

      // Bloquear cierre por click fuera o Escape: el nombre es obligatorio
      // para empezar (no queremos un "invitado sin nombre" que después no
      // sepamos cómo etiquetar).
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          showError('Necesitamos tu nombre para continuar.');
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          showError('Necesitamos tu nombre para continuar.');
        }
      });

      function showError(msg: string) {
        if (!errorBox || !errorText) return;
        errorText.textContent = msg;
        errorBox.classList.remove('hidden');
        errorBox.classList.add('flex');
        input?.focus();
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = input.value.trim();

        if (!name) {
          showError('Necesitamos tu nombre para continuar.');
          return;
        }

        if (name.length < 2) {
          showError('Tu nombre debe tener al menos 2 caracteres.');
          return;
        }

        try {
          // Persistir nombre del invitado local (sobra como redundancia; la
          // fuente de verdad son las cookies que setea el endpoint).
          localStorage.setItem('edificarte_guest_name', name);
          localStorage.setItem('edificarte_welcome_shown', 'true');
          localStorage.removeItem('edificarte_guest_avatar');
        } catch (_) {
          showError('No pudimos guardar tu nombre. Recargá la página e intentá de nuevo.');
          return;
        }

        // Setear cookies server-side vía endpoint. Si falla, mostrar error
        // (sin las cookies el registro en /yo no va a pre-rellenar el nombre).
        try {
          const res = await fetch('/api/welcome', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name }),
          });
          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            showError(data.error || 'No pudimos registrar tu nombre en el servidor.');
            return;
          }
        } catch (_) {
          showError('Error de conexión. Verificá tu internet e intentá de nuevo.');
          return;
        }

        // Cerrar modal y avanzar al mapa
        modal.classList.add('opacity-0');
        setTimeout(() => {
          modal.classList.add('hidden');
          document.body.classList.remove('modal-open');
          window.location.href = '/mapa?welcome=1';
        }, 250);
      });
    })();
  </script>

  <!-- Banner suave si no hay idioma elegido -->
  <div
    id="lang-soft-cta"
    class="mb-4 [&:not(.hidden)]:flex hidden items-center justify-between gap-3 rounded-2xl border border-brand-200/50 bg-brand-50 px-4 py-3 text-sm text-brand-800 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-200"
  >
    <span class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[18px]">translate</span>
      Elegí tu idioma para empezar
    </span>
    <button
      id="lang-soft-cta-link"
      class="rounded-full bg-brand-500 px-3 py-1 text-xs font-semibold text-white hover:bg-brand-600"
      type="button"
    >
      Ir al mapa
    </button>
  </div>

  <div class="space-y-6">
    <!-- Header -->
    <div
      class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 p-6 text-white shadow-xl"
    >
      <div
        class="pointer-events-none absolute -bottom-10 -right-10 h-40 w-40 rounded-full bg-white/5 blur-xl"
