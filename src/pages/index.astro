---
import Layout from '../layouts/Layout.astro';
import AiLoader from '../components/ui/AiLoader.astro';
import { MONUMENTS } from '../data/monuments';

type Category = 'todos' | 'turismo' | 'patrimonio' | 'cultura' | 'gastronomia' | 'museo';

interface Experience {
  id: string;
  title: string;
  description: string;
  image: string;
  category: Exclude<Category, 'todos'>;
  tagColor: 'emerald' | 'brand' | 'amber' | 'rose' | 'indigo';
  url: string;
  cta: string;
  rating?: number;
  reviewCount?: number;
  price?: string;
  translations?: {
    es: { name: string; desc: string; category: string; cta: string; guide: string };
    en: { name: string; desc: string; category: string; cta: string; guide: string };
    señas: { name: string; desc: string; category: string; cta: string; guide: string; videoUrl: string };
  };
}

const experiencias: Experience[] = [
  {
    id: 'turismo-regenerativo',
    title: 'Turismo Regenerativo México',
    description:
      'Experiencias inmersivas con comunidades locales que impulsan el cambio social y la regeneración cultural.',
    image:
      'https://www.turismoregenerativomexico.com/wp-content/uploads/2025/08/Copia-de-DSCN4585-768x576.jpg',
    category: 'turismo',
    tagColor: 'emerald',
    url: 'https://turismoregenerativomexico.com',
    cta: 'Conoce más',
    rating: 4.95,
    reviewCount: 124,
    price: '$250 MXN',
  },
  {
    id: 'fundacion-edificate',
    title: 'Fundación Edificate',
    description:
      'Preservamos el patrimonio arquitectónico y cultural de México a través de la educación y la tecnología.',
    image:
      'https://www.fundacionedificate.org/wp-content/uploads/2025/01/Edificate.jpg',
    category: 'patrimonio',
    tagColor: 'brand',
    url: 'https://www.fundacionedificate.org/',
    cta: 'Visitar sitio',
    rating: 4.9,
    reviewCount: 98,
    price: 'Gratis',
  },
  {
    id: 'casa-lamm',
    title: 'Casa Lamm - Cultura & Academia',
    description:
      'Centro cultural en una casona porfiriana de la CDMX: exposiciones, librería, taller de arte y academia de historia del arte.',
    image:
      'https://stanzahotel.com/wp-content/uploads/2024/07/casa_lamm_1.jpg',
    category: 'cultura',
    tagColor: 'amber',
    url: 'https://casalamm.com.mx/',
    cta: 'Ver agenda',
    rating: 4.88,
    reviewCount: 156,
    price: 'Varios',
  },
  {
    id: 'mercado-san-juan',
    title: 'Mercado de San Juan',
    description:
      'Gastronomía local en su máxima expresión: quesos artesanales, carnes exóticas, dulces tradicionales y chef en residencia.',
    image:
      'https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'gastronomia',
    tagColor: 'rose',
    url: 'https://www.mercadodesanjuan.com.mx/',
    cta: 'Visitar mercado',
    rating: 4.92,
    reviewCount: 342,
    price: 'Gratis',
  },
  {
    id: 'cdmx-walks',
    title: 'CDMX Heritage Walks',
    description:
      'Recorridos guiados a pie por el Centro Histórico: arquitectura virreinal, murales contemporáneos y leyendas populares.',
    image:
      'https://images.unsplash.com/photo-1518105779142-d975f22f1b0a?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'turismo',
    tagColor: 'emerald',
    url: 'https://cdmxheritage.com/',
    cta: 'Reservar tour',
    rating: 4.97,
    reviewCount: 88,
    price: '$180 MXN',
  },
  {
    id: 'museo-anahuacalli',
    title: 'Museo Anahuacalli',
    description:
      'Pirámide de basalto diseñada por Diego Rivera para albergar su colección de arte prehispánico, rodeada de reserva ecológica.',
    image:
      'https://cdn0.bodas.com.mx/vendor/0011/3_2/960/jpeg/vista-aerea-de-costado-dron_5_320011-162250734231083.jpeg',
    category: 'patrimonio',
    tagColor: 'brand',
    url: 'https://www.museoanahuacalli.org.mx/',
    cta: 'Conoce más',
    rating: 4.96,
    reviewCount: 210,
    price: '$80 MXN',
  },
];

// Generar experiencias a partir de los museos de Monuments
const museosExperiencias: Experience[] = MONUMENTS.filter((m) => m.type === 'museo').map((m) => {
  const ratings: Record<string, { rating: number; reviewCount: number; price: string }> = {
    'bellas-artes': { rating: 4.97, reviewCount: 382, price: '$85 MXN' },
    'palacio-nacional': { rating: 4.89, reviewCount: 145, price: 'Gratis' },
    'revolucion': { rating: 4.92, reviewCount: 204, price: '$120 MXN' },
    'angel': { rating: 4.96, reviewCount: 412, price: 'Gratis' },
    'chapultepec': { rating: 4.98, reviewCount: 520, price: '$90 MXN' },
  };

  const translations = {
    es: {
      name: m.name,
      desc: m.desc,
      category: m.category,
      cta: 'Ver guía',
      guide: `¡Bienvenido al ${m.name}! Este emblemático espacio es parte fundamental del patrimonio histórico de la Ciudad de México. Aquí podrás contemplar una arquitectura imponente y aprender sobre su evolución artística, social e histórica a través del tiempo. Disfrutá del recorrido detallado por sus salas principales y descubrí los secretos que sus paredes guardan.`,
    },
    en: {
      name: m.name === 'Palacio de Bellas Artes' ? 'Palace of Fine Arts' : (m.name === 'Palacio Nacional' ? 'National Palace' : (m.name === 'Castillo de Chapultepec' ? 'Chapultepec Castle' : (m.name === 'Ángel de la Independencia' ? 'Angel of Independence' : 'Monument to the Revolution'))),
      desc: m.name === 'Palacio de Bellas Artes' ? 'One of the world\'s most famous opera houses, known for its Art Nouveau exterior and Art Deco interior.' : m.desc,
      category: m.category === 'Museo / Teatro' ? 'Museum / Theater' : (m.category === 'Museo / Castillo' ? 'Museum / Castle' : 'Historical Monument'),
      cta: 'View guide',
      guide: `Welcome to the ${m.name}! This emblematic site is a key piece of Mexico City's historical heritage. Here, you can contemplate stunning architecture and learn about its artistic, social, and historical evolution through time. Enjoy the detailed self-guided tour through its main halls and uncover the secrets written in its walls.`,
    },
    señas: {
      name: `${m.name} (LSM)`,
      desc: 'Guía adaptada en Lengua de Señas Mexicana (LSM) con subtítulos y videos de alta visibilidad.',
      category: 'Accesibilidad / LSM',
      cta: 'Ver LSM',
      guide: `Esta es la guía accesible en Lengua de Señas Mexicana (LSM) para el ${m.name}. Explicamos la historia, el contexto y los murales o detalles artísticos más representativos para garantizar el acceso pleno a la cultura para la comunidad con discapacidad auditiva.`,
      videoUrl: 'https://www.youtube.com/embed/dQw4w9WgXcQ', // Video educativo genérico como demo
    },
  };

  const rData = ratings[m.id] || { rating: 4.8, reviewCount: 15, price: 'Gratis' };

  return {
    id: m.id,
    title: m.name,
    description: m.desc,
    image: m.image,
    category: 'museo',
    tagColor: 'indigo',
    url: '#',
    cta: 'Ver guía',
    rating: rData.rating,
    reviewCount: rData.reviewCount,
    price: rData.price,
    translations,
  };
});

const todasLasExperiencias: Experience[] = [...experiencias, ...museosExperiencias];

const tagStyles: Record<
  Experience['tagColor'],
  { badge: string; pill: string }
> = {
  emerald: {
    badge:
      'border-emerald-200/50 bg-emerald-50 text-emerald-700 dark:border-emerald-800/50 dark:bg-emerald-950/40 dark:text-emerald-400',
    pill: 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-400',
  },
  brand: {
    badge:
      'border-brand-200/50 bg-brand-50 text-brand-700 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-400',
    pill: 'border-brand-200 bg-brand-50 text-brand-700 dark:border-brand-800 dark:bg-brand-950/30 dark:text-brand-400',
  },
  amber: {
    badge:
      'border-amber-200/50 bg-amber-50 text-amber-700 dark:border-amber-800/50 dark:bg-amber-950/40 dark:text-amber-400',
    pill: 'border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-800 dark:bg-amber-950/30 dark:text-amber-400',
  },
  rose: {
    badge:
      'border-rose-200/50 bg-rose-50 text-rose-700 dark:border-rose-800/50 dark:bg-rose-950/40 dark:text-rose-400',
    pill: 'border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-800 dark:bg-rose-950/30 dark:text-rose-400',
  },
  indigo: {
    badge:
      'border-indigo-200/50 bg-indigo-50 text-indigo-700 dark:border-indigo-800/50 dark:bg-indigo-950/40 dark:text-indigo-400',
    pill: 'border-indigo-200 bg-indigo-50 text-indigo-700 dark:border-indigo-800 dark:bg-indigo-950/30 dark:text-indigo-400',
  },
};

const categoryLabel: Record<Category, string> = {
  todos: 'Todos',
  turismo: 'Turismo',
  patrimonio: 'Patrimonio',
  cultura: 'Cultura',
  gastronomia: 'Gastronomía',
  museo: 'Museos',
};

const categories: Exclude<Category, 'todos'>[] = ['turismo', 'patrimonio', 'cultura', 'gastronomia', 'museo'];
---

<Layout title="EdificARTE — Explorar">
  <script is:inline>
    // Distinguir entre la primera carga del sitio (inicio de sesión) y navegación interna
    if (!sessionStorage.getItem('edificarte_session_active')) {
      sessionStorage.setItem('edificarte_session_active', 'true');
      if (localStorage.getItem('edificarte_welcome_shown') === 'true') {
        window.location.href = '/mapa';
      }
    }
  </script>

  <script>
    const lang = localStorage.getItem('edificarte_lang');
    const banner = document.getElementById('lang-soft-cta');
    if (!lang && banner) {
      banner.classList.remove('hidden');
      document
        .getElementById('lang-soft-cta-link')
        ?.addEventListener('click', () => {
          window.location.href = '/mapa';
        });
    }
  </script>

  <!-- Banner suave si no hay idioma elegido -->
  <div
    id="lang-soft-cta"
    class="mb-4 flex hidden items-center justify-between gap-3 rounded-2xl border border-brand-200/50 bg-brand-50 px-4 py-3 text-sm text-brand-800 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-200"
  >
    <span class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[18px]">translate</span>
      Elegí tu idioma para empezar
    </span>
    <button
      id="lang-soft-cta-link"
      class="rounded-full bg-brand-500 px-3 py-1 text-xs font-semibold text-white hover:bg-brand-600"
      type="button"
    >
      Ir al mapa
    </button>
  </div>

  <div class="space-y-6">
    <!-- Header -->
    <div
      class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 p-6 text-white shadow-xl"
    >
      <div
        class="pointer-events-none absolute -bottom-10 -right-10 h-40 w-40 rounded-full bg-white/5 blur-xl"
      >
      </div>
      <h1 class="text-3xl font-extrabold tracking-tight">Explorar</h1>

      <!-- Search Input Container -->
      <div class="mt-4 relative w-full max-w-md">
        <div class="flex items-center rounded-full border border-white/20 bg-white/10 px-4 py-2.5 backdrop-blur-md transition-all focus-within:bg-white/15 focus-within:border-white/30">
          <span class="material-symbols-outlined mr-2 text-[20px] text-white/70">search</span>
          <input
            type="text"
            id="explore-search-input"
            placeholder="Buscar experiencias, patrimonio, cultura..."
            class="w-full min-w-0 border-none bg-transparent p-0 text-sm font-medium text-white placeholder-white/60 outline-none focus:ring-0"
          />
        </div>
      </div>
    </div>

    <!-- Category Chips -->
    <div
      class="no-scrollbar -mx-4 flex gap-2 overflow-x-auto px-4 pb-1"
      role="tablist"
      aria-label="Filtrar por categoría"
    >
      {
        (Object.keys(categoryLabel) as Category[]).map((cat) => (
          <button
            type="button"
            data-filter={cat}
            class={`filter-chip rounded-full border px-4 py-2 text-[12px] font-semibold transition-all active:scale-95 ${
              cat === 'todos'
                ? 'border-brand-500 bg-brand-500 text-white shadow-sm'
                : 'border-slate-200/70 bg-white text-slate-700 hover:border-brand-200 hover:bg-brand-50/60 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-brand-800 dark:hover:bg-brand-950/30 dark:hover:text-brand-400'
            }`}
            aria-pressed={cat === 'todos' ? 'true' : 'false'}
          >
            {categoryLabel[cat]}
          </button>
        ))
      }
    </div>

    <!-- Experience Sections (Horizontal Carousels) -->
    <div id="experiences-sections-container" class="space-y-6">
      {
        categories.map((cat) => {
          const catExp = todasLasExperiencias.filter(exp => exp.category === cat);
          if (catExp.length === 0) return null;
          
          return (
            <section
              data-category={cat}
              class="category-section w-full py-2 border-b border-slate-100/60 dark:border-slate-800/60 last:border-0"
            >
              <div class="mb-3 flex items-center justify-between">
                <h2 class="font-bold text-base md:text-lg tracking-tight text-slate-800 dark:text-slate-100 flex items-center gap-1.5">
                  <span class="h-2 w-2 rounded-full bg-brand-500"></span>
                  {categoryLabel[cat]}
                </h2>
                <div class="flex items-center gap-1.5">
                  <button
                    type="button"
                    class="scroll-left-btn h-7 w-7 rounded-full border border-slate-200 dark:border-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center transition-all active:scale-90"
                    title="Deslizar izquierda"
                  >
                    <span class="material-symbols-outlined text-[16px]">chevron_left</span>
                  </button>
                  <button
                    type="button"
                    class="scroll-right-btn h-7 w-7 rounded-full border border-slate-200 dark:border-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center transition-all active:scale-90"
                    title="Deslizar derecha"
                  >
                    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                  </button>
                </div>
              </div>

              <div
                class="scroll-container no-scrollbar -mx-1 flex snap-x snap-mandatory gap-4 overflow-x-auto px-1 pb-3 scroll-smooth"
              >
                {
                  catExp.map((exp) => (
                    <article
                      data-category={exp.category}
                      data-translations={exp.translations ? JSON.stringify(exp.translations) : undefined}
                      data-rating={exp.rating}
                      data-image={exp.image}
                      data-id={exp.id}
                      class={`exp-card group relative flex h-[350px] w-[250px] sm:w-[270px] flex-none snap-start flex-col overflow-hidden rounded-2xl border border-slate-200/50 dark:border-slate-800/50 bg-white dark:bg-slate-900 shadow-sm transition-all duration-300 hover:shadow-md ${exp.translations ? 'cursor-pointer' : ''}`}
                    >
                      {/* Image */}
                      <div class="relative h-44 w-full overflow-hidden rounded-t-2xl bg-slate-100 dark:bg-slate-850">
                        <img
                          src={exp.image}
                          alt={exp.title}
                          loading="lazy"
                          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                        <button
                          type="button"
                          class="favorite-btn absolute top-3 right-3 z-10 rounded-full bg-white/80 dark:bg-slate-900/80 text-neutral-700 dark:text-neutral-300 backdrop-blur-sm hover:bg-white/90 dark:hover:bg-slate-900 hover:text-rose-500 dark:hover:text-rose-400 p-1.5 transition-all shadow-sm active:scale-90"
                          title="Añadir a favoritos"
                        >
                          <svg class="h-4 w-4 fill-none stroke-current stroke-[2px]" viewBox="0 0 24 24">
                            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
                          </svg>
                        </button>
                        <span
                          class={`absolute top-3 left-3 rounded-lg px-2 py-0.5 font-bold text-[10px] uppercase tracking-wider backdrop-blur-md border ${tagStyles[exp.tagColor].badge}`}
                        >
                          {categoryLabel[exp.category]}
                        </span>
                      </div>

                      {/* Body */}
                      <div class="flex flex-1 flex-col justify-between p-4 bg-white dark:bg-slate-900">
                        <div>
                          <p class="text-slate-400 dark:text-slate-500 text-[10px] font-bold uppercase tracking-wider">
                            México / Ciudad de México
                          </p>
                          <h2 class="text-sm font-bold tracking-tight text-slate-800 dark:text-slate-100 mt-1 line-clamp-1 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                            {exp.title}
                          </h2>
                          <p class="text-slate-500 dark:text-slate-400 text-xs tracking-tight mt-1.5 line-clamp-2 leading-relaxed">
                            {exp.description}
                          </p>
                        </div>

                        {/* Footer */}
                        <div class="mt-auto pt-3 flex items-center gap-1.5 text-[11px] font-semibold text-slate-700 dark:text-slate-300 border-t border-slate-100 dark:border-slate-800/60">
                          {exp.rating && (
                            <span class="flex items-center gap-0.5 text-amber-500">
                              <span class="material-symbols-outlined text-[14px] !font-bold">star</span>
                              <span class="text-slate-800 dark:text-slate-200">{exp.rating.toFixed(2)}</span>
                            </span>
                          )}
                          {exp.reviewCount && (
                            <span class="text-slate-400 dark:text-slate-500 font-normal">
                              ({exp.reviewCount})
                            </span>
                          )}
                          {exp.price && (
                            <span class="text-slate-400 dark:text-slate-500 font-normal ml-0.5">
                              · {exp.price}
                            </span>
                          )}

                          {
                            exp.translations ? (
                              <button
                                type="button"
                                class="guide-trigger-btn ml-auto inline-flex items-center gap-1 rounded-xl bg-brand-50 hover:bg-brand-100 dark:bg-brand-950/20 dark:hover:bg-brand-950/40 text-brand-600 dark:text-brand-400 font-bold px-3 py-1.5 text-[11px] shadow-sm transition-all active:scale-[0.97]"
                              >
                                {exp.cta}
                                <span class="material-symbols-outlined text-[12px] transition-transform duration-200 group-hover:translate-x-0.5">arrow_forward</span>
                              </button>
                            ) : (
                              <a
                                href={exp.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="ml-auto inline-flex items-center gap-1 rounded-xl bg-brand-50 hover:bg-brand-100 dark:bg-brand-950/20 dark:hover:bg-brand-950/40 text-brand-600 dark:text-brand-400 font-bold px-3 py-1.5 text-[11px] shadow-sm transition-all active:scale-[0.97]"
                              >
                                {exp.cta}
                                <span class="material-symbols-outlined text-[12px] transition-transform duration-200 group-hover:translate-x-0.5">arrow_forward</span>
                              </a>
                            )
                          }
                        </div>
                      </div>
                    </article>
                  ))
                }
              </div>
            </section>
          );
        })
      }

      <!-- Empty state (shown by JS when no matches) -->
      <div
        id="empty-state"
        class="hidden flex-col items-center gap-2 rounded-2xl border border-dashed border-slate-300/60 bg-white/60 p-10 text-center dark:border-slate-700/60 dark:bg-slate-900/40"
      >
        <span class="material-symbols-outlined text-3xl text-slate-400"
          >search_off</span
        >
        <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">
          No hay experiencias en esta categoría todavía
        </p>
        <p class="text-[12px] text-slate-500 dark:text-slate-400">
          Probá con otra categoría o volvé a "Todos".
        </p>
      </div>
    </div>

    <!-- Coming Soon Footer -->
    <div
      class="flex flex-col items-center gap-3 rounded-2xl border border-slate-200/60 bg-white p-6 text-center shadow-sm dark:border-slate-800/60 dark:bg-slate-900"
    >
      <div
        class="rounded-2xl bg-brand-50 p-3 text-brand-500 dark:bg-brand-950/30 dark:text-brand-400"
      >
        <svg
          class="h-7 w-7"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
          ></path>
        </svg>
      </div>
      <div>
        <p class="text-sm font-bold text-slate-800 dark:text-slate-200">
          Más experiencias próximamente
        </p>
        <p class="mt-1 max-w-sm text-[12px] text-slate-500 dark:text-slate-400">
          Seguimos sumando proyectos, rutas y organizaciones que transforman el
          turismo y el patrimonio cultural de México.
        </p>
      </div>
      <span
        class="inline-flex items-center gap-1.5 rounded-full border border-brand-200/50 bg-brand-50 px-3 py-1 text-[11px] font-semibold text-brand-600 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-400"
      >
        <span
          class="h-1.5 w-1.5 animate-ping rounded-full bg-brand-500 dark:bg-brand-400"
        ></span>
        En construcción
      </span>
    </div>
  <!-- Museum/Guide Details Modal (Overlay) -->
  <div
    id="guide-modal"
    class="fixed inset-0 z-50 flex hidden items-center justify-center bg-black/60 p-4 backdrop-blur-md transition-opacity duration-300 opacity-0"
  >
    <div
      class="w-full max-w-lg scale-95 transform rounded-[2rem] border border-white/20 bg-white/90 dark:border-slate-800/60 dark:bg-slate-900/90 p-6 shadow-2xl backdrop-blur-2xl transition-all duration-300 flex flex-col max-h-[90vh] overflow-hidden"
    >
      <!-- Modal Header -->
      <div class="flex items-start justify-between gap-4 pb-3 border-b border-slate-100 dark:border-slate-850">
        <div>
          <span id="guide-modal-badge" class="inline-flex items-center rounded-full bg-brand-50 dark:bg-brand-950/40 text-brand-700 dark:text-brand-400 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider">
            Museo
          </span>
          <h2 id="guide-modal-title" class="text-lg font-bold text-slate-800 dark:text-white mt-1">
            Cargando...
          </h2>
        </div>
        <button
          type="button"
          id="btn-close-guide"
          class="rounded-full p-1.5 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center transition-colors"
        >
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>

      <!-- Modal Body (Scrollable) -->
      <div class="flex-1 overflow-y-auto py-4 space-y-4 no-scrollbar">
        <!-- Image Banner -->
        <div class="relative h-44 w-full overflow-hidden rounded-2xl bg-slate-100 dark:bg-slate-850">
          <img
            id="guide-modal-image"
            src=""
            alt=""
            class="h-full w-full object-cover"
          />
        </div>

        <!-- Language Selector Tabs -->
        <div class="flex gap-2 p-1 bg-slate-150 dark:bg-slate-800 rounded-xl">
          <button
            type="button"
            data-guide-lang="es"
            class="guide-lang-tab flex-1 py-2 text-[11px] font-bold rounded-lg transition-all text-brand-700 dark:text-brand-300 bg-white dark:bg-slate-700 shadow-sm"
          >
            🇪🇸 ES
          </button>
          <button
            type="button"
            data-guide-lang="en"
            class="guide-lang-tab flex-1 py-2 text-[11px] font-bold rounded-lg transition-all text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-350"
          >
            🇺🇸 EN
          </button>
          <button
            type="button"
            data-guide-lang="señas"
            class="guide-lang-tab flex-1 py-2 text-[11px] font-bold rounded-lg transition-all text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-350"
          >
            🤟 LSM
          </button>
        </div>

        <!-- Translated Content -->
        <div class="space-y-2">
          <h3 id="guide-modal-subtitle" class="font-bold text-[12px] text-slate-700 dark:text-slate-300 uppercase tracking-wider">
            Guía de Audio e Información
          </h3>
          <p id="guide-modal-text" class="text-xs leading-relaxed text-slate-600 dark:text-slate-300">
            Cargando...
          </p>
        </div>

        <!-- LSM Video Container -->
        <div id="guide-modal-video-container" class="hidden space-y-2">
          <h4 class="font-bold text-[11px] text-slate-700 dark:text-slate-300">
            Intérprete en Lengua de Señas Mexicana (LSM)
          </h4>
          <div class="relative w-full aspect-video rounded-xl overflow-hidden bg-black border border-slate-200 dark:border-slate-800">
            <iframe
              id="guide-modal-video"
              class="absolute inset-0 w-full h-full"
              src=""
              title="LSM Guide Video"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
      
      <!-- Modal Footer -->
      <div class="pt-3 border-t border-slate-100 dark:border-slate-800/80 flex items-center justify-between">
        <div class="flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px] text-amber-500" style="font-variation-settings:'FILL' 1">star</span>
          <span id="guide-modal-rating" class="text-xs font-bold text-slate-800 dark:text-slate-200">4.97</span>
        </div>
        <button
          type="button"
          id="btn-go-to-map-route"
          class="inline-flex items-center gap-1.5 rounded-xl bg-[#3f043a] hover:bg-[#3f043a]/90 text-white font-bold px-4 py-2 text-xs shadow-sm transition-all active:scale-[0.97]"
        >
          <span class="material-symbols-outlined text-[16px]">map</span>
          <span>Ver ruta en el mapa</span>
        </button>
      </div>
    </div>
  </div>

  </Layout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .filter-chip[aria-pressed='true'] {
    background-color: #3f043a;
    color: #ffffff;
    border-color: #3f043a;
  }

  .exp-card.hidden-card {
    display: none !important;
  }
  .category-section.hidden-section {
    display: none !important;
  }

  @keyframes bounce-slow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
</style>

<script>
  // Filtrado y búsqueda client-side de experiencias con secciones horizontales.
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const sections = document.querySelectorAll<HTMLElement>('.category-section');
  const emptyState = document.getElementById('empty-state');
  const searchInput = document.getElementById('explore-search-input') as HTMLInputElement;

  let activeCategory = 'todos';
  let searchQuery = '';

  function updateList() {
    let totalVisibleCount = 0;

    sections.forEach((section) => {
      const sectionCategory = section.dataset.category || '';
      const cards = section.querySelectorAll<HTMLElement>('.exp-card');
      let visibleCardsInSection = 0;

      cards.forEach((card) => {
        const title = card.querySelector('h2')?.textContent?.toLowerCase() || '';
        const desc = card.querySelector('p')?.textContent?.toLowerCase() || '';

        const matchesCategory = activeCategory === 'todos' || sectionCategory === activeCategory;
        const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery);

        const isVisible = matchesCategory && matchesSearch;
        card.classList.toggle('hidden-card', !isVisible);
        if (isVisible) {
          visibleCardsInSection++;
        }
      });

      // Si la categoría de la sección no coincide con la activa, o si no hay cartas visibles en ella, ocultamos toda la sección
      const isSectionVisible = (activeCategory === 'todos' || sectionCategory === activeCategory) && (visibleCardsInSection > 0);
      section.classList.toggle('hidden-section', !isSectionVisible);
      
      totalVisibleCount += visibleCardsInSection;
    });

    if (emptyState) {
      emptyState.classList.toggle('hidden', totalVisibleCount > 0);
      emptyState.classList.toggle('flex', totalVisibleCount === 0);
    }
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => {
        c.setAttribute('aria-pressed', 'false');
        c.classList.remove('shadow-sm');
      });
      chip.setAttribute('aria-pressed', 'true');
      chip.classList.add('shadow-sm');
      activeCategory = chip.dataset.filter ?? 'todos';
      updateList();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    updateList();
  });

  // Manejar el scroll horizontal con los botones chevron
  document.querySelectorAll('.category-section').forEach((section) => {
    const container = section.querySelector('.scroll-container');
    const leftBtn = section.querySelector('.scroll-left-btn');
    const rightBtn = section.querySelector('.scroll-right-btn');

    if (container) {
      leftBtn?.addEventListener('click', () => {
        container.scrollBy({ left: -280, behavior: 'smooth' });
      });
      rightBtn?.addEventListener('click', () => {
        container.scrollBy({ left: 280, behavior: 'smooth' });
      });
    }
  });

  // Hacer interactivos los botones de favoritos (corazón)
  document.querySelectorAll('.favorite-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const svg = btn.querySelector('svg');
      if (svg) {
        const isFavorited = svg.classList.contains('fill-rose-500');
        if (isFavorited) {
          svg.classList.remove('fill-rose-500', 'text-rose-500');
          svg.classList.add('fill-none', 'text-neutral-700', 'dark:text-neutral-300');
        } else {
          svg.classList.remove('fill-none', 'text-neutral-700', 'dark:text-neutral-300');
          svg.classList.add('fill-rose-500', 'text-rose-500');
        }
      }
    });
  });

  // Lógica del modal de guías y traducciones
  const guideModal = document.getElementById('guide-modal');
  const btnCloseGuide = document.getElementById('btn-close-guide');
  const btnGoToMapRoute = document.getElementById('btn-go-to-map-route');
  
  const guideTitle = document.getElementById('guide-modal-title');
  const guideBadge = document.getElementById('guide-modal-badge');
  const guideImage = document.getElementById('guide-modal-image') as HTMLImageElement;
  const guideText = document.getElementById('guide-modal-text');
  const guideRating = document.getElementById('guide-modal-rating');
  const guideVideoContainer = document.getElementById('guide-modal-video-container');
  const guideVideo = document.getElementById('guide-modal-video') as HTMLIFrameElement;
  
  const langTabs = document.querySelectorAll<HTMLButtonElement>('.guide-lang-tab');

  let currentTranslations: any = null;
  let activeGuideLang = 'es';
  let currentMuseumId = '';

  function openGuideModal(card: HTMLElement) {
    const rawTranslations = card.getAttribute('data-translations');
    if (!rawTranslations) return;

    try {
      currentTranslations = JSON.parse(rawTranslations);
    } catch (e) {
      console.error('Error parsing translations JSON:', e);
      return;
    }

    currentMuseumId = card.getAttribute('data-id') || '';
    const rating = card.getAttribute('data-rating') || '4.8';
    const imageSrc = card.getAttribute('data-image') || '';

    if (guideTitle) guideTitle.textContent = currentTranslations.es.name;
    if (guideImage) {
      guideImage.src = imageSrc;
      guideImage.alt = currentTranslations.es.name;
    }
    if (guideRating) guideRating.textContent = parseFloat(rating).toFixed(2);
    
    // Default a español
    setGuideLanguage('es');

    if (guideModal) {
      guideModal.classList.remove('hidden');
      // Forzar reflow
      void guideModal.offsetHeight;
      guideModal.classList.remove('opacity-0');
      const innerContent = guideModal.querySelector('div');
      if (innerContent) {
        innerContent.classList.remove('scale-95');
        innerContent.classList.add('scale-100');
      }
    }
  }

  function closeGuideModal() {
    if (guideModal) {
      guideModal.classList.add('opacity-0');
      const innerContent = guideModal.querySelector('div');
      if (innerContent) {
        innerContent.classList.remove('scale-100');
        innerContent.classList.add('scale-95');
      }
      setTimeout(() => {
        guideModal.classList.add('hidden');
        if (guideVideo) guideVideo.src = ''; // Detener video si se está reproduciendo
      }, 300);
    }
  }

  function setGuideLanguage(lang: string) {
    activeGuideLang = lang;
    if (!currentTranslations || !currentTranslations[lang]) return;

    const data = currentTranslations[lang];

    if (guideTitle) guideTitle.textContent = data.name;
    if (guideBadge) guideBadge.textContent = data.category;
    if (guideText) guideText.textContent = data.guide;

    // Actualizar tabs activas visualmente
    langTabs.forEach((tab) => {
      const isSelected = tab.getAttribute('data-guide-lang') === lang;
      tab.classList.toggle('bg-white', isSelected);
      tab.classList.toggle('dark:bg-slate-700', isSelected);
      tab.classList.toggle('shadow-sm', isSelected);
      tab.classList.toggle('text-brand-700', isSelected);
      tab.classList.toggle('dark:text-brand-300', isSelected);
      
      tab.classList.toggle('text-slate-500', !isSelected);
      tab.classList.toggle('dark:text-slate-400', !isSelected);
      tab.classList.toggle('hover:text-slate-700', !isSelected);
      tab.classList.toggle('dark:hover:text-slate-350', !isSelected);
    });

    // Manejar video de LSM
    if (lang === 'señas' && data.videoUrl) {
      if (guideVideoContainer) guideVideoContainer.classList.remove('hidden');
      if (guideVideo) guideVideo.src = data.videoUrl;
    } else {
      if (guideVideoContainer) guideVideoContainer.classList.add('hidden');
      if (guideVideo) guideVideo.src = '';
    }
  }

  // Escuchar clics en tarjetas de museos
  document.querySelectorAll<HTMLElement>('.exp-card[data-translations]').forEach((card) => {
    card.addEventListener('click', (e) => {
      // Ignorar si pulsó el botón de favoritos
      const target = e.target as HTMLElement;
      if (target.closest('.favorite-btn')) return;

      openGuideModal(card);
    });
  });

  // Escuchar clics en los tabs de idioma
  langTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const lang = tab.getAttribute('data-guide-lang');
      if (lang) setGuideLanguage(lang);
    });
  });

  btnCloseGuide?.addEventListener('click', closeGuideModal);
  
  // Cerrar haciendo clic afuera del modal
  guideModal?.addEventListener('click', (e) => {
    if (e.target === guideModal) {
      closeGuideModal();
    }
  });

  // Redirigir al mapa con la ruta activa
  btnGoToMapRoute?.addEventListener('click', () => {
    if (currentMuseumId) {
      window.location.href = `/mapa?route=${currentMuseumId}&play=true`;
    }
  });
</script>
