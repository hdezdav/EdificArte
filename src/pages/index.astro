    <div id="experiences-sections-container" class="space-y-6">
      {
        categories.map((cat) => {
          const catExp = cat === 'turismo'
            ? [...todasLasExperiencias.filter(exp => exp.category === cat), ...TOURS.map(toExperience)]
            : cat === 'sitio-remoto'
              ? todasLasExperiencias.filter(exp => exp.category === 'sitio-remoto' || exp.category === 'cultura' || exp.category === 'patrimonio')
              : todasLasExperiencias.filter(exp => exp.category === cat);
          if (catExp.length === 0) return null;

          return (
            <section
              data-category={cat}
              data-render-categories={cat === 'sitio-remoto' ? "sitio-remoto,cultura,patrimonio" : cat}
