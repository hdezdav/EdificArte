---
import Layout from '../layouts/Layout.astro';
import DemoOne from '../components/ui/demo.tsx';

type Category = 'todos' | 'turismo' | 'patrimonio' | 'cultura' | 'gastronomia';

interface Experience {
  id: string;
  title: string;
  description: string;
  image: string;
  category: Exclude<Category, 'todos'>;
  tagColor: 'emerald' | 'brand' | 'amber' | 'rose';
  url: string;
  cta: string;
}

const experiencias: Experience[] = [
  {
    id: 'turismo-regenerativo',
    title: 'Turismo Regenerativo México',
    description:
      'Experiencias inmersivas con comunidades locales que impulsan el cambio social y la regeneración cultural.',
    image:
      'https://images.unsplash.com/photo-1518709268805-4e9042af2176?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'turismo',
    tagColor: 'emerald',
    url: 'https://turismoregenerativomexico.com',
    cta: 'Conoce más',
  },
  {
    id: 'fundacion-edificarte',
    title: 'Fundación EdificARTE',
    description:
      'Preservamos el patrimonio arquitectónico y cultural de México a través de la educación y la tecnología.',
    image:
      'https://images.unsplash.com/photo-1564507592333-c60657eea523?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'patrimonio',
    tagColor: 'brand',
    url: 'https://www.fundacionedificate.org/',
    cta: 'Visitar sitio',
  },
  {
    id: 'casa-lamm',
    title: 'Casa Lamm — Cultura & Academia',
    description:
      'Centro cultural en una casona porfiriana de la CDMX: exposiciones, librería, taller de arte y academia de historia del arte.',
    image:
      'https://images.unsplash.com/photo-1545987796-200677ee1011?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'cultura',
    tagColor: 'amber',
    url: 'https://casalamm.com.mx/',
    cta: 'Ver agenda',
  },
  {
    id: 'mercado-san-juan',
    title: 'Mercado de San Juan',
    description:
      'Gastronomía local en su máxima expresión: quesos artesanales, carnes exóticas, dulces tradicionales y chef en residencia.',
    image:
      'https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'gastronomia',
    tagColor: 'rose',
    url: 'https://www.mercadodesanjuan.com.mx/',
    cta: 'Visitar mercado',
  },
  {
    id: 'cdmx-walks',
    title: 'CDMX Heritage Walks',
    description:
      'Recorridos guiados a pie por el Centro Histórico: arquitectura virreinal, murales contemporáneos y leyendas populares.',
    image:
      'https://images.unsplash.com/photo-1518105779142-d975f22f1b0a?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'turismo',
    tagColor: 'emerald',
    url: 'https://cdmxheritage.com/',
    cta: 'Reservar tour',
  },
  {
    id: 'museo-anahuacalli',
    title: 'Museo Anahuacalli',
    description:
      'Pirámide de basalto diseñada por Diego Rivera para albergar su colección de arte prehispánico, rodeada de reserva ecológica.',
    image:
      'https://images.unsplash.com/photo-1585123334904-845d60e97b29?auto=format&fit=crop&w=800&h=500&q=80',
    category: 'patrimonio',
    tagColor: 'brand',
    url: 'https://www.museoanahuacalli.org.mx/',
    cta: 'Conoce más',
  },
];

const tagStyles: Record<
  Experience['tagColor'],
  { badge: string; pill: string }
> = {
  emerald: {
    badge:
      'border-emerald-200/50 bg-emerald-50 text-emerald-700 dark:border-emerald-800/50 dark:bg-emerald-950/40 dark:text-emerald-400',
    pill: 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-400',
  },
  brand: {
    badge:
      'border-brand-200/50 bg-brand-50 text-brand-700 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-400',
    pill: 'border-brand-200 bg-brand-50 text-brand-700 dark:border-brand-800 dark:bg-brand-950/30 dark:text-brand-400',
  },
  amber: {
    badge:
      'border-amber-200/50 bg-amber-50 text-amber-700 dark:border-amber-800/50 dark:bg-amber-950/40 dark:text-amber-400',
    pill: 'border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-800 dark:bg-amber-950/30 dark:text-amber-400',
  },
  rose: {
    badge:
      'border-rose-200/50 bg-rose-50 text-rose-700 dark:border-rose-800/50 dark:bg-rose-950/40 dark:text-rose-400',
    pill: 'border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-800 dark:bg-rose-950/30 dark:text-rose-400',
  },
};

const categoryLabel: Record<Category, string> = {
  todos: 'Todos',
  turismo: 'Turismo',
  patrimonio: 'Patrimonio',
  cultura: 'Cultura',
  gastronomia: 'Gastronomía',
};
---

<Layout title="EdificARTE — Explorar">
  <!--
    El modal de selección de idioma vive en /mapa. Si el usuario llega aquí
    sin idioma elegido, mostramos un CTA suave en lugar de un redirect
    automático (que generaba loop y rompía el SEO).
  -->
  <script>
    const lang = localStorage.getItem('edificarte_lang');
    const banner = document.getElementById('lang-soft-cta');
    if (!lang && banner) {
      banner.classList.remove('hidden');
      document
        .getElementById('lang-soft-cta-link')
        ?.addEventListener('click', () => {
          window.location.href = '/mapa';
        });
    }
  </script>

  <!-- Banner suave si no hay idioma elegido -->
  <div
    id="lang-soft-cta"
    class="mb-4 flex hidden items-center justify-between gap-3 rounded-2xl border border-brand-200/50 bg-brand-50 px-4 py-3 text-sm text-brand-800 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-200"
  >
    <span class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[18px]">translate</span>
      Elegí tu idioma para empezar
    </span>
    <button
      id="lang-soft-cta-link"
      class="rounded-full bg-brand-500 px-3 py-1 text-xs font-semibold text-white hover:bg-brand-600"
      type="button"
    >
      Ir al mapa
    </button>
  </div>

  <div class="space-y-6">
    <!-- Header -->
    <div
      class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 p-6 text-white shadow-xl"
    >
      <div
        class="pointer-events-none absolute -bottom-10 -right-10 h-40 w-40 rounded-full bg-white/5 blur-xl"
      >
      </div>
      <h1 class="text-3xl font-extrabold tracking-tight">Explorar</h1>
      
      <!-- Search Input Container -->
      <div class="mt-4 relative w-full max-w-md">
        <div class="flex items-center rounded-full border border-white/20 bg-white/10 px-4 py-2.5 backdrop-blur-md transition-all focus-within:bg-white/15 focus-within:border-white/30">
          <span class="material-symbols-outlined mr-2 text-[20px] text-white/70">search</span>
          <input
            type="text"
            id="explore-search-input"
            placeholder="Buscar experiencias, patrimonio, cultura..."
            class="w-full min-w-0 border-none bg-transparent p-0 text-sm font-medium text-white placeholder-white/60 outline-none focus:ring-0"
          />
        </div>
      </div>
    </div>

    <!-- Category Chips -->
    <div
      class="no-scrollbar -mx-4 flex gap-2 overflow-x-auto px-4 pb-1"
      role="tablist"
      aria-label="Filtrar por categoría"
    >
      {
        (Object.keys(categoryLabel) as Category[]).map((cat) => (
          <button
            type="button"
            data-filter={cat}
            class={`filter-chip rounded-full border px-4 py-2 text-[12px] font-semibold transition-all active:scale-95 ${
              cat === 'todos'
                ? 'border-brand-500 bg-brand-500 text-white shadow-sm'
                : 'border-slate-200/70 bg-white text-slate-700 hover:border-brand-200 hover:bg-brand-50/60 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-brand-800 dark:hover:bg-brand-950/30 dark:hover:text-brand-400'
            }`}
            aria-pressed={cat === 'todos' ? 'true' : 'false'}
          >
            {categoryLabel[cat]}
          </button>
        ))
      }
    </div>

    <!-- Experience Grid -->
    <div id="experiences-grid" class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        experiencias.map((exp) => (
          <article
            data-category={exp.category}
            class="exp-card group flex flex-col overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md dark:border-slate-800/60 dark:bg-slate-900"
          >
            {/* Image */}
            <div class="relative h-44 overflow-hidden bg-slate-100">
              <img
                src={exp.image}
                alt={exp.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <span
                class={`absolute right-3 top-3 inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-semibold backdrop-blur-md ${tagStyles[exp.tagColor].badge}`}
              >
                {categoryLabel[exp.category]}
              </span>
            </div>

            {/* Body */}
            <div class="flex flex-1 flex-col gap-3 p-5">
              <h2 class="text-base font-bold leading-tight text-slate-800 dark:text-slate-100">
                {exp.title}
              </h2>
              <p class="line-clamp-3 text-[13px] leading-relaxed text-slate-500 dark:text-slate-400">
                {exp.description}
              </p>
              <a
                href={exp.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-auto inline-flex items-center gap-1.5 text-[12px] font-semibold text-brand-600 transition-colors hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
              >
                {exp.cta}
                <svg
                  class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                  />
                </svg>
              </a>
            </div>
          </article>
        ))
      }

      <!-- Empty state (shown by JS when no matches) -->
      <div
        id="empty-state"
        class="hidden flex-col items-center gap-2 rounded-2xl border border-dashed border-slate-300/60 bg-white/60 p-10 text-center dark:border-slate-700/60 dark:bg-slate-900/40 md:col-span-2"
      >
        <span class="material-symbols-outlined text-3xl text-slate-400"
          >search_off</span
        >
        <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">
          No hay experiencias en esta categoría todavía
        </p>
        <p class="text-[12px] text-slate-500 dark:text-slate-400">
          Probá con otra categoría o volvé a "Todos".
        </p>
      </div>
    </div>

    <!-- Coming Soon Footer -->
    <div
      class="flex flex-col items-center gap-3 rounded-2xl border border-slate-200/60 bg-white p-6 text-center shadow-sm dark:border-slate-800/60 dark:bg-slate-900"
    >
      <div
        class="rounded-2xl bg-brand-50 p-3 text-brand-500 dark:bg-brand-950/30 dark:text-brand-400"
      >
        <svg
          class="h-7 w-7"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
          ></path>
        </svg>
      </div>
      <div>
        <p class="text-sm font-bold text-slate-800 dark:text-slate-200">
          Más experiencias próximamente
        </p>
        <p class="mt-1 max-w-sm text-[12px] text-slate-500 dark:text-slate-400">
          Seguimos sumando proyectos, rutas y organizaciones que transforman el
          turismo y el patrimonio cultural de México.
        </p>
      </div>
      <span
        class="inline-flex items-center gap-1.5 rounded-full border border-brand-200/50 bg-brand-50 px-3 py-1 text-[11px] font-semibold text-brand-600 dark:border-brand-800/50 dark:bg-brand-950/40 dark:text-brand-400"
      >
        <span
          class="h-1.5 w-1.5 animate-ping rounded-full bg-brand-500 dark:bg-brand-400"
        ></span>
        En construcción
      </span>
    </div>
  </div>

  <!-- Floating AI Agent Button (Simulated) -->
  <div class="fixed bottom-24 right-4 z-40">
    <div class="relative">
      <button
        id="ai-agent-btn"
        class="group flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-tr from-brand-600 to-purple-600 text-white shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl active:scale-95 animate-bounce-slow"
        aria-label="Asistente de IA"
      >
        <!-- Glowing background ring -->
        <span class="absolute inset-0 -z-10 animate-ping rounded-full bg-purple-500/30 opacity-75"></span>
        <!-- Icon -->
        <span class="material-symbols-outlined text-[26px] transition-transform duration-300 group-hover:rotate-12">smart_toy</span>
      </button>

      <!-- AI Popover -->
      <div
        id="ai-agent-popover"
        class="hidden absolute bottom-16 right-0 mb-2 w-72 rounded-3xl border border-slate-200/50 bg-white/95 p-4 shadow-[0_8px_32px_rgba(0,0,0,0.15)] backdrop-blur-xl transition-all duration-300 text-slate-800 dark:border-slate-800/50 dark:bg-slate-900/95 dark:text-white"
      >
        <!-- Loading State View -->
        <div id="ai-agent-loading-view" class="flex flex-col items-center justify-center py-4">
          <DemoOne client:load />
        </div>

        <!-- Content State View (hidden initially) -->
        <div id="ai-agent-content-view" class="hidden flex items-start gap-3">
          <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-tr from-brand-600 to-purple-600 text-white text-base">
            <span class="material-symbols-outlined text-[18px]">smart_toy</span>
          </span>
          <div>
            <h4 class="text-[13px] font-bold text-slate-900 dark:text-white">Asistente AI de EdificARTE</h4>
            <p class="mt-1 text-[11px] leading-relaxed text-slate-600 dark:text-slate-300">
              ¡Hola! Próximamente estaré listo para responder tus preguntas sobre el patrimonio histórico, recomendarte rutas a pie y contarte las leyendas de la CDMX.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .filter-chip[aria-pressed='true'] {
    background-color: #3f043a;
    color: #ffffff;
    border-color: #3f043a;
  }

  .exp-card.hidden-card {
    display: none;
  }

  @keyframes bounce-slow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
</style>

<script>
  // Filtrado y búsqueda client-side de experiencias.
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLElement>('.exp-card');
  const emptyState = document.getElementById('empty-state');
  const searchInput = document.getElementById('explore-search-input') as HTMLInputElement;

  let activeCategory = 'todos';
  let searchQuery = '';

  function updateList() {
    let visibleCount = 0;
    cards.forEach((card) => {
      const title = card.querySelector('h2')?.textContent?.toLowerCase() || '';
      const desc = card.querySelector('p')?.textContent?.toLowerCase() || '';
      const category = card.dataset.category || '';

      const matchesCategory = activeCategory === 'todos' || category === activeCategory;
      const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery);

      const isVisible = matchesCategory && matchesSearch;
      card.classList.toggle('hidden-card', !isVisible);
      if (isVisible) visibleCount++;
    });

    if (emptyState) {
      emptyState.classList.toggle('hidden', visibleCount > 0);
      emptyState.classList.toggle('flex', visibleCount === 0);
    }
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => {
        c.setAttribute('aria-pressed', 'false');
        c.classList.remove('shadow-sm');
      });
      chip.setAttribute('aria-pressed', 'true');
      chip.classList.add('shadow-sm');
      activeCategory = chip.dataset.filter ?? 'todos';
      updateList();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    updateList();
  });

  // Toggle del Popover del Asistente IA con simulación de carga
  const aiBtn = document.getElementById('ai-agent-btn');
  const aiPopover = document.getElementById('ai-agent-popover');
  const aiLoadingView = document.getElementById('ai-agent-loading-view');
  const aiContentView = document.getElementById('ai-agent-content-view');
  let aiTimeout: number | null = null;

  if (aiBtn && aiPopover) {
    aiBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isHidden = aiPopover.classList.contains('hidden');

      if (isHidden) {
        aiPopover.classList.remove('hidden');
        aiLoadingView?.classList.remove('hidden');
        aiContentView?.classList.add('hidden');

        if (aiTimeout) clearTimeout(aiTimeout);
        aiTimeout = window.setTimeout(() => {
          aiLoadingView?.classList.add('hidden');
          aiContentView?.classList.remove('hidden');
        }, 2200);
      } else {
        aiPopover.classList.add('hidden');
        if (aiTimeout) {
          clearTimeout(aiTimeout);
          aiTimeout = null;
        }
      }
    });

    document.addEventListener('click', () => {
      aiPopover.classList.add('hidden');
      if (aiTimeout) {
        clearTimeout(aiTimeout);
        aiTimeout = null;
      }
    });

    aiPopover.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  }
</script>
