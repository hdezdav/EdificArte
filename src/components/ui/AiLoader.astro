---
/**
 * AiLoader — Loader animado estilo "Generating" letra por letra.
 *
 * Migrado desde src/components/ui/ai-loader.tsx a Astro puro. No requiere
 * hidratación: el efecto es 100% CSS, así que React no aporta nada aquí.
 *
 * Réplica del original shadcn/AI Elements con la misma estructura DOM
 * (loader-wrapper > N x loader-letter + div.loader).
 */
interface Props {
  class?: string;
  /** Texto que se anima letra por letra. Por defecto: "Generating". */
  text?: string;
}

const { class: className = '', text = 'Escuchando...' } = Astro.props;
const letters = Array.from(text);
---

<div class={`loader-wrapper ${className}`}>
  {
    letters.map((letter, i) => (
      <span
        class="loader-letter"
        style={`--i: ${i}; --total: ${letters.length}`}
      >
        {letter}
      </span>
    ))
  }
  <div class="loader"></div>
</div>

<style>
  .loader-wrapper {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    gap: 0.02em;
    padding-bottom: 0.4em;
    color: currentColor;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .loader-letter {
    display: inline-block;
    transform: translateY(0.6em);
    opacity: 0;
    animation: loader-letter-rise 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i) * 0.07s + 0.2s);
  }

  .loader {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    border-radius: 9999px;
    background: currentColor;
    transform-origin: left center;
    transform: scaleX(0);
    animation: loader-fill 1.4s cubic-bezier(0.65, 0, 0.35, 1) infinite;
    opacity: 0.7;
  }

  @keyframes loader-letter-rise {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes loader-fill {
    0% {
      transform: scaleX(0);
      transform-origin: left center;
    }
    45% {
      transform: scaleX(1);
      transform-origin: left center;
    }
    50% {
      transform: scaleX(1);
      transform-origin: right center;
    }
    100% {
      transform: scaleX(0);
      transform-origin: right center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .loader-letter,
    .loader {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>