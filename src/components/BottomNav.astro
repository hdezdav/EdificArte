---
const pathname = Astro.url.pathname;

// Helper to determine if a route is active
const isActive = (route: string) => {
  if (route === '/') {
    return pathname === '/' || pathname === '/index.html';
  }
  return pathname.startsWith(route);
};

const tabs = [
  {
    name: 'Mapa',
    path: '/mapa',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-8.25V15m-9 3h12a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0018 4.5H6a2.25 2.25 0 00-2.25 2.25v9A2.25 2.25 0 006 18z"></path>
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11.25a3 3 0 11-6 0 3 3 0 016 0z"></path>
    </svg>`,
  },
  {
    name: 'Inicio',
    path: '/',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"></path>
    </svg>`,
  },
  {
    name: 'Yo',
    path: '/yo',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
    </svg>`,
  },
];
---

<nav
  class="glassmorphism pb-safe fixed bottom-0 left-0 right-0 z-50 border-t border-slate-200/50 shadow-lg dark:border-slate-800/50"
>
  <div
    class="mx-auto flex h-16 max-w-screen-md items-center justify-around px-6"
  >
    {
      tabs.map((tab) => {
        const active = isActive(tab.path);
        return (
          <a
            href={tab.path}
            class={`group relative flex h-full w-20 flex-col items-center justify-center transition-all duration-300`}
          >
            {/* Active indicator bar */}
            {active && (
              <span class="absolute top-0 h-1 w-12 animate-pulse rounded-full bg-brand-500 dark:bg-brand-400" />
            )}

            {/* Icon Wrapper */}
            <div
              class={`transition-transform duration-300 ${
                active
                  ? 'animate-nav-active scale-110 text-brand-600 dark:text-brand-400'
                  : 'text-slate-400 group-hover:scale-105 group-hover:text-slate-600 dark:text-slate-500 dark:group-hover:text-slate-300'
              }`}
              set:html={tab.icon}
            />

            {/* Label */}
            <span
              class={`mt-1 text-[10px] font-medium transition-all duration-300 ${
                active
                  ? 'font-semibold text-brand-600 dark:text-brand-400'
                  : 'text-slate-400 group-hover:text-slate-500 dark:text-slate-500 dark:group-hover:text-slate-400'
              }`}
            >
              {tab.name}
            </span>
          </a>
        );
      })
    }
  </div>
</nav>
