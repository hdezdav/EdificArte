---
/**
 * DonationPanel — free-form USDC donation panel.
 *
 * Renders below the artesanías (tienda) section on the home page.
 * Uses window.__EDIFICARTE_DONATION_ADDRESS__ (injected server-side via
 * `define:vars` in src/pages/index.astro) as the destination. The
 * donate button handler lives inline in index.astro and reuses
 * BrowserWalletProvider from src/lib/onchain/client.ts (same pattern
 * as the cart checkout flow).
 *
 * No backend, no D1 record, no /api/orders call: user signs the tx
 * directly and we display the txHash + PolygonScan link.
 */
---

<section
  id="donation-panel"
  aria-labelledby="donation-panel-title"
  class="relative overflow-hidden rounded-3xl border border-brand-200/40 bg-gradient-to-br from-brand-50 via-white to-purple-50/60 p-5 sm:p-7 shadow-sm dark:border-brand-800/40 dark:from-brand-950/40 dark:via-slate-900 dark:to-purple-950/30"
>
  <div class="pointer-events-none absolute -top-12 -right-12 h-40 w-40 rounded-full bg-brand-500/10 blur-2xl"></div>
  <div class="pointer-events-none absolute -bottom-12 -left-12 h-40 w-40 rounded-full bg-purple-500/10 blur-2xl"></div>

  <div class="relative flex flex-col gap-4">
    <div class="flex items-start gap-3">
      <div
        class="flex h-11 w-11 flex-none items-center justify-center rounded-2xl bg-gradient-to-tr from-brand-500 to-purple-600 text-white shadow-md"
        aria-hidden="true"
      >
        <span class="material-symbols-outlined text-[22px]">volunteer_activism</span>
      </div>
      <div class="min-w-0">
        <h2
          id="donation-panel-title"
          class="text-lg sm:text-xl font-bold tracking-tight text-slate-800 dark:text-white"
        >
          Apoyá EdificARTE
        </h2>
        <p class="mt-0.5 text-[12px] sm:text-sm text-slate-500 dark:text-slate-400">
          Tu donación ayuda a mantener el proyecto. 100% va al desarrollo.
        </p>
      </div>
    </div>

    <fieldset
      class="flex flex-wrap items-center gap-2"
      aria-label="Montos sugeridos en USDC"
    >
      <legend class="sr-only">Elegí un monto sugerido o ingresá uno personalizado</legend>

      <button
        type="button"
        class="donation-chip rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-[12px] font-semibold text-slate-700 transition-all active:scale-95 hover:border-brand-300 hover:bg-brand-50/60 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-brand-700 dark:hover:bg-brand-950/40 dark:hover:text-brand-300"
        data-amount="5"
        aria-pressed="false"
      >
        $5 USDC
      </button>
      <button
        type="button"
        class="donation-chip rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-[12px] font-semibold text-slate-700 transition-all active:scale-95 hover:border-brand-300 hover:bg-brand-50/60 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-brand-700 dark:hover:bg-brand-950/40 dark:hover:text-brand-300"
        data-amount="10"
        aria-pressed="false"
      >
        $10 USDC
      </button>
      <button
        type="button"
        class="donation-chip rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-[12px] font-semibold text-slate-700 transition-all active:scale-95 hover:border-brand-300 hover:bg-brand-50/60 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-brand-700 dark:hover:bg-brand-950/40 dark:hover:text-brand-300"
        data-amount="25"
        aria-pressed="false"
      >
        $25 USDC
      </button>
      <button
        type="button"
        class="donation-chip rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-[12px] font-semibold text-slate-700 transition-all active:scale-95 hover:border-brand-300 hover:bg-brand-50/60 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-brand-700 dark:hover:bg-brand-950/40 dark:hover:text-brand-300"
        data-amount="50"
        aria-pressed="false"
      >
        $50 USDC
      </button>
      <button
        type="button"
        class="donation-chip rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-[12px] font-semibold text-slate-700 transition-all active:scale-95 hover:border-brand-300 hover:bg-brand-50/60 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-brand-700 dark:hover:bg-brand-950/40 dark:hover:text-brand-300"
        data-amount="custom"
        aria-pressed="false"
        aria-controls="donation-custom-amount"
      >
        Otro
      </button>
    </fieldset>

    <!-- Custom amount input (shown when "Otro" chip is selected) -->
    <div id="donation-custom-amount-wrapper" class="hidden">
      <label
        for="donation-custom-amount"
        class="block text-[11px] font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1"
      >
        Monto personalizado
      </label>
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[12px] font-semibold text-slate-400">$</span>
        <input
          id="donation-custom-amount"
          type="number"
          step="0.01"
          min="0.01"
          inputmode="decimal"
          placeholder="Monto en USDC"
          aria-describedby="donation-custom-amount-help"
          class="w-full rounded-xl border border-slate-200 bg-white py-2.5 pl-7 pr-20 text-sm text-slate-800 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:focus:border-brand-400"
        />
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[11px] font-semibold text-slate-400">USDC</span>
      </div>
      <p id="donation-custom-amount-help" class="mt-1 text-[10px] text-slate-400">
        Mínimo $0.01 USDC.
      </p>
    </div>

    <!-- Donate button -->
    <button
      type="button"
      id="btn-donate"
      class="w-full inline-flex items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-brand-600 to-purple-600 hover:from-brand-700 hover:to-purple-700 text-white font-bold py-3 text-xs sm:text-sm shadow-md transition-all active:scale-[0.98] disabled:opacity-60 disabled:cursor-not-allowed"
    >
      <span class="material-symbols-outlined text-[18px]" aria-hidden="true">favorite</span>
      <span id="btn-donate-label">Donar con USDC</span>
    </button>

    <!-- Status / result area -->
    <div
      id="donation-status"
      role="status"
      aria-live="polite"
      class="hidden rounded-2xl border p-3 text-[12px]"
    >
      <p id="donation-status-text" class="font-semibold"></p>
      <a
        id="donation-polygonscan-link"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-1.5 inline-flex items-center gap-1 text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 font-semibold"
      >
        Ver en PolygonScan
        <span class="material-symbols-outlined text-[14px]" aria-hidden="true">open_in_new</span>
      </a>
    </div>

    <p class="text-[10px] text-slate-400 dark:text-slate-500 text-center">
      Pagás directo desde tu wallet. Sin intermediarios. Red: Polygon · USDC.
    </p>
  </div>
</section>