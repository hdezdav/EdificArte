---
---

<div class="fixed bottom-[76px] right-4 z-40" id="ai-agent-container">
  <div class="relative">
    <!-- Floating Toggle Button -->
    <button
      id="ai-agent-btn"
      class="group flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-tr from-brand-600 to-purple-600 text-white shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl active:scale-95 animate-bounce-slow"
      aria-label="Asistente de IA"
    >
      <!-- Glowing background ring -->
      <span class="absolute inset-0 -z-10 animate-ping rounded-full bg-purple-500/30 opacity-75"></span>
      <!-- Icon -->
      <span class="material-symbols-outlined text-[26px] transition-transform duration-300 group-hover:rotate-12">smart_toy</span>
    </button>

    <!-- AI Chat Popover -->
    <div
      id="ai-agent-popover"
      class="hidden absolute bottom-16 right-0 mb-2 w-[calc(100vw-32px)] sm:w-80 h-[380px] sm:h-[420px] max-h-[calc(100vh-150px)] rounded-3xl border border-slate-200/50 bg-white/95 shadow-[0_8px_32px_rgba(0,0,0,0.15)] backdrop-blur-xl transition-all duration-300 text-slate-800 dark:border-slate-800/50 dark:bg-slate-900/95 dark:text-white [&:not(.hidden)]:flex flex-col overflow-hidden"
    >
      <!-- Header -->
      <div class="bg-gradient-to-r from-brand-600 to-purple-600 text-white p-3.5 flex items-center justify-between shadow-sm">
        <div class="flex items-center gap-2">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-white/20 text-white">
            <span class="material-symbols-outlined text-[16px]">smart_toy</span>
          </span>
          <div class="text-left">
            <h4 class="text-[12px] font-bold leading-none">Asistente EdificARTE</h4>
            <span class="text-[9px] text-emerald-300 flex items-center gap-1 font-medium mt-0.5">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span> Activo ahora
            </span>
          </div>
        </div>
        <button id="ai-agent-close" class="text-white/80 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-[18px]">close</span>
        </button>
      </div>

      <!-- Messages Area -->
      <div id="ai-agent-messages" class="flex-1 overflow-y-auto p-4 space-y-3 scrollbar-thin text-left">
        <!-- Initial Message -->
        <div class="flex items-start gap-2 max-w-[85%]">
          <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 text-[12px]">
            <span class="material-symbols-outlined text-[14px]">smart_toy</span>
          </span>
          <div class="bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-100 rounded-2xl rounded-tl-none px-3.5 py-2 text-[12px] shadow-sm leading-relaxed relative group pr-8 break-words">
            <div class="pr-2">
              ¡Hola! Soy tu asistente de <strong>EdificARTE</strong>. 🗺️<br/><br/>
              ¿Quieres que te recomiende una ruta de monumentos o te cuente la historia de algún lugar de la CDMX? ¡Pregúntame lo que quieras!
            </div>
            <button 
              class="ai-speak-btn absolute top-2 right-2 text-slate-400 hover:text-brand-600 transition-colors p-0.5"
              title="Escuchar respuesta"
            >
              <span class="material-symbols-outlined text-[16px]">volume_up</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Input Area -->
      <form id="ai-agent-form" class="border-t border-slate-100 dark:border-slate-800 p-2.5 bg-white/50 dark:bg-slate-900/50 flex gap-2 items-center">
        <button
          type="button"
          id="ai-mic-btn"
          class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-slate-50 dark:bg-slate-800 text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 hover:text-brand-600 transition-all active:scale-95 shadow-sm"
          title="Dictar mensaje (voz)"
        >
          <span class="material-symbols-outlined text-[16px]">mic</span>
        </button>
        <input
          type="text"
          id="ai-agent-input"
          placeholder="¿Qué ruta quieres hacer hoy?..."
          autocomplete="off"
          class="flex-1 min-w-0 bg-slate-50 dark:bg-slate-800 border-none rounded-full px-3.5 py-2 text-[16px] sm:text-[16px] text-slate-800 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 outline-none focus:ring-1 focus:ring-brand-500"
        />
        <button
          type="submit"
          class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-brand-600 text-white hover:bg-brand-700 active:scale-95 transition-all shadow-sm"
        >
          <span class="material-symbols-outlined text-[16px]">send</span>
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.1) transparent;
  }
  .dark .scrollbar-thin {
    scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
  }
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 2px;
  }
  .dark .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
  }
  
  @keyframes bounce-slow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
  }
</style>

<script>
  import '../scripts/ai-agent.ts';
</script>
