---
import BottomNav from '../components/BottomNav.astro';
import AiAgent from '../components/AiAgent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  fullScreen?: boolean;
}

const {
  title,
  description = 'EdificARTE — Audio guía geolocalizada y gamificación turística de monumentos históricos.',
  fullScreen = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content="#3f043a" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Google Fonts for Plus Jakarta Sans & Material Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block"
      rel="stylesheet"
    />

    <!-- Force light mode -->
    <script is:inline>
      document.documentElement.classList.remove('dark');
    </script>
  </head>
  <body
    class="flex min-h-screen flex-col bg-slate-50 font-sans text-slate-900 transition-colors duration-300 dark:bg-slate-950 dark:text-slate-100"
  >
    {
      !fullScreen && (
        <header id="site-header" class="sticky top-0 z-40 w-full border-b border-slate-200/50 bg-white/70 backdrop-blur-md dark:border-slate-800/50 dark:bg-slate-900/70">
          <div class="mx-auto flex h-14 max-w-screen-md items-center justify-between px-4">
            <div class="flex items-center gap-2">
              <span class="text-xl font-extrabold text-[#3f043a] tracking-tight">
                EdificARTE
              </span>
            </div>
          </div>
        </header>
      )
    }

    <main
      class={fullScreen
        ? 'w-full h-screen relative overflow-hidden'
        : 'mx-auto w-full max-w-screen-md flex-grow px-4 pb-24 pt-6'}
    >
      <slot />
    </main>

    <AiAgent />
    <BottomNav />

    <style is:global>
      /* Cuando hay un modal abierto, ocultamos header + BottomNav
         para que no tapen parte del contenido del modal. */
      body.modal-open #site-header,
      body.modal-open #bottom-nav {
        display: none;
      }
    </style>
  </body>
</html>

